---
interface Props {
    variant?: "default" | "alt" | "highlight";
    class?: string;
}
const { variant = "default", class: className = "" } = Astro.props;

const bgClass = {
    default: "bg-background",
    alt: "bg-surface-alt",
    highlight: "bg-highlight",
}[variant];
---

<section class:list={["py-16 md:py-24 lg:py-32", bgClass, className]}>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <slot />
    </div>
</section>
