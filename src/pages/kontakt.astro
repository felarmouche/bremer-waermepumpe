---
import Layout from "../layout/Layout.astro";
import SectionShell from "../components/SectionShell.astro";
import TrustBar from "../components/TrustBar.astro";
import FullForm from "../components/FullForm.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const title = "Wärmepumpe in Bremen anfragen – Kostenlose Ersteinschätzung";
const description =
    "Jetzt unverbindlich Eignung, Kosten und Förderung für Ihre Wärmepumpe in Bremen prüfen lassen. Kostenlose Ersteinschätzung durch einen regionalen Fachbetrieb.";
const canonical = Astro.url.href;

const trustItems = [
    { text: "Kostenfreie Ersteinschätzung" },
    { text: "Regionaler Fachbetrieb" },
    { text: "Antwort innerhalb weniger Werktage" },
    { text: "100% unverbindlich" },
];

const formFields = [
    {
        name: "name",
        label: "Ihr Name",
        type: "text" as const,
        placeholder: "Vor- und Nachname",
        required: true,
    },
    {
        name: "plz",
        label: "PLZ",
        type: "text" as const,
        placeholder: "z. B. 28195",
        required: true,
        pattern: "[0-9]{5}",
    },
    {
        name: "gebaeudetyp",
        label: "Gebäudetyp",
        type: "select" as const,
        required: true,
        options: [
            { value: "einfamilienhaus", label: "Einfamilienhaus" },
            { value: "reihenhaus", label: "Reihenhaus" },
            { value: "doppelhaushaelfte", label: "Doppelhaushälfte" },
            { value: "mehrfamilienhaus", label: "Mehrfamilienhaus" },
            { value: "eigentumswohnung", label: "Eigentumswohnung" },
        ],
    },
    {
        name: "baujahr",
        label: "Ungefähres Baujahr",
        type: "text" as const,
        placeholder: "z. B. 1965",
        required: false,
    },
    {
        name: "aktuelle_heizung",
        label: "Aktuelle Heizung",
        type: "select" as const,
        required: true,
        options: [
            { value: "gas", label: "Gasheizung" },
            { value: "oel", label: "Ölheizung" },
            { value: "nachtspeicher", label: "Nachtspeicherheizung" },
            { value: "fernwaerme", label: "Fernwärme" },
            { value: "sonstige", label: "Sonstige / Unsicher" },
        ],
    },
    {
        name: "wohnflaeche",
        label: "Wohnfläche (ca. m²)",
        type: "number" as const,
        placeholder: "z. B. 120",
        required: false,
    },
    {
        name: "email",
        label: "E-Mail",
        type: "email" as const,
        placeholder: "ihre@email.de",
        required: true,
    },
    {
        name: "telefon",
        label: "Telefon (optional)",
        type: "tel" as const,
        placeholder: "Für Rückruf",
        required: false,
    },
    {
        name: "nachricht",
        label: "Ihre Frage oder Anmerkung (optional)",
        type: "textarea" as const,
        placeholder: "z. B. Altbau, Förderung, Kosten …",
        required: false,
    },
];
---

<Layout title={title} description={description} canonical={canonical}>
    <Breadcrumb items={[
        { label: "Startseite", href: "/" },
        { label: "Kontakt" }
    ]} />
    <!-- Hero-like header -->
    <section class="bg-primary py-16 md:py-20">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
            <h1
                class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight tracking-tight"
            >
                Wärmepumpe in Bremen anfragen
            </h1>
            <p class="mt-6 text-white/85 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
                Eignung, Kosten und Förderung für Ihr Haus prüfen lassen – kostenlos und unverbindlich. Wir melden uns innerhalb weniger Werktage bei Ihnen.
            </p>
        </div>
    </section>

    <TrustBar items={trustItems} />

    <!-- Form + Sidebar -->
    <SectionShell>
        <div class="max-w-5xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
                <!-- Form (3/5) -->
                <div class="lg:col-span-3" id="formular">
                    <h2 class="text-xl md:text-2xl font-bold text-text mb-2">
                        Kostenlose Ersteinschätzung anfordern
                    </h2>
                    <p class="text-text-muted text-sm mb-6 leading-relaxed">
                        Füllen Sie das Formular aus – wir prüfen Eignung, Kosten und Fördermöglichkeiten für Ihr Haus und melden uns persönlich bei Ihnen.
                    </p>
                    <FullForm
                        formId="kontakt-form"
                        fields={formFields}
                        submitLabel="Jetzt unverbindlich anfragen"
                        showCallbackOption={true}
                    />
                </div>

                <!-- Sidebar (2/5) -->
                <aside class="lg:col-span-2 space-y-6">
                    <div class="surface-card p-6">
                        <h3 class="font-semibold text-text mb-3">Was passiert nach dem Absenden?</h3>
                        <ol class="space-y-3 text-sm text-text-muted">
                            <li class="flex items-start gap-3">
                                <span class="shrink-0 w-6 h-6 bg-primary text-white text-xs font-bold flex items-center justify-center rounded-full">1</span>
                                <span>Wir prüfen Ihre Angaben und bewerten die Eignung Ihres Hauses.</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="shrink-0 w-6 h-6 bg-primary text-white text-xs font-bold flex items-center justify-center rounded-full">2</span>
                                <span>Sie erhalten eine erste Einschätzung zu Kosten und Fördermöglichkeiten.</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="shrink-0 w-6 h-6 bg-primary text-white text-xs font-bold flex items-center justify-center rounded-full">3</span>
                                <span>Bei Interesse vereinbaren wir einen Vor-Ort-Termin mit einem regionalen Fachbetrieb.</span>
                            </li>
                        </ol>
                    </div>

                    <div class="surface-card p-6">
                        <h3 class="font-semibold text-text mb-3">Das prüfen wir für Sie</h3>
                        <ul class="space-y-2 text-sm text-text-muted">
                            <li class="flex items-start gap-2">
                                <span class="text-primary font-bold shrink-0 mt-0.5">&#10003;</span>
                                <span>Eignung Ihres Gebäudes für eine Wärmepumpe</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-primary font-bold shrink-0 mt-0.5">&#10003;</span>
                                <span>Realistische Kosteneinschätzung</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-primary font-bold shrink-0 mt-0.5">&#10003;</span>
                                <span>Fördermöglichkeiten (KfW, BAFA)</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-primary font-bold shrink-0 mt-0.5">&#10003;</span>
                                <span>Passender Wärmepumpen-Typ</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-primary font-bold shrink-0 mt-0.5">&#10003;</span>
                                <span>Altbau-Eignung und nötige Anpassungen</span>
                            </li>
                        </ul>
                    </div>

                    <div class="surface-card p-6">
                        <h3 class="font-semibold text-text mb-3">Kontakt</h3>
                        <ul class="space-y-2 text-sm text-text-muted">
                            <li>Bremen und Umgebung</li>
                            <li>E-Mail: info@waerme-guru.de</li>
                            <li>Telefon: auf Anfrage</li>
                        </ul>
                    </div>
                </aside>
            </div>
        </div>
    </SectionShell>

    <!-- Weiterführende Informationen -->
    <SectionShell variant="alt">
        <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-xl md:text-2xl font-bold text-text mb-6">
                Sie möchten sich erst informieren?
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <a href="/waermepumpe-altbau-bremen/" class="surface-card p-5 hover:border-border-strong transition-colors block cursor-pointer">
                    <h3 class="font-semibold text-text mb-1">Wärmepumpe im Altbau</h3>
                    <p class="text-text-muted text-sm">Eignung, Vorlauftemperatur und Praxisbeispiele aus Bremen.</p>
                </a>
                <a href="/waermepumpe-kosten-foerderung-bremen/" class="surface-card p-5 hover:border-border-strong transition-colors block cursor-pointer">
                    <h3 class="font-semibold text-text mb-1">Kosten & Förderung</h3>
                    <p class="text-text-muted text-sm">KfW-Förderung bis 70%, Eigenanteil und Beispielrechnungen.</p>
                </a>
            </div>
        </div>
    </SectionShell>
</Layout>
