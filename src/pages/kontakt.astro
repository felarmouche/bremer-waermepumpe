---
import Layout from "../layout/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import FullForm from "../components/FullForm.astro";
import SectionShell from "../components/SectionShell.astro";
import InternalLinkCard from "../components/InternalLinkCard.astro";

const title = "Wärmepumpe in Bremen anfragen – Kontakt";
const description = "Kontaktieren Sie uns für eine unverbindliche Beratung zur Wärmepumpe in Bremen. Rückruf, Anfrage oder allgemeine Fragen – wir sind für Sie da.";
const canonical = Astro.url.href;

const formFields = [
    {
        name: "anrede", label: "Anrede", type: "select" as const, required: false,
        options: [
            { value: "herr", label: "Herr" },
            { value: "frau", label: "Frau" },
            { value: "divers", label: "Divers" },
        ],
    },
    { name: "name", label: "Name", type: "text" as const, placeholder: "Vor- und Nachname", required: true },
    { name: "telefon", label: "Telefonnummer", type: "tel" as const, placeholder: "Für Rückrufe", required: true },
    { name: "email", label: "E-Mail-Adresse", type: "email" as const, placeholder: "Ihre E-Mail", required: true },
    {
        name: "betreff", label: "Betreff", type: "select" as const, required: true,
        options: [
            { value: "allgemein", label: "Allgemeine Anfrage" },
            { value: "eignung", label: "Eignungsprüfung" },
            { value: "kosten", label: "Kostenanfrage" },
            { value: "rueckruf", label: "Rückrufwunsch" },
        ],
    },
    { name: "nachricht", label: "Nachricht", type: "textarea" as const, placeholder: "Wie können wir Ihnen helfen?", required: false },
];
---

<Layout title={title} description={description} canonical={canonical}>
    <HeroSection
        headline="Wärmepumpe in Bremen anfragen"
        subtext="Haben Sie Fragen oder möchten Sie eine unverbindliche Ersteinschätzung? Schreiben Sie uns oder vereinbaren Sie einen Rückruf."
        primaryCTA={{ label: "Zum Kontaktformular", href: "#kontakt-form" }}
    />

    <SectionShell>
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
            <div class="lg:col-span-3">
                <FullForm
                    formId="kontakt-form"
                    submitLabel="Anfrage senden"
                    fields={formFields}
                    showCallbackOption={true}
                />
            </div>
            <div class="lg:col-span-2 space-y-6">
                <div class="surface-card p-6">
                    <h3 class="font-semibold text-text mb-3">Kontaktinformationen</h3>
                    <ul class="space-y-2 text-sm text-text-muted">
                        <li><strong class="text-text">Telefon:</strong> auf Anfrage</li>
                        <li><strong class="text-text">E-Mail:</strong> info@waerme-guru.de</li>
                        <li><strong class="text-text">Standort:</strong> Bremen</li>
                    </ul>
                </div>
                <div class="surface-card p-6">
                    <h3 class="font-semibold text-text mb-3">Servicegebiet</h3>
                    <p class="text-text-muted text-sm">
                        Wir betreuen Eigenheime in Bremen, Bremerhaven und dem direkten Umland. Sprechen Sie uns an – wir prüfen gerne, ob Ihr Standort in unserem Einzugsgebiet liegt.
                    </p>
                </div>
                <div class="notice-success p-6 border">
                    <h3 class="font-semibold text-text mb-3">Reaktionszeit</h3>
                    <p class="text-text-muted text-sm">
                        Wir melden uns in der Regel innerhalb von 1–2 Werktagen bei Ihnen – per Telefon oder E-Mail, wie Sie es wünschen.
                    </p>
                </div>
            </div>
        </div>
    </SectionShell>

    <!-- Servicegebiet -->
    <SectionShell variant="alt">
        <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">Unser Servicegebiet</h2>
        <p class="text-text-muted max-w-3xl mb-6">
            Wir sind in Bremen und Umgebung für Sie da. Unser Einzugsgebiet umfasst:
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 max-w-3xl">
            {["Bremen-Mitte", "Schwachhausen", "Horn-Lehe", "Findorff", "Obervieland", "Huchting", "Vegesack", "Bremen-Nord", "Oberneuland", "Borgfeld", "Bremerhaven", "Umland"].map((area) => (
                <div class="surface-card p-3 text-sm text-text-muted text-center">{area}</div>
            ))}
        </div>
    </SectionShell>

    <SectionShell>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <InternalLinkCard
                href="/eignungscheck/"
                title="Eignungscheck"
                description="Direkt Ihre Hausdaten senden und Eignung prüfen lassen."
            />
            <InternalLinkCard
                href="/foerdercheck/"
                title="Fördercheck"
                description="Fördermöglichkeiten für Ihre Wärmepumpe prüfen."
            />
        </div>
    </SectionShell>
</Layout>
