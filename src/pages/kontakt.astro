---
import Layout from "../layout/Layout.astro";
import SectionShell from "../components/SectionShell.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const title = "Über diesen Ratgeber – Wärmepumpe Bremen";
const description =
    "Informationen zu diesem privaten Informationsportal rund um Wärmepumpen in Bremen. Redaktioneller Ratgeber ohne kommerziellen Hintergrund.";
const canonical = Astro.url.href;
---

<Layout title={title} description={description} canonical={canonical}>
    <Breadcrumb items={[
        { label: "Startseite", href: "/" },
        { label: "Über diesen Ratgeber" }
    ]} />

    <section class="bg-primary py-16 md:py-20">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
            <h1
                class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight tracking-tight"
            >
                Über diesen Ratgeber
            </h1>
            <p class="mt-6 text-white/85 text-base sm:text-lg leading-relaxed max-w-2xl mx-auto">
                Ein privates Informationsportal rund um das Thema Wärmepumpe in Bremen und Umgebung.
            </p>
        </div>
    </section>

    <SectionShell>
        <article class="max-w-3xl space-y-6 text-text-muted leading-relaxed">
            <p>
                Dieses Portal ist ein <strong class="text-text">privates, nicht-kommerzielles Informationsangebot</strong>.
                Ziel ist es, Hausbesitzern in Bremen und Umgebung einen strukturierten Überblick zu den Themen
                Wärmepumpen-Eignung, Kosten und Förderung zu geben – ohne Verkaufsinteresse und ohne Sales-Druck.
            </p>
            <p>
                Die hier veröffentlichten Inhalte werden redaktionell zusammengetragen und auf
                dem Stand des jeweils genannten Datums wiedergegeben. Förderprogramme, technische
                Anforderungen und Preisniveaus können sich jederzeit ändern. Für eine individuelle,
                verbindliche Bewertung Ihres konkreten Hauses wenden Sie sich bitte an einen
                zugelassenen Fachbetrieb oder eine anerkannte Energieberatung.
            </p>

            <div class="notice-success rounded p-5">
                <p class="font-semibold text-text mb-2">
                    Dies ist keine Rechts-, Steuer- oder Energieberatung.
                </p>
                <p class="text-sm leading-relaxed">
                    Alle Angaben zu Kosten, Förderbeträgen und technischen Voraussetzungen sind
                    unverbindliche Orientierung. Eine belastbare Einschätzung für Ihr Gebäude
                    erhalten Sie nur durch eine individuelle Prüfung vor Ort durch einen Fachbetrieb.
                </p>
            </div>

            <h2 class="text-2xl font-bold text-text mt-10 mb-4">Weiterführende offizielle Quellen</h2>
            <p>
                Wer verbindliche Informationen zu Förderung, Anträgen und Energieberatung sucht,
                findet diese bei den offiziellen Stellen:
            </p>
            <ul class="space-y-3 list-disc list-inside">
                <li>
                    <a
                        href="https://www.kfw.de/inlandsfoerderung/Privatpersonen/Bestehende-Immobilie/Energieeffizient-sanieren/Heizungsf%C3%B6rderung-Privatpersonen-Wohngeb%C3%A4ude-Eigentum-%28458%29/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-primary hover:underline"
                    >KfW 458 – Heizungsförderung für Privatpersonen</a>
                </li>
                <li>
                    <a
                        href="https://www.bafa.de/DE/Energie/Energieeffizienz/Energieberatung/Energieberatung_Wohngebaeude/energieberatung_wohngebaeude_node.html"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-primary hover:underline"
                    >BAFA – Energieberatung für Wohngebäude</a>
                </li>
                <li>
                    <a
                        href="https://www.verbraucherzentrale-bremen.de/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-primary hover:underline"
                    >Verbraucherzentrale Bremen – unabhängige Beratung</a>
                </li>
                <li>
                    <a
                        href="https://www.energieberater-bremen.de/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-primary hover:underline"
                    >Energieberater Bremen – Fachverzeichnis</a>
                </li>
            </ul>

            <h2 class="text-2xl font-bold text-text mt-10 mb-4">Kontakt &amp; Verantwortlicher</h2>
            <p>
                Für presse- oder datenschutzbezogene Anfragen nutzen Sie bitte die
                im <a href="/impressum/" class="text-primary hover:underline">Impressum</a>
                hinterlegte E-Mail-Adresse. Angaben nach DSGVO finden Sie in der
                <a href="/datenschutz/" class="text-primary hover:underline">Datenschutzerklärung</a>.
            </p>
        </article>
    </SectionShell>

    <SectionShell variant="alt">
        <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-xl md:text-2xl font-bold text-text mb-6">
                Weiter im Ratgeber
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <a href="/waermepumpe-altbau-bremen/" class="surface-card p-5 hover:border-border-strong transition-colors block cursor-pointer">
                    <h3 class="font-semibold text-text mb-1">Wärmepumpe im Altbau</h3>
                    <p class="text-text-muted text-sm">Eignung, Vorlauftemperatur und Praxisbeispiele aus Bremen.</p>
                </a>
                <a href="/waermepumpe-kosten-foerderung/" class="surface-card p-5 hover:border-border-strong transition-colors block cursor-pointer">
                    <h3 class="font-semibold text-text mb-1">Kosten &amp; Förderung</h3>
                    <p class="text-text-muted text-sm">KfW-Förderung, Eigenanteil und Beispielrechnungen – Stand 2026.</p>
                </a>
            </div>
        </div>
    </SectionShell>
</Layout>
