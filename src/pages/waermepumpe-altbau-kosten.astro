---
import { getImage } from "astro:assets";
import Layout from "../layout/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import TrustBar from "../components/TrustBar.astro";
import CTASection from "../components/CTASection.astro";
import FAQSection from "../components/FAQSection.astro";
import SectionShell from "../components/SectionShell.astro";
import NoticeSuccess from "../components/content/NoticeSuccess.astro";
import CheckList from "../components/content/CheckList.astro";
import InternalLinkCard from "../components/InternalLinkCard.astro";
import heroImage from "../images/hero-altbau-bremen.webp";

import type { PageData } from "../types/page";

const data: PageData = {
    title: "Wärmepumpe Altbau Kosten 2026: Preise, Einbau & Förderung",
    description: "Was kostet eine Wärmepumpe im Altbau? Preise 2026 inklusive Einbau, Heizkörper und Stromkosten, dazu KfW-Förderung und der realistische Eigenanteil.",
    lastUpdated: "2. Juni 2026",
    hero: {
        headline: "Wärmepumpe Altbau Kosten",
        subtext: "Was eine Wärmepumpe im Altbau wirklich kostet – von Anschaffung und Einbau über Heizkörper bis zu den Stromkosten, samt den Posten, die im Angebot oft fehlen.",
        primaryCTA: {
            label: "Eignung & Förderung prüfen",
            href: "/check/"
        },
        secondaryCTA: {
            label: "Kosten-Übersicht Bremen",
            href: "/waermepumpe-kosten-bremen/"
        }
    },
    trustItems: [
        {
            text: "Preise inkl. Einbau"
        },
        {
            text: "Inkl. Heizkörper-Posten"
        },
        {
            text: "Stand 2. Juni 2026"
        },
        {
            text: "Förderfähige Umfeldmaßnahmen"
        }
    ],
    breadcrumb: [
        {
            label: "Startseite",
            href: "/"
        },
        {
            label: "Kosten Bremen",
            href: "/waermepumpe-kosten-bremen/"
        },
        {
            label: "Altbau Kosten"
        }
    ],
    ctaBlock: {
        headline: "Was kostet die Wärmepumpe für Ihren Altbau?",
        text: "Erste Einordnung zur Eignung Ihrer Bestandsimmobilie und zur passenden Bauart – im Browser, ohne Datenübermittlung.",
        variant: "highlight",
        primaryCTA: {
            label: "Eignung & Förderung prüfen",
            href: "/check/"
        },
        secondaryCTA: {
            label: "Eignung Altbau Bremen",
            href: "/waermepumpe-altbau-bremen/"
        }
    },
    faqHeading: "FAQ: Wärmepumpe Altbau Kosten",
    faqs: [
        {
            question: "Lohnt sich eine Wärmepumpe im Altbau wirklich?",
            answer: "In sehr vielen Bremer Altbauten ja – sofern die Vorlauftemperatur ganzjährig unter etwa 55 °C bleibt. Wer den Klimabonus mitnimmt (alte Öl-/Gasheizung) und unter der Einkommensgrenze von 40.000 Euro liegt, kann mit 70 % Förderung den Eigenanteil unter 12.000 Euro drücken. Wirtschaftlich ist die Wärmepumpe damit oft schon nach 8–12 Jahren günstiger als eine neue Gasheizung."
        },
        {
            question: "Welche Wärmepumpe ist die beste für einen Altbau ohne Fußbodenheizung?",
            answer: "In Bremer Altbauten kommen am häufigsten Hochtemperatur-Luft-Wasser-Wärmepumpen mit dem natürlichen Kältemittel R290 (Propan) zum Einsatz. Sie erzeugen problemlos 60–65 °C Vorlauftemperatur und nutzen die meist großzügig dimensionierten alten Rippenheizkörper weiter – ohne kompletten Heizkörpertausch."
        },
        {
            question: "Wie hoch sind die Stromkosten einer Wärmepumpe im Altbau?",
            answer: "Im teilsanierten Altbau (140 m², 14.000 kWh Heizwärmebedarf) liegen die Stromkosten bei einem Wärmepumpentarif um 25 ct/kWh bei rund 1.000 Euro pro Jahr. Im unsanierten Altbau mit höherer Vorlauftemperatur kann das auf 1.300–1.600 Euro steigen – immer noch deutlich unter Öl- oder Gaskosten der Vorjahre."
        },
        {
            question: "Was kostet der Einbau einer Wärmepumpe im Altbau?",
            answer: "Für ein Altbau-Reihenhaus rechnen Sie mit 24.000 bis 32.000 Euro brutto für eine Hochtemperatur-Luft-Wasser-Wärmepumpe inklusive Einbau, hydraulischem Abgleich und Inbetriebnahme. Wenn 1–2 Heizkörper getauscht werden müssen, kommen 1.500–3.000 Euro dazu (förderfähig als Umfeldmaßnahme)."
        },
        {
            question: "Lohnt sich eine Wärmepumpe im unsanierten Altbau ohne Dämmung?",
            answer: "Ja, häufig – aber die Vorlauftemperatur und damit der Stromverbrauch liegen höher. Entscheidend ist die Heizlast: Reichen die vorhandenen Heizkörper bei etwa 55–65 °C aus, arbeitet eine Hochtemperatur-Wärmepumpe wirtschaftlich. Einzelne große Heizkörper oder ein hydraulischer Abgleich sind oft günstiger als eine komplette Dämmung und als Umfeldmaßnahme förderfähig. Im unsanierten Altbau steigen vor allem die laufenden Stromkosten, nicht zwingend die Anschaffung."
        },
        {
            question: "Welche Posten sind im Altbau oft förderfähig, aber werden vergessen?",
            answer: "Häufig: hydraulischer Abgleich (1.000–1.500 €), einzelne größere Heizkörper (300–800 € pro Stück), Pufferspeicher, akustische Fachplanung bei enger Nachbarschaft, Wanddurchbrüche und Putz-/Malerarbeiten, die direkt mit dem Heizungstausch zusammenhängen. Alles fließt in die KfW-458-förderfähigen Kosten ein, sofern technisch erforderlich."
        }
    ],
    schema: {
        type: "Article",
        datePublished: "2026-05-02",
        dateModified: "2026-06-02"
    }
};

const canonical = data.canonical ?? Astro.url.href;
const hero = { ...data.hero, imageSrc: heroImage };
const ogImage = await getImage({
    src: heroImage,
    width: 1200,
    height: 630,
    fit: "cover",
    format: "jpg",
});
const dateLine = data.lastUpdated ? `Stand: ${data.lastUpdated}` : null;
const pageSchema = data.schema
    ? {
          ...data.schema,
          datePublished: data.schema.datePublished ?? data.schema.dateModified,
          dateModified: data.schema.dateModified ?? data.schema.datePublished,
      }
    : undefined;
---

<Layout
    title={data.title}
    description={data.description}
    canonical={canonical}
    ogImage={ogImage.src}
    noindex={data.noindex}
    pageSchema={pageSchema}
>
    {data.breadcrumb?.length > 0 && <Breadcrumb items={data.breadcrumb} />}
    <HeroSection {...hero} />
    {data.trustItems?.length > 0 && <TrustBar items={data.trustItems} />}
    {dateLine && (
        <div class="bg-background border-b border-border">
            <p class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-text-muted">
                {dateLine} · Redaktion bremer-waermepumpe.de · Alle Angaben ohne Gewähr
            </p>
        </div>
    )}

{/* Intro */}
<SectionShell>
  <article class="max-w-3xl space-y-4 text-text-muted leading-relaxed">
    <div class="bg-highlight border border-border rounded p-5">
      <p class="font-bold text-text mb-2">Schnelle Antwort: Was kostet eine Wärmepumpe im Altbau?</p>
      <p class="text-sm leading-relaxed">
        Eine Wärmepumpe im Altbau liegt inklusive Einbau häufig bei
        <strong class="text-text">23.000 bis 37.000 €</strong> vor Förderung. Mit
        KfW 458 sinkt der Eigenanteil je nach Boni oft auf
        <strong class="text-text">unter 15.000 €</strong>. Wie hoch er genau ausfällt,
        hängt davon ab, ob eine alte Öl- oder Gasheizung getauscht wird und ob
        Effizienzbonus, Einkommensbonus und förderfähige Umfeldmaßnahmen sauber
        genutzt werden.
      </p>
    </div>
    <p>
      „Eine Wärmepumpe im Altbau ist viel teurer als im Neubau" – das stimmt nur halb. Was
      stimmt: Im Altbau gibt es mehr Posten, die in das Gesamtangebot einfließen können.
      Was nicht stimmt: Das macht die Wärmepumpe automatisch unwirtschaftlich. Im
      Gegenteil – im Altbau profitieren Eigentümer am häufigsten vom
      <strong class="text-text"> Klimageschwindigkeitsbonus</strong> (Tausch alter Öl-
      oder Gas-Heizungen) und holen damit bis zu 50 % der Investition über die KfW zurück.
    </p>
    <p>
      Diese Seite behandelt bewusst die <strong class="text-text">Kostenfrage</strong>:
      Welche Posten im Altbau-Angebot stehen sollten, was den Preis nach oben treibt,
      welche Posten förderfähig sind und mit welchem Eigenanteil Eigentümer 2026
      realistisch rechnen können. Die technische Machbarkeit steht separat auf der
      Eignungsseite.
    </p>
    <NoticeSuccess>
      <p>
        Bevor es um Kosten geht, sollte die <strong>Eignung</strong> stehen. Auf der Detailseite <a href="/waermepumpe-altbau-bremen/" class="text-brand underline">Wärmepumpe im Altbau Bremen</a> prüfen wir Vorlauftemperatur, Heizkörper und Hydraulik.
      </p>
    </NoticeSuccess>
  </article>
</SectionShell>

{/* Kostenrahmen Altbau */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Was kostet eine Wärmepumpe im Altbau? Preise inkl. Einbau
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Eine grobe Einordnung der Preise für Altbau-Objekte (Bestandsimmobilien älter als 30
    Jahre, teilsaniert oder unsaniert) – inklusive Einbau:
  </p>

  <div class="surface-card overflow-hidden max-w-2xl divide-y divide-border">
    <div class="grid grid-cols-2 px-5 py-4 text-sm">
      <span class="text-text-muted">Hochtemperatur-Luft-Wärmepumpe (R290)</span>
      <span class="font-semibold text-text text-right">14.000 – 22.000 €</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm">
      <span class="text-text-muted">Installation, Hydraulik, Inbetriebnahme</span>
      <span class="font-semibold text-text text-right">7.000 – 11.000 €</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm">
      <span class="text-text-muted">Hydraulischer Abgleich</span>
      <span class="font-semibold text-text text-right">1.000 – 1.500 €</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm">
      <span class="text-text-muted">1–3 Heizkörpertausch (falls nötig)</span>
      <span class="font-semibold text-text text-right">600 – 2.500 €</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm">
      <span class="text-text-muted">Akustische Fachplanung (Reihenhaus)</span>
      <span class="font-semibold text-text text-right">400 – 800 €</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm bg-highlight">
      <span class="font-semibold text-text">Gesamtspanne (typisch)</span>
      <span class="font-bold text-primary text-right">23.000 – 37.000 €</span>
    </div>
  </div>

  <p class="text-text-muted max-w-3xl text-sm leading-relaxed mt-6">
    Wichtig: Die meisten dieser Posten sind <strong class="text-text">förderfähig als Umfeldmaßnahmen</strong>, sofern sie technisch im Zusammenhang mit dem Heizungstausch erforderlich sind. Der hydraulische Abgleich ist sogar verpflichtende Voraussetzung für die KfW-Förderung.
  </p>
</SectionShell>

{/* Kostentreiber im Altbau */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Was treibt die Kosten im Altbau? Sanierungsgrad, Heizkörper, Wärmequelle
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Warum der gleiche Heizungstausch im Altbau einmal 24.000 € und einmal 37.000 € kostet,
    liegt vor allem an drei Faktoren – nicht am Gerät allein:
  </p>
  <div class="surface-card overflow-hidden max-w-3xl divide-y divide-border">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1.6fr] gap-1 px-5 py-4 text-sm">
      <span class="font-semibold text-text">Sanierungsgrad</span>
      <span class="text-text-muted">Saniert oder teilsaniert hält die Vorlauftemperatur niedrig – die Wärmepumpe wird kleiner und günstiger. Im unsanierten Altbau ohne Dämmung steigt vor allem der laufende Stromverbrauch, nicht zwingend die Anschaffung.</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1.6fr] gap-1 px-5 py-4 text-sm">
      <span class="font-semibold text-text">Heizkörper &amp; Vorlauftemperatur</span>
      <span class="text-text-muted">Reichen die vorhandenen Heizkörper bei niedriger Vorlauftemperatur, entfällt ein großer Posten. Müssen einzelne Heizkörper getauscht werden, kostet das 300–800 € pro Stück – als Umfeldmaßnahme meist förderfähig.</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1.6fr] gap-1 px-5 py-4 text-sm">
      <span class="font-semibold text-text">Wärmequelle &amp; Bauart</span>
      <span class="text-text-muted">Die Luft-Wasser-Wärmepumpe ist im Altbau am günstigsten. Eine Erdwärmepumpe ist effizienter, aber durch Bohrung oder Kollektor deutlich teurer und im dicht bebauten Bestand oft nicht umsetzbar.</span>
    </div>
  </div>
  <p class="text-text-muted max-w-3xl text-sm leading-relaxed mt-6">
    Ob eine <strong class="text-text">monovalente</strong> Wärmepumpe (allein heizend) ausreicht
    oder ein <strong class="text-text">bivalenter</strong> Betrieb mit Spitzenlast-Unterstützung
    sinnvoller ist, entscheidet die Heizlastberechnung – sie beeinflusst die Auslegung und damit
    den Preis. Die technische Eignung prüfen wir auf der Seite
    <a href="/waermepumpe-altbau-bremen/" class="text-brand underline">Wärmepumpe im Altbau</a>;
    die Bauart-Kosten im Detail stehen unter
    <a href="/luft-wasser-waermepumpe-kosten/" class="text-brand underline">Luft-Wasser-Wärmepumpe Kosten</a>.
  </p>
</SectionShell>

{/* Rechen-Szenario Altbau */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Rechen-Szenario: Altbau-Reihenhaus mit alter Gasheizung
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Das folgende Szenario ist keine behauptete Kundenreferenz, sondern eine
    transparente Modellrechnung für ein typisches Altbau-Objekt in Bremen. Es zeigt,
    welche Positionen ein Angebot enthalten sollte und wie die Förderung den
    Eigenanteil verändert.
  </p>

  <div class="surface-card overflow-hidden max-w-2xl divide-y divide-border">
    <div class="grid grid-cols-2 px-5 py-4 text-sm">
      <span class="text-text-muted">R290-Luft-Wasser-Wärmepumpe</span>
      <span class="font-semibold text-text text-right">17.500 €</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm">
      <span class="text-text-muted">Installation, Hydraulik, Speicher</span>
      <span class="font-semibold text-text text-right">9.500 €</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm">
      <span class="text-text-muted">Hydraulischer Abgleich</span>
      <span class="font-semibold text-text text-right">1.200 €</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm">
      <span class="text-text-muted">Akustische Fachplanung Reihenhaus</span>
      <span class="font-semibold text-text text-right">600 €</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm bg-highlight">
      <span class="font-semibold text-text">Modellhafte Investition</span>
      <span class="font-bold text-primary text-right">28.800 €</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm">
      <span class="text-text-muted">KfW 458: 30 % Basis + 20 % Klimabonus + 5 % Effizienzbonus</span>
      <span class="font-semibold text-text text-right">55 %</span>
    </div>
    <div class="grid grid-cols-2 px-5 py-4 text-sm bg-highlight">
      <span class="font-semibold text-text">Eigenanteil nach Zuschuss</span>
      <span class="font-bold text-primary text-right">ca. 12.960 €</span>
    </div>
  </div>
  <p class="text-text-muted max-w-3xl text-sm leading-relaxed mt-6">
    Liegt zusätzlich der Einkommensbonus vor, kann die Förderquote bis zur 70-%-Grenze
    steigen. Entscheidend ist aber immer die konkrete BzA und das förderfähige Angebot.
  </p>
</SectionShell>

{/* Welche Posten sind förderfähig? */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Welche Altbau-spezifischen Posten sind förderfähig?
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Im Altbau lohnt es sich besonders, alle förderfähigen Umfeldmaßnahmen sauber im
    KfW-Antrag aufzulisten. Häufig vergessen, aber förderfähig:
  </p>
  <CheckList
    items={[
      "Hydraulischer Abgleich (KfW-Pflicht für Förderung)",
      "Einzelne größere Heizkörper, falls für niedrige Vorlauftemperatur erforderlich",
      "Pufferspeicher und Warmwasserspeicher",
      "Akustische Fachplanung (TA-Lärm-konforme Aufstellung)",
      "Wanddurchbrüche, Leitungswege, Putz- und Malerarbeiten im direkten Zusammenhang",
      "Statisch erforderliche Fundamentplatten oder Schallschutzsockel",
      "Smarte Regelung und Heizungssteuerung",
      "Energieeffizienz-Experten-Honorar (BzA + BnD)",
    ]}
  />
  <p class="text-text-muted max-w-3xl text-sm mt-6">
    Was <strong class="text-text">nicht förderfähig</strong> ist: reine Schönheitsreparaturen
    ohne technischen Zusammenhang, neue Möbel/Einbauten, Eigenleistung. Auch eine reine
    Dämmungs- oder Fenstermaßnahme läuft nicht über KfW 458, sondern über separate
    BAFA-/KfW-Programme.
  </p>
</SectionShell>

{/* Häufige Mythen */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Drei Mythen rund um Wärmepumpe und Altbau-Kosten
  </h2>
  <div class="space-y-5 max-w-3xl">
    <div class="surface-card p-5">
      <p class="font-semibold text-text mb-2">„Wärmepumpe geht nur mit Fußbodenheizung."</p>
      <p class="text-text-muted text-sm">
        Stimmt nicht. Im Altbau sind die alten Rippenheizkörper oft überdimensioniert –
        bei niedriger Vorlauftemperatur reicht ihre Fläche völlig aus. Genau das nutzen
        Hochtemperatur-Wärmepumpen mit R290 als Stärke.
      </p>
    </div>
    <div class="surface-card p-5">
      <p class="font-semibold text-text mb-2">„Im unsanierten Haus rechnet sich das nie."</p>
      <p class="text-text-muted text-sm">
        Differenzierter sehen. Bei alter Öl- oder Gasheizung greifen Klimabonus +
        Effizienzbonus + ggf. Einkommensbonus. Wer 60–70 % Förderung mitnimmt, kommt
        oft mit Eigenanteilen unter 12.000 € raus – das amortisiert sich gegen weiter
        steigende CO₂-Preise.
      </p>
    </div>
    <div class="surface-card p-5">
      <p class="font-semibold text-text mb-2">„Im Reihenhaus geht das nicht wegen der Lärmgrenzen."</p>
      <p class="text-text-muted text-sm">
        TA Lärm gilt, ist aber lösbar. Moderne R290-Wärmepumpen unterschreiten die
        nächtlichen Richtwerte bei sauberer Aufstellung, und die akustische Fachplanung
        ist als Umfeldmaßnahme förderfähig. Die konkreten Abstands- und Lärmregeln für
        Bremen stehen unter
        <a href="/waermepumpe-abstand-nachbar-bremen/" class="text-brand underline">Abstand zum Nachbarn</a>.
      </p>
    </div>
  </div>
</SectionShell>

{/* Quellen */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Quellen und redaktioneller Stand
  </h2>
  <div class="surface-card p-5 max-w-3xl text-sm text-text-muted leading-relaxed">
    <p class="font-semibold text-text mb-3">Stand: 2. Juni 2026</p>
    <ul class="space-y-2">
      <li>
        KfW: <a href="https://www.kfw.de/inlandsfoerderung/Privatpersonen/Bestehende-Immobilie/F%C3%B6rderprodukte/Heizungsf%C3%B6rderung-f%C3%BCr-Privatpersonen-Wohngeb%C3%A4ude-%28458%29/" class="text-primary underline" target="_blank" rel="noopener">Heizungsförderung 458</a>
      </li>
      <li>
        BAFA: <a href="https://www.bafa.de/DE/Energie/Effiziente_Gebaeude/Sanierung_Wohngebaeude/Heizungsoptimierung/heizungsoptimierung_node.html" class="text-primary underline" target="_blank" rel="noopener">Heizungsoptimierung</a>
      </li>
      <li>
        swb: <a href="https://www.swb.de/strom/thermo-pronatur" class="text-primary underline" target="_blank" rel="noopener">Wärmepumpenstrom swb thermo proNatur</a>
      </li>
      <li>
        Kostenangaben sind redaktionelle Spannen für die Erstorientierung und ersetzen keine Heizlastberechnung oder ein verbindliches Angebot.
      </li>
    </ul>
  </div>
</SectionShell>

{/* Cluster-Crosslinks */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">
    Vertiefen
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl">
    <InternalLinkCard
      href="/waermepumpe-kosten-bremen/"
      title="Kosten Bremen (Hub)"
      description="Übersicht über alle Bauarten und realistische Eigenanteile in Bremen."
    />
    <InternalLinkCard
      href="/waermepumpe-altbau-bremen/"
      title="Altbau – Eignung prüfen"
      description="Vorlauftemperatur, Heizlast, Heizkörper – die technische Voraussetzung."
    />
    <InternalLinkCard
      href="/luft-wasser-waermepumpe-kosten/"
      title="Luft-Wasser-Wärmepumpe Kosten"
      description="Kosten der häufigsten Bauart im Detail: Gerät, Einbau und Stromverbrauch."
    />
    <InternalLinkCard
      href="/waermepumpe-foerderung-bremen/"
      title="Förderung & KfW 458"
      description="KfW 458 mit bis zu 70 % Zuschuss – inklusive Klimabonus."
    />
    <InternalLinkCard
      href="/check/"
      title="Altbau-Check"
