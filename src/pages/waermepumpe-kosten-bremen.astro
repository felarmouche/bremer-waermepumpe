---
import Layout from "../layout/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import TrustBar from "../components/TrustBar.astro";
import CTASection from "../components/CTASection.astro";
import FAQSection from "../components/FAQSection.astro";
import SectionShell from "../components/SectionShell.astro";
import NoticeSuccess from "../components/content/NoticeSuccess.astro";
import CheckList from "../components/content/CheckList.astro";
import InternalLinkCard from "../components/InternalLinkCard.astro";
import heroImage from "../images/heat-pump-bremen-hero.webp";

import type { PageData } from "../types/page";

const data: PageData = {
    title: "Wärmepumpe Kosten Bremen 2026: Preise & Stromkosten",
    description: "Wärmepumpe Kosten Bremen 2026: realistische Preise nach Bauart, Bremer Kostentreiber und swb-Wärmepumpentarif verständlich eingeordnet.",
    lastUpdated: "Mai 2026",
    hero: {
        headline: "Wärmepumpe Kosten Bremen",
        subtext: "Was eine Wärmepumpe in Bremen wirklich kostet – nach Wärmequelle, mit lokalen Kostentreibern und laufenden Stromkosten.",
        primaryCTA: {
            label: "Eignung & Förderung prüfen",
            href: "/check/"
        },
        secondaryCTA: {
            label: "Welche Förderung gibt es?",
            href: "/waermepumpe-foerderung-bremen/"
        }
    },
    trustItems: [
        {
            text: "Bremer Stromtarif eingerechnet"
        },
        {
            text: "Stand Mai 2026"
        },
        {
            text: "BremLBO + TA Lärm berücksichtigt"
        },
        {
            text: "Realistischer Eigenanteil"
        }
    ],
    breadcrumb: [
        {
            label: "Startseite",
            href: "/"
        },
        {
            label: "Kosten Bremen"
        }
    ],
    ctaBlock: {
        headline: "Was kostet die Wärmepumpe für Ihr Haus?",
        text: "Der Browser-Check liefert eine erste Einschätzung zur passenden Bauart und groben Investition – ohne Datenübermittlung, in wenigen Minuten.",
        variant: "highlight",
        primaryCTA: {
            label: "Eignung & Förderung prüfen",
            href: "/check/"
        },
        secondaryCTA: {
            label: "Welche Förderung gibt es?",
            href: "/waermepumpe-foerderung-bremen/"
        }
    },
    faqHeading: "FAQ: Wärmepumpe Kosten Bremen",
    faqs: [
        {
            question: "Was kostet eine Wärmepumpe in Bremen 2026 realistisch?",
            answer: "Für ein Bremer Einfamilienhaus liegen Luft-Wasser-Wärmepumpen inklusive Installation typischerweise bei 22.000 bis 35.000 Euro brutto, Sole-Wasser-Wärmepumpen mit Erdsondenbohrung bei 30.000 bis 45.000 Euro. Der tatsächliche Eigenanteil lässt sich erst nach einem Angebot und einer Prüfung der dann geltenden Förderkonditionen seriös bestimmen."
        },
        {
            question: "Wie viel Förderung gibt es für eine Wärmepumpe in Bremen?",
            answer: "Für den Heizungstausch ist in der Regel die KfW-Heizungsförderung 458 relevant. Die Höhe hängt unter anderem von Antragstermin, Gebäude, Eigentums- und Nutzungssituation ab. Aktuelle Konditionen und Bremer Förderwege stehen zentral auf der Seite Wärmepumpe Förderung Bremen."
        },
        {
            question: "Wie hoch sind die Stromkosten einer Wärmepumpe in Bremen?",
            answer: "Die swb (Stadtwerke Bremen) bietet einen Wärmepumpentarif mit aktuell 24,98 ct/kWh (Stand Mai 2026). Bei einem Bremer Einfamilienhaus mit etwa 4.000 kWh Wärmepumpenstrom pro Jahr ergeben sich rund 1.000 Euro Jahresstromkosten. Im sanierten Bestand ist auch deutlich weniger möglich, im unsanierten Altbau entsprechend mehr."
        },
        {
            question: "Lohnt sich eine Wärmepumpe in einem Bremer Altbau?",
            answer: "In vielen Fällen ja. Entscheidend ist nicht das Baujahr, sondern die Vorlauftemperatur. Wenn das Haus ganzjährig mit unter 55 °C Vorlauf auskommt, sind die Bedingungen gut. Die Detailprüfung steht auf der Seite Wärmepumpe Altbau Bremen."
        },
        {
            question: "Was muss ich beim Aufstellort in Bremen beachten?",
            answer: "Die Bremer Landesbauordnung erlaubt für Wärmepumpen-Außengeräte einen Grenzabstand von 0 Metern (BremLBO §6 Abs. 8 Nr. 4) – ein klarer Bremen-Vorteil gegenüber den meisten anderen Bundesländern, wo 3 Meter gelten. Trotzdem zu beachten: TA Lärm mit nächtlichen Grenzwerten von 35 dB(A) im reinen Wohngebiet und 45 dB(A) im Mischgebiet."
        }
    ],
    schema: {
        type: "Article",
        datePublished: "2026-05-02",
        dateModified: "2026-07-15"
    }
};

const canonical = data.canonical ?? Astro.url.href;
const hero = { ...data.hero, imageSrc: heroImage };
const dateLine = data.lastUpdated ? `Stand: ${data.lastUpdated}` : null;
const pageSchema = data.schema
    ? {
          ...data.schema,
          datePublished: data.schema.datePublished ?? data.schema.dateModified,
          dateModified: data.schema.dateModified ?? data.schema.datePublished,
      }
    : undefined;
---

<Layout
    title={data.title}
    description={data.description}
    canonical={canonical}
    noindex={data.noindex}
    pageSchema={pageSchema}
>
    {data.breadcrumb?.length > 0 && <Breadcrumb items={data.breadcrumb} />}
    <HeroSection {...hero} />
    {data.trustItems?.length > 0 && <TrustBar items={data.trustItems} />}
    {dateLine && (
        <div class="bg-background border-b border-border">
            <p class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-text-muted">
                {dateLine} · Redaktion bremer-waermepumpe.de · Alle Angaben ohne Gewähr
            </p>
        </div>
    )}

{/* Intro: Bremen-Kontext */}
<SectionShell>
  <article class="max-w-3xl">
    <div class="bg-highlight border border-border rounded p-5 mb-8">
      <p class="font-bold text-text mb-2">
        Schnelle Antwort: Was kostet eine Wärmepumpe in Bremen?
      </p>
      <p class="text-text-muted text-sm leading-relaxed">
        Für Bremer Einfamilienhäuser liegt eine Luft-Wasser-Wärmepumpe inklusive
        Einbau typischerweise bei <strong class="text-text">22.000 bis 35.000 €</strong>
        vor Förderung. Der Eigenanteil hängt vom konkreten Angebot und den zum
        Antragstermin geltenden <a href="/waermepumpe-foerderung-bremen/" class="text-brand underline">Förderkonditionen</a>
        ab und wird deshalb hier nicht pauschal beziffert. Der laufende Strombedarf hängt an der Jahresarbeitszahl; mit dem swb-Tarif
        <strong class="text-text"> thermo proNatur</strong> lag der Arbeitspreis
        Anfang 2026 bei <strong class="text-text">24,98 ct/kWh</strong>.
      </p>
    </div>
    <p class="text-text-muted leading-relaxed">
      In Bremen liegt der Wärmepumpen-Marktanteil laut KfW-Energiewendebarometer 2025 bei rund <strong class="text-text">2 %</strong> – deutlich unter dem Bundesschnitt von etwa 8 %. Das hat zwei Konsequenzen: Erstens gibt es vor Ort weniger Vergleichswerte, und zweitens findet man im Netz oft generische Deutschland-Preise, die für Bremen nicht stimmen. Diese Seite ordnet die <strong class="text-text">Wärmepumpen-Kosten für Bremen 2026</strong> realistisch ein – inklusive lokaler Faktoren wie swb-Stromtarif, BremLBO und Lärmrahmen.
    </p>
    <NoticeSuccess class="mt-6">
      <p>
        <strong>Hinweis der Redaktion (Stand Mai 2026):</strong> Alle Preise sind
        Marktbeobachtungen und Erfahrungswerte aus dem Bremer Raum. Eine verbindliche
        Kostenermittlung erfolgt durch ein Angebot eines Fachbetriebs. Die
        Verbraucherzentrale Bremen bietet für Bremer Haushalte eine kostenpflichtige
        Angebotsanalyse mit drei Heizungsbauer-Angeboten – das ist eine sehr gute
        Vergleichsgrundlage.
      </p>
    </NoticeSuccess>
  </article>
</SectionShell>

{/* Kostenrahmen nach Wärmequelle */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Was kostet eine Wärmepumpe in Bremen? Überblick nach Bauart
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Die Bauart der Wärmepumpe bestimmt den größten Teil der Investition. In Bremen
    dominieren Luft-Wasser-Wärmepumpen, weil sie ohne Bohrung auskommen und in
    Reihenhauszeilen einfacher unterzubringen sind.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="surface-card p-5">
      <h3 class="font-semibold text-text">Luft-Wasser-Wärmepumpe</h3>
      <p class="text-2xl font-bold text-primary my-2">22.000 – 35.000 €</p>
      <p class="text-text-muted text-sm">
        Inklusive Außengerät, Inneneinheit, Installation und Inbetriebnahme. Häufigste
        Wahl im Bremer Bestand.
      </p>
    </div>
    <div class="surface-card p-5">
      <h3 class="font-semibold text-text">Sole-Wasser-Wärmepumpe (Erdsonde)</h3>
      <p class="text-2xl font-bold text-primary my-2">30.000 – 45.000 €</p>
      <p class="text-text-muted text-sm">
        Höhere Effizienz, aber Tiefenbohrung in Bremen genehmigungspflichtig
        (Gewässerschutz). Oft im freistehenden Einfamilienhaus mit Garten sinnvoll.
      </p>
    </div>
    <div class="surface-card p-5">
      <h3 class="font-semibold text-text">Wasser-Wasser-Wärmepumpe</h3>
      <p class="text-2xl font-bold text-primary my-2">35.000 – 55.000 €</p>
      <p class="text-text-muted text-sm">
        Höchste Effizienz, in Bremen wegen Grundwasser-Zugänglichkeit oft denkbar – aber
        wasserrechtliche Erlaubnis erforderlich. Im MVP eher Nische.
      </p>
    </div>
  </div>

  <p class="text-text-muted max-w-3xl text-sm mt-6">
    Diese Spannen umfassen das Komplettpaket: Gerät, Montage, Hydraulik und Inbetriebnahme.
    Zusätzliche Arbeiten wie Heizkörpertausch oder Wanddurchbrüche müssen im Angebot
    separat erfasst werden. Ob sie in die Förderung einbezogen werden können, erklärt
    die <a href="/kfw-458-waermepumpe/" class="text-brand underline">aktuelle KfW-458-Detailseite</a>.
  </p>
</SectionShell>

{/* Bremer Faktoren */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Welche Bremer Faktoren beeinflussen die Kosten?
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Ob die Wärmepumpe am unteren oder oberen Ende der Spanne liegt, entscheiden vor allem
    diese Punkte – und hier hat Bremen einige Eigenheiten:
  </p>
  <CheckList
    items={[
      { lead: "Heizflächen:", text: "Klassische Bremer Reihenhäuser haben oft alte, großzügige Rippenheizkörper. Diese können bei niedriger Vorlauftemperatur weiter genutzt werden – das spart vier- bis fünfstellige Beträge gegenüber einem kompletten Heizkörpertausch." },
      { lead: "Aufstellort:", text: "Die BremLBO erlaubt 0 m Grenzabstand für Außengeräte (§6 Abs. 8 Nr. 4) – in den meisten anderen Bundesländern sind 3 m Pflicht. In dichten Reihenhauszeilen (Viertel, Neustadt, Findorff) ist das ein echter Bremen-Vorteil." },
      { lead: "Schallschutz:", text: "TA Lärm gilt trotzdem: 35 dB(A) nachts im reinen Wohngebiet, 45 dB(A) im Mischgebiet. Eine akustische Fachplanung sichert die Einhaltung – manchmal wird ein Schallschutzsockel oder eine durchdachte Aufstellung gegenüber der Reihenhausgrenze nötig." },
      { lead: "Sanierungsstand:", text: "Bei Altbauten in Schwachhausen, Findorff oder dem Viertel kann ein hydraulischer Abgleich, ein punktueller Heizkörpertausch oder eine zusätzliche Dämmung erforderlich sein. Diese Posten gehören transparent ins Angebot." },
      { lead: "Elektrik:", text: "Häufig muss der Hausanschluss leicht verstärkt oder ein separater Stromzähler für den Wärmepumpentarif gesetzt werden. Im Komplettangebot meist mit drin, separat aufgelistet." },
    ]}
  />
</SectionShell>

{/* Stromkosten */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Wie hoch sind die Stromkosten in Bremen?
  </h2>
  <p class="text-text-muted max-w-3xl mb-4">
    Die laufenden Kosten der Wärmepumpe hängen am Strompreis. In Bremen bietet die
    <strong class="text-text"> swb (Stadtwerke Bremen)</strong> einen separaten
    Wärmepumpentarif – Stand Mai 2026 liegt dieser bei <strong class="text-text">24,98 ct/kWh</strong>
    (alle Preise inklusive Steuern und Abgaben, Tarif kann sich ändern).
  </p>
  <div class="surface-card p-5 max-w-2xl my-6">
    <p class="font-semibold text-text mb-3">Beispielrechnung Bremer Einfamilienhaus (140 m², teilsaniert)</p>
    <ul class="space-y-2 text-sm">
      <li class="flex justify-between">
        <span class="text-text-muted">Heizwärmebedarf</span>
        <span class="text-text">14.000 kWh/Jahr</span>
      </li>
      <li class="flex justify-between">
        <span class="text-text-muted">Jahresarbeitszahl (JAZ) realistisch</span>
        <span class="text-text">3,5</span>
      </li>
      <li class="flex justify-between">
        <span class="text-text-muted">Stromverbrauch Wärmepumpe</span>
        <span class="text-text">~ 4.000 kWh/Jahr</span>
      </li>
      <li class="flex justify-between border-t border-border pt-2 mt-2 font-semibold">
        <span class="text-text">Stromkosten swb-WP-Tarif</span>
        <span class="text-text">~ 1.000 €/Jahr</span>
      </li>
    </ul>
  </div>
  <p class="text-text-muted max-w-3xl text-sm">
    Vergleichswert: Ein konventioneller Haushaltsstromtarif in Bremen liegt 2026 bei
    rund 38–42 ct/kWh. Der Wärmepumpentarif spart also etwa 13–17 ct/kWh – bei 4.000 kWh
    sind das rund 500–700 Euro pro Jahr Differenz allein über den Tarif. Voraussetzung:
    separater Zähler, der vom Heizungsbauer mit eingeplant wird.
  </p>
</SectionShell>

{/* Förderung bewusst delegiert */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Vom Angebot zum realistischen Eigenanteil
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Der Eigenanteil lässt sich nicht dauerhaft mit einer pauschalen Förderquote
    berechnen. Dafür ändern sich Konditionen zu häufig und die förderfähigen Kosten
    hängen zu stark vom Einzelfall ab. Für eine belastbare Planung brauchen Sie:
  </p>
  <CheckList
    items={[
      { lead: "Vollständiges Angebot:", text: "Gerät, Montage, Hydraulik, Elektroarbeiten, Heizflächen und Schallschutz getrennt ausweisen lassen." },
      { lead: "Technische Prüfung:", text: "Nur notwendige und sauber dokumentierte Projektbestandteile können für die Förderprüfung berücksichtigt werden." },
      { lead: "Aktuelle Konditionen:", text: "Förderregeln erst zum geplanten Antragstermin aus der zentral gepflegten Förderübersicht übernehmen." },
    ]}
  />
  <p class="text-text-muted max-w-3xl text-sm mt-6">
    Prüfen Sie dafür die <a href="/waermepumpe-foerderung-bremen/" class="text-brand underline">aktuellen Förderwege in Bremen</a>
    und anschließend die <a href="/kfw-458-waermepumpe/" class="text-brand underline">KfW-458-Konditionen im Detail</a>.
  </p>
</SectionShell>

{/* Was Sie sparen vs. neue Gasheizung */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Lohnt sich das gegenüber einer neuen Gasheizung?
  </h2>
  <p class="text-text-muted max-w-3xl mb-4">
    Eine neue Gasheizung in einem Bremer Bestandsgebäude kostet typischerweise 12.000
    bis 18.000 Euro – ohne nennenswerte Förderung. Auf den ersten Blick günstiger. Auf
    20 Jahre gerechnet kippt das Bild aber:
  </p>
  <ul class="space-y-3 max-w-3xl">
    <li class="flex items-start gap-3">
      <span class="text-primary font-bold mt-0.5 shrink-0">→</span>
      <span class="text-text-muted">CO₂-Preis steigt bis 2027 stufenweise weiter, danach ETS 2 (europäischer Emissionshandel) – Gas wird im Betrieb teurer.</span>
    </li>
    <li class="flex items-start gap-3">
      <span class="text-primary font-bold mt-0.5 shrink-0">→</span>
      <span class="text-text-muted">GEG §71 ab 01.07.2026 in Bremen: 65 % EE-Pflicht beim Heizungstausch. Reine Gasheizung ist dann nur noch in Übergangsfällen zulässig.</span>
    </li>
    <li class="flex items-start gap-3">
      <span class="text-primary font-bold mt-0.5 shrink-0">→</span>
      <span class="text-text-muted">Wärmepumpen-Stromtarif (swb 24,98 ct/kWh) plus Eigenstrom aus Photovoltaik macht die Wärmepumpe oft schon im Betrieb günstiger als Gas.</span>
    </li>
  </ul>
  <p class="text-text-muted max-w-3xl text-sm mt-4">
    Den vollständigen Vergleich von Anschaffung, Förderung, Betriebskosten und GEG-Pflicht
    finden Sie auf der Detailseite <a href="/waermepumpe-oder-gasheizung-bremen/" class="text-brand underline">Wärmepumpe oder Gasheizung in Bremen</a>.
    Eine belastbare Wirtschaftlichkeitsrechnung liefert aber nur eine Energieberatung,
    die Ihre tatsächlichen Verbrauchsdaten kennt.
  </p>
</SectionShell>

{/* Quellen */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Quellen und redaktioneller Stand
  </h2>
  <div class="surface-card p-5 max-w-3xl text-sm text-text-muted leading-relaxed">
    <p class="font-semibold text-text mb-3">Stand: 29. Mai 2026</p>
    <ul class="space-y-2">
      <li>
        swb: <a href="https://www.swb.de/strom/thermo-pronatur" class="text-primary underline" target="_blank" rel="noopener">Wärmepumpenstrom swb thermo proNatur</a>
      </li>
      <li>
        Bremen: <a href="https://www.transparenz.bremen.de/metainformationen/bremische-landesbauordnung-vom-29-mai-2024-232736" class="text-primary underline" target="_blank" rel="noopener">Bremische Landesbauordnung</a>
      </li>
      <li>
        Kostenangaben sind redaktionelle Marktspannen und ersetzen kein verbindliches Fachbetriebsangebot.
      </li>
    </ul>
  </div>
</SectionShell>

{/* Cluster-Crosslinks */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">
    Vertiefen: Kosten im Detail
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl">
    <InternalLinkCard
      href="/gasheizung-umruesten-auf-waermepumpe-kosten/"
      title="Gasheizung auf Wärmepumpe umrüsten"
      description="Kosten für Ausbau, Heizkörper, Elektrik und den vollständigen Wechsel."
    />
    <InternalLinkCard
      href="/waermepumpe-altbau-kosten/"
      title="Wärmepumpe Altbau Kosten"
      description="Kostenrahmen für Bestandsgebäude inkl. Heizkörper- und Sanierungs-Posten."
    />
    <InternalLinkCard
      href="/luft-wasser-waermepumpe-kosten/"
      title="Luft-Wasser-Wärmepumpe Kosten"
      description="Detailaufschlüsselung der häufigsten Bauart in Bremen."
    />
    <InternalLinkCard
      href="/waermepumpe-kosten-einfamilienhaus/"
      title="Kosten Einfamilienhaus"
      description="Nach Wohnfläche (100/150/200 m²) und Bauart – mit Amortisationsrechnung."
    />
    <InternalLinkCard
      href="/waermepumpe-foerderung-bremen/"
      title="Förderung Bremen"
      description="Welche Förderung deckt diese Kosten ab? KfW 458, BAFA, BAB."
    />
    <InternalLinkCard
      href="/waermepumpe-altbau-bremen/"
      title="Altbau Bremen – Eignung"
      description="Bevor es um Kosten geht: Funktioniert die Wärmepumpe in Ihrem Altbau überhaupt?"
    />
    <InternalLinkCard
      href="/check/"
      title="Eignungs- und Fördercheck"
      description="Erste Einordnung im Browser – ohne Anmeldung."
    />
  </div>
</SectionShell>

    {data.ctaBlock && <CTASection {...data.ctaBlock} />}
    {data.faqs?.length > 0 && (
        <FAQSection heading={data.faqHeading} items={data.faqs} />
    )}
</Layout>
