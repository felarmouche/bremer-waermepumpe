---
import { getImage } from "astro:assets";
import Layout from "../layout/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import TrustBar from "../components/TrustBar.astro";
import CTASection from "../components/CTASection.astro";
import FAQSection from "../components/FAQSection.astro";
import SectionShell from "../components/SectionShell.astro";
import NoticeSuccess from "../components/content/NoticeSuccess.astro";
import CheckList from "../components/content/CheckList.astro";
import InternalLinkCard from "../components/InternalLinkCard.astro";
import heroImage from "../images/foerderung-bremen-hero.webp";

import type { PageData } from "../types/page";

const data: PageData = {
    title: "Wärmepumpe Förderung 2026: Was sich ändert (KfW, GEG, Lärm)",
    description:
        "Wärmepumpe Förderung 2026: Neue KfW-458-Konditionen ab 21. Juli (28.000 €, Klimabonus 16 %), Kürzungen ab Februar 2027, GEG-Reform, neue Lärmgrenzen. Geprüft am 15. Juli 2026.",
    lastUpdated: "15. Juli 2026",
    hero: {
        headline: "Wärmepumpe Förderung 2026",
        subtext:
            "Was sich 2026 ändert: neue KfW-458-Konditionen seit dem 21. Juli (28.000 € förderfähige Kosten, Klimabonus 16 %, gestaffelter Einkommensbonus), verschärfte Lärmgrenzen seit Januar – und das GEG wird durch das Gebäudemodernisierungsgesetz abgelöst. Die wichtigsten Updates auf einen Blick.",
        primaryCTA: {
            label: "Eignung & Förderung prüfen",
            href: "/check/"
        },
        secondaryCTA: {
            label: "Förderung Bremen",
            href: "/waermepumpe-foerderung-bremen/"
        }
    },
    trustItems: [
        {
            text: "Geprüft am 15. Juli 2026"
        },
        {
            text: "KfW 458: bis zu 70 % (80 % Sonderfall)"
        },
        {
            text: "Neue Konditionen seit 21.07.2026"
        },
        {
            text: "Kürzungen ab Februar 2027"
        }
    ],
    breadcrumb: [
        {
            label: "Startseite",
            href: "/"
        },
        {
            label: "Förderung Bremen",
            href: "/waermepumpe-foerderung-bremen/"
        },
        {
            label: "Förderung 2026"
        }
    ],
    ctaBlock: {
        headline: "Lohnt sich Ihr Heizungstausch unter den 2026er-Bedingungen?",
        text: "Der Browser-Check ordnet Ihre Förderfähigkeit unter den aktuellen 2026er-Regeln ein – unverbindlich & kostenlos. Kontaktdaten werden erst nach ausdrücklicher Einwilligung an den unter /fachpartner/ genannten Bremer Betrieb weitergegeben.",
        variant: "highlight",
        primaryCTA: {
            label: "Eignung & Förderung prüfen",
            href: "/check/"
        },
        secondaryCTA: {
            label: "KfW 458 im Detail",
            href: "/kfw-458-waermepumpe/"
        }
    },
    faqHeading: "FAQ: Wärmepumpe Förderung 2026",
    faqs: [
        {
            question: "Wie hoch ist die Wärmepumpenförderung 2026?",
            answer: "Der Kauf und Einbau einer Wärmepumpe wird 2026 über die KfW-Heizungsförderung 458 bezuschusst – mit bis zu 70 % der förderfähigen Kosten, für Haushalte mit dem höchsten Einkommensbonus bis 80 %. Seit dem 21. Juli 2026 berücksichtigt die KfW bei der ersten Wohneinheit höchstens 28.000 Euro (zuvor 30.000 Euro); daraus ergeben sich je nach Boni bis zu 22.400 Euro Zuschuss."
        },
        {
            question: "Wird die Wärmepumpenförderung 2026 gekürzt oder läuft sie aus?",
            answer: "Sie läuft weiter, wird aber schrittweise gekürzt: Seit dem 21. Juli 2026 gelten 28.000 Euro Höchstbetrag und 16 % Klimageschwindigkeitsbonus (zuvor 30.000 Euro und 20 %), der Effizienzbonus ist gestrichen. Ab dem 1. Februar 2027 sinken Höchstbetrag (−750 Euro) und Klimabonus (−4 Prozentpunkte) zusätzlich jedes halbe Jahr. Ein Enddatum des Programms ist nicht beschlossen – aber je später der Antrag, desto niedriger der Zuschuss."
        },
        {
            question: "Bis wann gibt es den Klimageschwindigkeitsbonus?",
            answer: "Der Klimageschwindigkeitsbonus beträgt seit dem 21. Juli 2026 noch 16 % (zuvor 20 %). Ab dem 1. Februar 2027 sinkt er halbjährlich – jeweils zum 1. Februar und 1. August – um 4 Prozentpunkte und läuft nach diesem Fahrplan zum 1. August 2028 aus. Maßgeblich ist das Datum der Antragstellung, nicht der Inbetriebnahme. Wer den Tausch der alten Öl- oder Gasheizung ohnehin plant, profitiert am stärksten, solange der Bonus noch hoch ist."
        },
        {
            question: "Welche Wärmepumpen sind 2026 noch förderfähig?",
            answer: "Förderfähig sind 2026 Wärmepumpen, die die technischen Effizienzkriterien erfüllen und die seit dem 1. Januar 2026 verschärften Schallanforderungen einhalten: geförderte Luft/Wasser-Wärmepumpen müssen mindestens 10 dB unter den EU-Ökodesign-Grenzwerten liegen (vorher 5 dB). Praktisch bedeutet das maximal 60 dB(A) Schallleistungspegel bei 6–12 kW und 55 dB(A) bei kleineren Geräten. Welche Modelle die Kriterien erfüllen, steht in der BAFA-Liste der förderfähigen Wärmepumpen; der Zuschuss selbst läuft über KfW 458."
        },
        {
            question: "Was wird 2026 aus dem Heizungsgesetz (GEG)?",
            answer: "Das Bundeskabinett hat am 13. Mai 2026 den Entwurf für ein neues Gebäudemodernisierungsgesetz (GModG) beschlossen, das das Gebäudeenergiegesetz (GEG 2024) ablösen soll. Die starre 65-%-Erneuerbare-Pflicht beim Heizungstausch entfällt zugunsten einer technologieoffeneren Regelung mit einer Grüngas-/Grünöl-Stufe ab 2029. Der ursprüngliche Stichtag 1. Juli 2026 wurde verschoben; das Gesetz soll später im Jahr 2026 in Kraft treten. Bundestag und Bundesrat müssen noch zustimmen – bis dahin gilt formal das GEG 2024. Die Wärmepumpe bleibt in jedem Fall die wirtschaftlichste Lösung mit den höchsten Boni."
        },
        {
            question: "Welche Voraussetzungen gelten 2026 für die KfW-458-Förderung?",
            answer: "Bestandsgebäude (Bauantrag mindestens 5 Jahre alt), eine förderfähige Wärmepumpe (Effizienz- und seit 2026 verschärfte Schallanforderungen), eine Bestätigung zum Antrag (BzA) durch einen Energieeffizienz-Experten oder ein zugelassenes Fachunternehmen, ein Liefer-/Leistungsvertrag mit aufschiebender oder auflösender Förderbedingung, der Antrag bei „Meine KfW\" vor Maßnahmenbeginn sowie der hydraulische Abgleich. Diese Voraussetzungen sind 2026 gegenüber 2025 unverändert."
        }
    ],
    schema: {
        type: "Article",
        datePublished: "2026-05-02",
        dateModified: "2026-07-15"
    }
};

const canonical = data.canonical ?? Astro.url.href;
const hero = { ...data.hero, imageSrc: heroImage };
const ogImage = await getImage({
    src: heroImage,
    width: 1200,
    height: 630,
    fit: "cover",
    format: "jpg",
});
const dateLine = data.lastUpdated ? `Stand: ${data.lastUpdated}` : null;
const pageSchema = data.schema
    ? {
          ...data.schema,
          datePublished: data.schema.datePublished ?? data.schema.dateModified,
          dateModified: data.schema.dateModified ?? data.schema.datePublished,
      }
    : undefined;
---

<Layout
    title={data.title}
    description={data.description}
    canonical={canonical}
    ogImage={ogImage.src}
    noindex={data.noindex}
    pageSchema={pageSchema}
>
    {data.breadcrumb?.length > 0 && <Breadcrumb items={data.breadcrumb} />}
    <HeroSection {...hero} />
    {data.trustItems?.length > 0 && <TrustBar items={data.trustItems} />}
    {dateLine && (
        <div class="bg-background border-b border-border">
            <p class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-text-muted">
                {dateLine} · Redaktion bremer-waermepumpe.de · Alle Angaben ohne Gewähr
            </p>
        </div>
    )}

{/* Answer-first: Kurzantwort */}
<SectionShell>
  <article class="max-w-3xl">
    <div class="surface-card p-6 sm:p-8 border-l-4 border-primary">
      <p class="text-xs font-semibold text-primary uppercase tracking-wide mb-3">
        Kurzantwort
      </p>
      <p class="text-text leading-relaxed text-base sm:text-lg">
        2026 ist das Jahr der Förder-Wende: Seit dem{" "}
        <strong>21. Juli 2026</strong> gelten neue KfW-458-Konditionen –
        <strong>28.000 € förderfähige Kosten</strong> für die erste Wohneinheit
        (zuvor 30.000 €), <strong>Klimabonus 16 %</strong> (zuvor 20 %),
        Einkommensbonus gestaffelt auf 40/30/10 %, Effizienzbonus gestrichen.
        Gedeckelt wird bei <strong>70 %</strong>, für die niedrigsten Einkommen
        bei 80 %. Ab dem <strong>1. Februar 2027</strong> wird zusätzlich
        halbjährlich gekürzt. Daneben gelten <strong>verschärfte Lärmgrenzen
        seit dem 1. Januar 2026</strong>, und das GEG soll durch das neue{" "}
        <strong>Gebäudemodernisierungsgesetz</strong> abgelöst werden.
      </p>
    </div>
    <p class="text-text-muted leading-relaxed mt-6">
      Diese Seite fasst alle 2026er-Änderungen für Eigentümer in Deutschland
      kompakt zusammen: was seit wann gilt, was gestrichen wurde und was ab 2027
      absehbar ist. Berechnungsdetails und Sonderfälle bleiben bewusst auf den
      verlinkten Fachseiten, damit sich die Inhalte nicht gegenseitig Konkurrenz
      machen.
    </p>
    <NoticeSuccess class="mt-6">
      <p>
        <strong>Verfasser:</strong>
        <a href="/kontakt/" class="text-primary underline">Ferris El-Armouche</a>.
        Quellenstand: 15. Juli 2026. Diese private Informationsseite ersetzt keine
        verbindliche Förderberatung oder Förderzusage. Maßgeblich sind die
        Bedingungen von KfW, BAFA und den jeweils gültigen Gesetzen zum Zeitpunkt
        Ihrer Antragstellung.
      </p>
    </NoticeSuccess>
  </article>
</SectionShell>

{/* GEG → GModG Reform */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Heizungsgesetz 2026: GEG wird zum Gebäudemodernisierungsgesetz
  </h2>
  <p class="text-text-muted max-w-3xl mb-4">
    Die größte Änderung 2026 ist politischer Natur: Das Bundeskabinett hat am{" "}
    <strong class="text-text">13. Mai 2026</strong> den Entwurf für ein neues{" "}
    <strong class="text-text">Gebäudemodernisierungsgesetz (GModG)</strong>{" "}
    beschlossen, das das Gebäudeenergiegesetz (GEG 2024) ablösen soll. Was das
    für Wärmepumpen-Pläne bedeutet:
  </p>
  <CheckList
    items={[
      { lead: "65-%-Pflicht entfällt:", text: "Die starre Vorgabe, dass neue Heizungen zu 65 % erneuerbar betrieben werden müssen, wird durch eine technologieoffenere Regelung ersetzt." },
      { lead: "Grüngas-/Grünöl-Stufe ab 2029:", text: "Statt der Pflicht steigt der Anteil erneuerbarer Brennstoffe für Gas- und Ölheizungen ab 2029 schrittweise an („Bio-Treppe\")." },
      { lead: "Stichtag verschoben:", text: "Der ursprüngliche Termin 1. Juli 2026 ist hinfällig; das neue Gesetz soll später im Jahr 2026 in Kraft treten." },
      { lead: "Noch nicht final:", text: "Es handelt sich um einen Kabinettsentwurf. Bundestag und Bundesrat müssen noch zustimmen – bis dahin gilt formal das GEG 2024." },
      { lead: "Wärmepumpe bleibt erste Wahl:", text: "Unabhängig von der konkreten Pflicht ist die Wärmepumpe weiterhin die wirtschaftlichste Lösung – und nur sie sichert die vollen KfW-Boni." },
    ]}
  />
  <p class="text-text-muted max-w-3xl text-sm mt-6">
    Wichtig: Die Förderung ist von der Gesetzesreform getrennt. Wer 2026 eine
    Wärmepumpe einbaut, erhält die KfW-Förderung unabhängig davon, wann das GModG
    final in Kraft tritt.
  </p>
</SectionShell>

{/* Klimabonus-Staffelung */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Klimageschwindigkeitsbonus: 16 % seit 21. Juli, ab 2027 fallend
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Der Klimabonus belohnt den Tausch alter fossiler Heizungen. Der
    Haushaltsausschuss des Bundestages hat am 8. Juli 2026 beschlossen, ihn
    schrittweise abzubauen: Seit dem <strong class="text-text">21. Juli 2026</strong>{" "}
    beträgt er <strong class="text-text">16 %</strong> (zuvor 20 %). Ab dem{" "}
    <strong class="text-text">1. Februar 2027</strong> sinkt er halbjährlich –
    jeweils zum 1. Februar und 1. August – um{" "}
    <strong class="text-text">4 Prozentpunkte</strong> und läuft nach diesem
    Fahrplan zum 1. August 2028 aus. Parallel schmilzt der Förderhöchstbetrag
    der ersten Wohneinheit im selben Rhythmus um je 750 € ab.
  </p>
  <p class="text-text-muted max-w-3xl text-sm">
    Maßgeblich ist das Datum der Antragstellung, nicht der Inbetriebnahme.
    Was das in Euro bedeutet, zeigt der
    <a href="/kfw-458-waermepumpe/#foerder-fahrplan" class="text-brand underline">Kürzungsfahrplan
    mit Rechenbeispielen auf der KfW-458-Detailseite</a>.
  </p>
</SectionShell>

{/* Verschärfte Lärmgrenzen */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Verschärfte Lärmgrenzen seit 1. Januar 2026
  </h2>
  <p class="text-text-muted max-w-3xl mb-4">
    Seit Jahresbeginn 2026 müssen geförderte Luft/Wasser-Wärmepumpen{" "}
    <strong class="text-text">mindestens 10 dB unter den Grenzwerten der
    EU-Ökodesign-Verordnung</strong> liegen – vorher reichten 5 dB. Daraus
    ergeben sich diese praktischen Förder-Obergrenzen für den Schallleistungspegel:
  </p>

  <div class="surface-card p-5 max-w-2xl my-6">
    <ul class="text-sm space-y-2">
      <li class="flex justify-between">
        <span class="text-text-muted">Wärmepumpen 6–12 kW Heizleistung</span>
        <span class="font-semibold text-text">max. 60 dB(A)</span>
      </li>
      <li class="flex justify-between border-t border-border pt-2 mt-2">
        <span class="text-text-muted">Wärmepumpen unter 6 kW</span>
        <span class="font-semibold text-text">max. 55 dB(A)</span>
      </li>
      <li class="flex justify-between border-t border-border pt-2 mt-2">
        <span class="text-text-muted">größere Anlagen</span>
        <span class="font-semibold text-text">nach Geräteklasse / Ökodesign</span>
      </li>
    </ul>
  </div>

  <p class="text-text-muted max-w-3xl text-sm">
    Praktisch heißt das: Geräte, die diese Grenzen reißen, sind seit dem 1. Januar
    2026 nicht mehr KfW-458-förderfähig – obwohl sie baurechtlich weiterhin zulässig
    sein können. Es gibt keine Übergangsfrist. Der Markt hat reagiert: aktuelle
    Modelle (2025/26) erfüllen die neuen Werte in der Regel. Wer ein älteres
    Restposten-Gerät einbaut, sollte den Schallleistungspegel im Datenblatt prüfen,
    sonst entfällt die Förderung.
  </p>
</SectionShell>

{/* Förderfähige Wärmepumpen 2026 / BAFA-Liste */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Welche Wärmepumpen sind 2026 förderfähig?
  </h2>
  <p class="text-text-muted max-w-3xl mb-4">
    Ob eine Wärmepumpe 2026 gefördert wird, hängt an zwei Bedingungen: Sie muss
    die technischen <strong class="text-text">Effizienzkriterien</strong> erfüllen
    und die seit Januar 2026 verschärften <strong class="text-text">Schallanforderungen</strong>{" "}
    einhalten. Welche konkreten Modelle das erfüllen, ist amtlich gelistet:
  </p>
  <CheckList
    items={[
      { lead: "BAFA-Liste der förderfähigen Wärmepumpen:", text: "Das BAFA pflegt im Wärmeerzeuger-Portal die offizielle Liste der förderfähigen Geräte (Luft/Wasser, Sole/Wasser, Wasser/Wasser, Luft/Luft). Steht ein Modell dort, ist die technische Voraussetzung erfüllt." },
      { lead: "Zuschuss läuft über die KfW:", text: "Seit 2024 fördert die KfW (Programm 458) den Kauf und Einbau – nicht das BAFA. Das BAFA ist für die Liste sowie für Heizungsoptimierung und Energieberatung zuständig." },
      { lead: "Effizienzbonus gestrichen:", text: "Der frühere 5-%-Bonus für natürliche Kältemittel (z. B. R290/Propan) bzw. Erdreich/Wasser/Abwasser ist zum 21.07.2026 entfallen. Für Anfang 2027 ist stattdessen ein Wertschöpfungsbonus für EU-gefertigte Wärmepumpen angekündigt." },
      { lead: "Aktuelle Geräte erfüllen die Werte:", text: "Marktübliche Modelle (Vaillant, Viessmann, Wolf, Daikin, Bosch u. a.) in der Baureihe 2025/26 sind in der Regel förderfähig – bei Restposten lohnt der Blick ins Datenblatt." },
    ]}
  />
  <p class="text-text-muted max-w-3xl text-sm mt-6">
    Den vollständigen Antragsweg, die Boni-Matrix und die förderfähigen Kosten je
    Wohneinheit erklärt die Detailseite
    <a href="/kfw-458-waermepumpe/" class="text-brand underline">KfW 458 im Detail</a>.
    Was das BAFA rund um Wärmepumpen noch fördert, steht auf der
    <a href="/bafa-foerderung-waermepumpe/" class="text-brand underline">BAFA-Seite</a>.
  </p>
</SectionShell>

{/* Übersicht Boni-Summen 2026 */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Übersicht: Maximale Förderquote 2026
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Wie viel Förderung 2026 realistisch ist, hängt von den eigenen
    Boni-Voraussetzungen ab:
  </p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-4xl">
    <div class="surface-card p-5 text-center">
      <p class="text-3xl font-bold text-primary">30 %</p>
      <p class="font-semibold text-text mt-2">Standardfall</p>
      <p class="text-text-muted text-sm mt-2">Grundförderung – wenn keine alte fossile Heizung getauscht wird. Der frühere 5-%-Effizienzbonus ist seit dem 21.07.2026 gestrichen.</p>
    </div>
    <div class="surface-card p-5 text-center">
      <p class="text-3xl font-bold text-primary">46 %</p>
      <p class="font-semibold text-text mt-2">Tausch alter Öl/Gas</p>
      <p class="text-text-muted text-sm mt-2">+ 16 % Klimabonus (sinkt ab Februar 2027 halbjährlich) – der häufigste Fall im Bestand.</p>
    </div>
    <div class="surface-card p-5 text-center">
      <p class="text-3xl font-bold text-primary">70–80 %</p>
      <p class="font-semibold text-text mt-2">Maximum</p>
      <p class="text-text-muted text-sm mt-2">+ gestaffelter Einkommensbonus (40/30/10 %). Deckel 70 %, für die niedrigsten Haushaltseinkommen 80 %.</p>
    </div>
  </div>
  <p class="text-text-muted max-w-3xl text-sm mt-6">
    Die maximal förderfähigen Kosten je Wohneinheit (28.000 / 15.000 / 8.000 Euro)
    und die Berechnung bei mehreren Wohneinheiten stehen auf der
    <a href="/kfw-458-waermepumpe/" class="text-brand underline">KfW-458-Detailseite</a>.
  </p>
</SectionShell>

{/* Verweis auf die lokale Ebene — dieser Spoke bleibt bewusst de-lokalisiert,
    damit er nicht mit dem Bremen-Hub um dieselben Queries konkurriert. */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Gelten die Regeln bundesweit?
  </h2>
  <p class="text-text-muted max-w-3xl mb-4">
    Ja. Förderhöhen, Boni und die neuen Bundesregeln gelten überall gleich.
    Unterschiede entstehen erst eine Ebene darunter: Länder und Kommunen legen
    eigene Zuschuss- und Kreditprogramme auf, die zusätzlich beantragt werden
    können, und die kommunale Wärmeplanung entscheidet vor Ort darüber, welche
    Straßenzüge auf Fernwärme umgestellt werden. Beides ändert sich häufig und
    lohnt einen Blick auf die Programme der eigenen Stadt.
  </p>
  <p class="text-text-muted max-w-3xl text-sm">
    Für Bremen sind die lokalen Programme hier zusammengefasst:
    <a href="/waermepumpe-foerderung-bremen/" class="text-brand underline">Wärmepumpe Förderung Bremen</a>.
  </p>
</SectionShell>

{/* Quellen */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Quellen und redaktioneller Stand
  </h2>
  <div class="surface-card p-5 max-w-3xl text-sm text-text-muted leading-relaxed">
    <p class="font-semibold text-text mb-3">Quellenstand: 15. Juli 2026</p>
    <ul class="space-y-2">
      <li>
        KfW: <a
          href="https://www.kfw.de/inlandsfoerderung/Privatpersonen/Bestehende-Immobilie/F%C3%B6rderprodukte/Heizungsf%C3%B6rderung-f%C3%BCr-Privatpersonen-Wohngeb%C3%A4ude-%28458%29/"
          class="text-primary underline"
          target="_blank"
          rel="noopener">Heizungsförderung für Privatpersonen – Wohngebäude 458</a>
      </li>
      <li>
        KfW: <a
          href="https://www.kfw.de/%C3%9Cber-die-KfW/Newsroom/Aktuelles/Pressemitteilungen-Details_900928.html"
          class="text-primary underline"
          target="_blank"
          rel="noopener">Pressemitteilung: Anpassungen in den KfW-Produkten der BEG (neue Konditionen ab 21.07.2026, Degression ab 01.02.2027)</a>
      </li>
      <li>
        BAFA: <a
          href="https://www.bafa.de/DE/Energie/Effiziente_Gebaeude/Waermeerzeuger_Portal/waermeerzeuger_portal.html"
          class="text-primary underline"
          target="_blank"
          rel="noopener">Wärmeerzeuger-Portal – Liste förderfähiger Wärmepumpen</a>
      </li>
      <li>
        BWP: <a
          href="https://www.waermepumpe.de/presse/news/details/beg-foerderung-2026-neue-schallanforderungen-fuer-waermepumpen/"
          class="text-primary underline"
          target="_blank"
          rel="noopener">BEG-Förderung 2026 – neue Schallanforderungen für Wärmepumpen</a>
      </li>
      <li>
