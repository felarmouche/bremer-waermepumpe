---
import { getImage } from "astro:assets";
import Layout from "../layout/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import TrustBar from "../components/TrustBar.astro";
import CTASection from "../components/CTASection.astro";
import FAQSection from "../components/FAQSection.astro";
import SectionShell from "../components/SectionShell.astro";
import NoticeSuccess from "../components/content/NoticeSuccess.astro";
import CheckList from "../components/content/CheckList.astro";
import NumberedSteps from "../components/content/NumberedSteps.astro";
import InternalLinkCard from "../components/InternalLinkCard.astro";
import heroImage from "../images/foerderung-bremen-hero.webp";

import type { PageData } from "../types/page";

const data: PageData = {
  title: "KfW 458 förderfähige Kosten ab 21.07.2026: Tabelle + Beispiele",
  description:
    "Förderfähige Kosten neu ab 21.07.2026: 28.000 statt 30.000 € für die 1. Wohneinheit, Klimabonus 16 %, Einkommensbonus bis 40 % – Tabelle alt vs. neu + Beispiele.",
  lastUpdated: "14. Juli 2026",
  hero: {
    headline: "KfW 458 förderfähige Kosten",
    subtext:
      "Neue Konditionen ab 21. Juli 2026: 28.000 € förderfähige Kosten für die erste Wohneinheit, gestaffelter Einkommensbonus, Frist für Alt-Anträge am 20. Juli – mit Tabelle alt vs. neu und Rechenbeispielen.",
    primaryCTA: {
      label: "KfW-Boni für Ihr Haus prüfen",
      href: "/check/",
    },
    secondaryCTA: {
      label: "Förderung Bremen",
      href: "/waermepumpe-foerderung-bremen/",
    },
  },
  trustItems: [
    {
      text: "Neue Sätze ab 21.07.2026",
    },
    {
      text: "28.000 / 15.000 / 8.000 €",
    },
    {
      text: "Frist 20.07.2026, 20 Uhr",
    },
    {
      text: "WEG & Mehrfamilienhaus",
    },
    {
      text: "Stand 14. Juli 2026",
    },
  ],
  breadcrumb: [
    {
      label: "Startseite",
      href: "/",
    },
    {
      label: "Förderung Bremen",
      href: "/waermepumpe-foerderung-bremen/",
    },
    {
      label: "KfW 458",
    },
  ],
  ctaBlock: {
    headline: "Welche KfW-458-Boni greifen für Ihr Bremer Haus?",
    text: "Der Check ordnet Heizungsalter, Eigentum, Wohneinheiten und mögliche Boni ein – als erste Orientierung vor Angebot und Antrag.",
    variant: "highlight",
    primaryCTA: {
      label: "KfW-Boni für Ihr Haus prüfen",
      href: "/check/",
    },
    secondaryCTA: {
      label: "Was kostet das nach Förderung?",
      href: "/waermepumpe-kosten-bremen/",
    },
  },
  faqHeading: "FAQ: KfW 458 förderfähige Kosten",
  faqs: [
    {
      question: "Was sind die förderfähigen Kosten bei KfW 458?",
      answer:
        "Ab dem 21.07.2026 berücksichtigt die KfW bei der Heizungsförderung 458 bis zu 28.000 Euro für die erste Wohneinheit (zuvor 30.000 Euro), jeweils 15.000 Euro für die zweite bis sechste Wohneinheit und jeweils 8.000 Euro ab der siebten Wohneinheit. Auf diese förderfähigen Kosten wird der individuelle Fördersatz angewendet.",
    },
    {
      question: "Zählt die zweite Wohneinheit mit 30.000 oder 15.000 Euro?",
      answer:
        "Die zweite bis sechste Wohneinheit zählt jeweils mit 15.000 Euro. Die erste Wohneinheit zählt ab dem 21.07.2026 mit 28.000 Euro (bis 20.07.2026: 30.000 Euro). Ein Zweifamilienhaus kommt damit auf 43.000 Euro förderfähige Kosten, ein Dreifamilienhaus auf 58.000 Euro.",
    },
    {
      question: "Kann ich noch zu den alten Konditionen beantragen?",
      answer:
        "Nur mit einer bereits vorliegenden Bestätigung zum Antrag (BzA): Dann kann der Zuschussantrag bis zum 20. Juli 2026, 20 Uhr, im Portal Meine KfW zu den bisherigen Konditionen gestellt werden. Neue BzA werden in der Umstellungsphase seit dem 09.07.2026 nicht erstellt. Bereits erteilte Förderzusagen bleiben unverändert gültig.",
    },
    {
      question: "Wie funktioniert der neue Einkommensbonus ab 21.07.2026?",
      answer:
        "Der Einkommensbonus für selbstnutzende Eigentümer ist ab dem 21.07.2026 gestaffelt: 40 Prozent bei einem Haushaltsjahreseinkommen bis 30.000 Euro, 30 Prozent bis 40.000 Euro und 10 Prozent bis 50.000 Euro. Mit mindestens einem minderjährigen Kind im Haushalt erhöhen sich diese Einkommensgrenzen einmalig um 10.000 Euro (Familienzuschlag).",
    },
    {
      question: "Gibt es den Effizienzbonus für natürliche Kältemittel noch?",
      answer:
        "Nein. Der Effizienzbonus von 5 Prozentpunkten für Wärmepumpen mit natürlichem Kältemittel oder Wärmequelle Erdreich, Wasser oder Abwasser entfällt zum 21.07.2026, ebenso der Emissionsminderungszuschlag für Biomasseheizungen. Bereits zugesagte Anträge behalten ihre Konditionen.",
    },
    {
      question: "Wie hoch ist die maximale Förderung ab dem 21.07.2026?",
      answer:
        "Die Gesamtförderung bleibt bei maximal 70 Prozent der förderfähigen Kosten gedeckelt. Für selbstnutzende Haushalte mit Anspruch auf den höchsten Einkommensbonus steigt der Deckel auf 80 Prozent – bei 28.000 Euro förderfähigen Kosten sind das bis zu 22.400 Euro Zuschuss für die erste Wohneinheit.",
    },
    {
      question: "Wie funktioniert KfW 458 bei einer WEG?",
      answer:
        "Wohnungseigentümergemeinschaften können KfW 458 nutzen, wenn der Heizungstausch Gemeinschaftseigentum betrifft. Der Förderhöchstbetrag wird nach der Zahl der Wohneinheiten im Gebäude berechnet. Für WEGs sind saubere Beschlüsse, Vollmachten und ein abgestimmter Antrag besonders wichtig.",
    },
    {
      question: "Muss der KfW-458-Antrag vor dem Auftrag gestellt werden?",
      answer:
        "Der Antrag muss vor Beginn der Maßnahme gestellt werden. Dafür braucht man in der Regel schon einen Liefer- oder Leistungsvertrag mit förderkonformer Bedingung sowie die Bestätigung zum Antrag (BzA). Erst nach Förderzusage sollte die Umsetzung starten.",
    },
    {
      question: "Wo stelle ich den Antrag für KfW 458?",
      answer:
        "Der Zuschussantrag für KfW 458 wird online im Portal Meine KfW gestellt. Dafür werden die BzA-ID aus der Bestätigung zum Antrag, die Vertrags- und Eigentümerdaten benötigt. Nach der Förderzusage haben Antragsteller in der Regel 36 Monate Zeit, die Maßnahme umzusetzen und die Nachweise einzureichen.",
    },
  ],
  schema: {
    type: "HowTo",
    datePublished: "2026-05-02",
    dateModified: "2026-07-14",
    howToName: "KfW 458 förderfähige Kosten für Wärmepumpe berechnen",
    howToDescription:
      "Schritt-für-Schritt-Einordnung der KfW-458-förderfähigen Kosten nach Wohneinheiten und Boni für Wärmepumpen im Bestand.",
    howToSteps: [
      {
        name: "Wohneinheiten zählen",
        text: "Zuerst wird die Anzahl der Wohneinheiten im Gebäude bestimmt. Ab dem 21.07.2026 zählt die erste Wohneinheit mit 28.000 Euro, die zweite bis sechste jeweils mit 15.000 Euro und jede weitere mit 8.000 Euro förderfähigen Kosten.",
      },
      {
        name: "Förderfähige Kosten im Angebot trennen",
        text: "Gerät, Einbau, hydraulischer Abgleich, Speicher, Fachplanung und technisch notwendige Umfeldmaßnahmen müssen im Angebot nachvollziehbar dem Heizungstausch zugeordnet sein.",
      },
      {
        name: "Boni prüfen",
        text: "Basisförderung, Klimageschwindigkeitsbonus und gestaffelter Einkommensbonus werden geprüft. Die Summe ist auf maximal 70 Prozent begrenzt, bei den niedrigsten Haushaltseinkommen auf 80 Prozent.",
      },
      {
        name: "BzA und Vertrag vorbereiten",
        text: "Ein Energieeffizienz-Experte oder zugelassenes Fachunternehmen stellt die Bestätigung zum Antrag aus. Der Liefer- oder Leistungsvertrag muss eine förderkonforme Bedingung enthalten.",
      },
      {
        name: "Antrag bei Meine KfW stellen und Zusage abwarten",
        text: "Mit der BzA-ID wird der Zuschussantrag im Portal Meine KfW gestellt. Erst nach Förderzusage sollte die Maßnahme umgesetzt werden; danach bleiben in der Regel 36 Monate Zeit bis zum Nachweis.",
      },
    ],
  },
};

const canonical = data.canonical ?? Astro.url.href;
const hero = { ...data.hero, imageSrc: heroImage };
const ogImage = await getImage({
  src: heroImage,
  width: 1200,
  height: 630,
  fit: "cover",
  format: "jpg",
});
const dateLine = data.lastUpdated ? `Stand: ${data.lastUpdated}` : null;
const pageSchema = data.schema
  ? {
      ...data.schema,
      datePublished: data.schema.datePublished ?? data.schema.dateModified,
      dateModified: data.schema.dateModified ?? data.schema.datePublished,
    }
  : undefined;
---

<Layout
  title={data.title}
  description={data.description}
  canonical={canonical}
  ogImage={ogImage.src}
  noindex={data.noindex}
  pageSchema={pageSchema}
>
  {data.breadcrumb?.length > 0 && <Breadcrumb items={data.breadcrumb} />}
  <HeroSection {...hero} />
  {data.trustItems?.length > 0 && <TrustBar items={data.trustItems} />}
  {
    dateLine && (
      <div class="bg-background border-b border-border">
        <p class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-text-muted">
          {dateLine} · Redaktion bremer-waermepumpe.de · Alle Angaben ohne
          Gewähr
        </p>
      </div>
    )
  }

  <SectionShell>
    <article class="max-w-3xl space-y-5 text-text-muted leading-relaxed">
      <div class="surface-card p-6 sm:p-8 border-l-4 border-primary">
        <p
          class="text-xs font-semibold text-primary uppercase tracking-wide mb-3"
        >
          Kurzantwort
        </p>
        <p class="text-text leading-relaxed text-base sm:text-lg">
          Die <strong>KfW-Heizungsförderung 458</strong> (offiziell „Heizungsförderung
          für Privatpersonen – Wohngebäude") bezuschusst den Tausch einer alten Heizung
          gegen eine Wärmepumpe. <strong>Ab dem 21. Juli 2026</strong> gelten neue
          Konditionen: förderfähige Kosten von <strong>28.000 €</strong> für die erste
          Wohneinheit (zuvor 30.000 €), weiterhin <strong>je 15.000 €</strong> für die
          zweite bis sechste und <strong>je 8.000 €</strong> ab der siebten. Die
          Grundförderung bleibt bei 30 %, der Klimageschwindigkeitsbonus sinkt auf
          16 %, der Effizienzbonus entfällt, der Einkommensbonus wird auf
          40/30/10 % gestaffelt. Gedeckelt wird bei <strong>70 %</strong>, für die
          niedrigsten Einkommen bei <strong>80 %</strong>.
        </p>
        <p class="text-sm text-text-muted leading-relaxed mt-4">
          <strong class="text-text">Frist:</strong> Wer bereits eine Bestätigung zum
          Antrag (BzA) hat, kann noch bis <strong class="text-text">20. Juli 2026,
          20 Uhr</strong>, zu den alten Konditionen beantragen. Neue BzA werden seit
          dem 09.07.2026 erst wieder ab dem 21.07.2026 erstellt. Bereits erteilte
          Zusagen bleiben unverändert gültig.
        </p>
      </div>
      <div class="bg-highlight border border-border rounded p-5">
        <p class="font-bold text-text mb-3">
          KfW 458 alt vs. neu: alle Änderungen zum 21.07.2026
        </p>
        <div class="surface-card overflow-hidden divide-y divide-border">
          <div class="grid grid-cols-3 px-4 py-3 text-sm bg-background">
            <span class="font-semibold text-text">Baustein</span>
            <span class="font-semibold text-text text-right">bis 20.07.2026</span>
            <span class="font-semibold text-primary text-right">ab 21.07.2026</span>
          </div>
          <div class="grid grid-cols-3 px-4 py-3 text-sm">
            <span class="text-text-muted">1. Wohneinheit</span>
            <span class="text-text-muted text-right">30.000 €</span>
            <span class="font-semibold text-text text-right">28.000 €</span>
          </div>
          <div class="grid grid-cols-3 px-4 py-3 text-sm">
            <span class="text-text-muted">2.–6. Wohneinheit</span>
            <span class="text-text-muted text-right">je 15.000 €</span>
            <span class="font-semibold text-text text-right">je 15.000 €</span>
          </div>
          <div class="grid grid-cols-3 px-4 py-3 text-sm">
            <span class="text-text-muted">ab 7. Wohneinheit</span>
            <span class="text-text-muted text-right">je 8.000 €</span>
            <span class="font-semibold text-text text-right">je 8.000 €</span>
          </div>
          <div class="grid grid-cols-3 px-4 py-3 text-sm">
            <span class="text-text-muted">Grundförderung</span>
            <span class="text-text-muted text-right">30 %</span>
            <span class="font-semibold text-text text-right">30 %</span>
          </div>
          <div class="grid grid-cols-3 px-4 py-3 text-sm">
            <span class="text-text-muted">Klimageschwindigkeitsbonus</span>
            <span class="text-text-muted text-right">20 %</span>
            <span class="font-semibold text-text text-right">16 %</span>
          </div>
          <div class="grid grid-cols-3 px-4 py-3 text-sm">
            <span class="text-text-muted">Effizienzbonus</span>
            <span class="text-text-muted text-right">5 %</span>
            <span class="font-semibold text-text text-right">entfällt</span>
          </div>
          <div class="grid grid-cols-3 px-4 py-3 text-sm">
            <span class="text-text-muted">Emissionsminderungszuschlag</span>
            <span class="text-text-muted text-right">2.500 €</span>
            <span class="font-semibold text-text text-right">entfällt</span>
          </div>
          <div class="grid grid-cols-3 px-4 py-3 text-sm">
            <span class="text-text-muted">Einkommensbonus</span>
            <span class="text-text-muted text-right">30 % (bis 40.000 €)</span>
            <span class="font-semibold text-text text-right">40/30/10 % gestaffelt</span>
          </div>
          <div class="grid grid-cols-3 px-4 py-3 text-sm">
            <span class="text-text-muted">Familienzuschlag</span>
            <span class="text-text-muted text-right">–</span>
            <span class="font-semibold text-text text-right">+10.000 € auf die Einkommensgrenze</span>
          </div>
          <div class="grid grid-cols-3 px-4 py-3 text-sm bg-background">
            <span class="font-semibold text-text">Maximaler Zuschuss</span>
            <span class="text-text-muted text-right">70 %</span>
            <span class="font-bold text-primary text-right">70 %, bis 80 %*</span>
          </div>
        </div>
        <p class="text-xs text-text-muted mt-3">
          *80 % für selbstnutzende Haushalte mit Anspruch auf den höchsten
          Einkommensbonus. Quelle: KfW, Anpassungen der BEG zum 21.07.2026.
        </p>
      </div>
      <p>
        An der Rechenlogik ändert sich nichts: Entscheidend ist zuerst der
        <strong class="text-text">Förderhöchstbetrag nach Wohneinheiten</strong
        >, erst danach wird der persönliche Fördersatz angewendet. Wer noch mit
        der alten Staffel „30.000 / 15.000 / 8.000" rechnet, setzt ab dem
        21. Juli 2026 für die erste Wohneinheit 28.000 € an.
      </p>
      <NoticeSuccess>
        <p>
          <strong>Bremer Praxis:</strong> Für viele Einfamilienhäuser, Reihenhäuser
          und Altbremer Häuser ist die erste Wohneinheit der zentrale Fall. Bei Zwei-
          oder Drei-Parteien-Häusern in Bremen wird die Rechnung aber schnell anders,
          weil die zweite und dritte Wohneinheit nur noch mit je 15.000 Euro einfließen.
        </p>
      </NoticeSuccess>
      <p class="text-sm">
        <strong class="text-text">Verfasser:</strong>
        <a href="/kontakt/" class="text-primary underline">Ferris El-Armouche</a
        >. Stand 14. Juli 2026, geprüft an der KfW-Quelle. Diese private
        Informationsseite ersetzt keine verbindliche Förderberatung oder
        Förderzusage durch KfW, Energieeffizienz-Experten oder Fachunternehmen.
      </p>
    </article>
  </SectionShell>

  <SectionShell variant="alt">
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
      Beispiele nach neuen Konditionen: EFH, Zweifamilienhaus, 10 Wohneinheiten
    </h2>
    <p class="text-text-muted max-w-3xl mb-6">
      Die folgenden Beispiele zeigen, welcher Betrag ab dem 21.07.2026 in die
      KfW-458-Rechnung einfließen kann. Der tatsächliche Zuschuss hängt
      anschließend von Basisförderung und Boni ab.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="surface-card p-5">
        <h3 class="font-semibold text-text">Einfamilienhaus</h3>
        <p class="text-2xl font-bold text-primary my-2">28.000 €</p>
        <p class="text-text-muted text-sm">
          Selbstnutzer mit Klimageschwindigkeitsbonus (46 %): 12.880 € Zuschuss.
          Mit höchstem Einkommensbonus (80 %): bis 22.400 €.
        </p>
      </div>
      <div class="surface-card p-5">
        <h3 class="font-semibold text-text">Zweifamilienhaus</h3>
        <p class="text-2xl font-bold text-primary my-2">43.000 €</p>
        <p class="text-text-muted text-sm">
          28.000 € für die erste WE plus 15.000 € für die zweite WE.
        </p>
      </div>
      <div class="surface-card p-5">
        <h3 class="font-semibold text-text">10 Wohneinheiten</h3>
        <p class="text-2xl font-bold text-primary my-2">135.000 €</p>
        <p class="text-text-muted text-sm">
          28.000 € + 5 × 15.000 € + 4 × 8.000 €.
        </p>
      </div>
    </div>

    <div
      class="bg-highlight border border-border rounded p-5 mt-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <div>
        <p class="font-bold text-text">KfW-Boni für Ihr Bremer Haus prüfen</p>
        <p class="text-text-muted text-sm mt-1">
          Eigentum, Heizungsalter, Nutzung und Wohneinheiten entscheiden über
          den Förderhebel.
        </p>
      </div>
      <a href="/check/" class="btn-accent shrink-0 text-center"
        >KfW-Boni prüfen</a
      >
    </div>
  </SectionShell>

  <SectionShell>
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
      Welche Boni gelten ab dem 21.07.2026?
    </h2>
    <p class="text-text-muted max-w-3xl mb-6">
      Die KfW 458 besteht weiterhin aus einer Basisförderung und möglichen
      Bonusbausteinen. Die Summe kann rechnerisch höher sein, wird aber
      gedeckelt.
    </p>
    <CheckList
      items={[
        {
          lead: "30 % Basisförderung:",
          text: "Unverändert die Grundlage für förderfähige Wärmepumpen im bestehenden Wohngebäude.",
        },
        {
          lead: "+16 % Klimageschwindigkeitsbonus (zuvor 20 %):",
          text: "Für selbstnutzende Eigentümer beim Austausch funktionsfähiger Öl-, Kohle-, Gasetagen- oder Nachtspeicherheizungen sowie mindestens 20 Jahre alter Gas-/Biomasseheizungen. Sinkt ab dem 01.02.2027 halbjährlich weiter.",
        },
        {
          lead: "+40/30/10 % Einkommensbonus:",
          text: "Für selbstnutzende Eigentümer, gestaffelt nach Haushaltsjahreseinkommen: 40 % bis 30.000 €, 30 % bis 40.000 €, 10 % bis 50.000 €.",
        },
        {
          lead: "Familienzuschlag:",
          text: "Mit mindestens einem minderjährigen Kind im Haushalt erhöhen sich die Einkommensgrenzen einmalig um 10.000 €.",
        },
        {
          lead: "Entfallen:",
          text: "Der Effizienzbonus (5 %) für natürliche Kältemittel bzw. Erdreich/Wasser/Abwasser und der Emissionsminderungszuschlag für Biomasse werden zum 21.07.2026 gestrichen.",
        },
        {
          lead: "Deckel 70 bzw. 80 %:",
          text: "Die Gesamtförderung bleibt auf 70 % begrenzt; für Haushalte mit dem höchsten Einkommensbonus gilt ein Deckel von 80 %.",
        },
      ]}
    />
  </SectionShell>

  <SectionShell variant="alt">
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
      Einkommensbonus neu: 40/30/10 % und Familienzuschlag
    </h2>
    <p class="text-text-muted max-w-3xl mb-6">
      Der Einkommensbonus für selbstnutzende Eigentümer wird zum 21.07.2026
      gestaffelt und reicht künftig bis zu einem Haushaltsjahreseinkommen von
      <strong class="text-text">50.000 €</strong>. Familien mit mindestens
      einem minderjährigen Kind profitieren zusätzlich vom
      <strong class="text-text">Familienzuschlag</strong>: Er hebt die
      jeweilige Einkommensgrenze einmalig um 10.000 € an.
    </p>
    <div class="surface-card overflow-hidden divide-y divide-border max-w-3xl mb-6">
      <div class="grid grid-cols-3 px-4 py-3 text-sm bg-background">
        <span class="font-semibold text-text">Haushaltsjahreseinkommen</span>
        <span class="font-semibold text-text text-right">Einkommensbonus</span>
        <span class="font-semibold text-text text-right">mit Familienzuschlag</span>
      </div>
      <div class="grid grid-cols-3 px-4 py-3 text-sm">
        <span class="text-text-muted">bis 30.000 €</span>
        <span class="font-semibold text-text text-right">40 %</span>
        <span class="text-text-muted text-right">bis 40.000 €</span>
      </div>
      <div class="grid grid-cols-3 px-4 py-3 text-sm">
        <span class="text-text-muted">bis 40.000 €</span>
        <span class="font-semibold text-text text-right">30 %</span>
        <span class="text-text-muted text-right">bis 50.000 €</span>
      </div>
      <div class="grid grid-cols-3 px-4 py-3 text-sm">
        <span class="text-text-muted">bis 50.000 €</span>
        <span class="font-semibold text-text text-right">10 %</span>
        <span class="text-text-muted text-right">bis 60.000 €</span>
      </div>
    </div>
    <NoticeSuccess>
      <p>
        <strong>Entfallen zum 21.07.2026:</strong> Der Effizienzbonus von 5 %
        für Wärmepumpen mit natürlichem Kältemittel (z.&nbsp;B. Propan/R290)
        oder Wärmequelle Erdreich, Wasser, Abwasser wird gestrichen – ebenso
        der Emissionsminderungszuschlag für Biomasseheizungen. Bereits
        zugesagte Anträge behalten ihre Konditionen.
      </p>
    </NoticeSuccess>
    <h3 class="text-xl font-bold text-text mt-8 mb-3">
