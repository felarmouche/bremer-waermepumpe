---
import Layout from "../layout/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import TrustBar from "../components/TrustBar.astro";
import CTASection from "../components/CTASection.astro";
import FAQSection from "../components/FAQSection.astro";
import SectionShell from "../components/SectionShell.astro";
import NoticeSuccess from "../components/content/NoticeSuccess.astro";
import CheckList from "../components/content/CheckList.astro";
import InternalLinkCard from "../components/InternalLinkCard.astro";
import heroImage from "../images/heat-pump-bremen-hero.webp";

import type { PageData } from "../types/page";

const data: PageData = {
    title: "Wärmepumpe Kosten Einfamilienhaus: Preise & Amortisation",
    description: "Wärmepumpe Kosten im Einfamilienhaus 2026: Preise nach Wohnfläche (100, 150, 200 m²), Bauart, Zusatzposten und Betriebskosten.",
    lastUpdated: "Mai 2026",
    hero: {
        headline: "Wärmepumpe Kosten Einfamilienhaus",
        subtext: "Realistische Investition für Bremer Einfamilienhäuser nach Wohnfläche und Bauart – mit Eigenanteil und Amortisation.",
        primaryCTA: {
            label: "Eignung & Förderung prüfen",
            href: "/check/"
        },
        secondaryCTA: {
            label: "Kosten-Hub Bremen",
            href: "/waermepumpe-kosten-bremen/"
        }
    },
    trustItems: [
        {
            text: "Nach 100/150/200 m²"
        },
        {
            text: "Stand Mai 2026"
        },
        {
            text: "Inkl. Förderung"
        },
        {
            text: "Mit Amortisationsrechnung"
        }
    ],
    breadcrumb: [
        {
            label: "Startseite",
            href: "/"
        },
        {
            label: "Kosten Bremen",
            href: "/waermepumpe-kosten-bremen/"
        },
        {
            label: "Einfamilienhaus"
        }
    ],
    ctaBlock: {
        headline: "Was passt zu Ihrer Wohnfläche?",
        text: "Browser-Check zur passenden Bauart und groben Investitionshöhe – unverbindlich & kostenlos.",
        variant: "highlight",
        primaryCTA: {
            label: "Eignung & Förderung prüfen",
            href: "/check/"
        },
        secondaryCTA: {
            label: "Förderung Bremen",
            href: "/waermepumpe-foerderung-bremen/"
        }
    },
    faqHeading: "FAQ: Wärmepumpe Kosten Einfamilienhaus",
    faqs: [
        {
            question: "Was kostet eine Wärmepumpe für ein Einfamilienhaus mit 150 m²?",
            answer: "Für ein typisches teilsaniertes Einfamilienhaus mit 150 m² liegen die Komplettkosten einer Luft-Wasser-Wärmepumpe bei 24.000 bis 32.000 Euro brutto. Eine Sole-Wasser-Variante mit Erdsonde liegt bei 32.000 bis 42.000 Euro. Eine mögliche Förderung wird erst nach dem vollständigen Angebot und mit den dann geltenden Konditionen berechnet."
        },
        {
            question: "Wie viel kostet eine Wärmepumpe nach Abzug der Förderung?",
            answer: "Der Eigenanteil ergibt sich aus den vollständigen Projektkosten abzüglich einer individuell geprüften Förderung. Eine feste Zahl wäre unseriös, weil Antragstermin, Wohneinheiten, Nutzung und anerkannte Kosten das Ergebnis verändern. Die aktuellen KfW-Konditionen stehen auf der KfW-458-Detailseite."
        },
        {
            question: "Welche Wärmepumpe ist für ein Einfamilienhaus am besten?",
            answer: "Im sanierten Neubau und gut gedämmten Bestand ist die klassische Luft-Wasser-Wärmepumpe (8–10 kW) Standard. Im Altbau mit höherer Vorlauftemperatur empfiehlt sich eine Hochtemperatur-Variante mit R290 (Propan), die bis 65 °C Vorlauf erreicht. Sole-Wasser ist die effizienteste, aber teuerste Option – sinnvoll bei freistehenden Häusern mit Garten und langfristiger Nutzung."
        },
        {
            question: "Wann amortisiert sich eine Wärmepumpe im Einfamilienhaus?",
            answer: "Das hängt von Investition, Förderung, Gebäude-Effizienz, Strom- und Gaspreisen sowie dem CO₂-Preis ab. Statt einer pauschalen Jahreszahl sollte die Amortisation mit dem konkreten Angebot und mehreren Energiepreis-Szenarien berechnet werden."
        },
        {
            question: "Was kostet das im Einfamilienhaus mit 200 m² Wohnfläche?",
            answer: "Für ein 200-m²-Einfamilienhaus liegt die Investition typischerweise bei 28.000 bis 38.000 Euro für Luft-Wasser-Wärmepumpen mit 12–14 kW Leistung. Ob und bis zu welcher Höhe diese Kosten berücksichtigt werden können, richtet sich nach den KfW-Konditionen zum Antragstermin."
        }
    ],
    schema: {
        type: "Article",
        datePublished: "2026-05-02",
        dateModified: "2026-07-15"
    }
};

const canonical = data.canonical ?? Astro.url.href;
const hero = { ...data.hero, imageSrc: heroImage };
const dateLine = data.lastUpdated ? `Stand: ${data.lastUpdated}` : null;
const pageSchema = data.schema
    ? {
          ...data.schema,
          datePublished: data.schema.datePublished ?? data.schema.dateModified,
          dateModified: data.schema.dateModified ?? data.schema.datePublished,
      }
    : undefined;
---

<Layout
    title={data.title}
    description={data.description}
    canonical={canonical}
    noindex={data.noindex}
    pageSchema={pageSchema}
>
    {data.breadcrumb?.length > 0 && <Breadcrumb items={data.breadcrumb} />}
    <HeroSection {...hero} />
    {data.trustItems?.length > 0 && <TrustBar items={data.trustItems} />}
    {dateLine && (
        <div class="bg-background border-b border-border">
            <p class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-text-muted">
                {dateLine} · Redaktion bremer-waermepumpe.de · Alle Angaben ohne Gewähr
            </p>
        </div>
    )}

{/* Intro */}
<SectionShell>
  <article class="max-w-3xl space-y-4 text-text-muted leading-relaxed">
    <p>
      Das klassische Bremer Einfamilienhaus ist freistehend oder Teil einer Reihenhauszeile,
      hat zwischen 100 und 220 m² Wohnfläche und meist eine alte Gas- oder Ölheizung. Für
      diese Häusergröße ist die Wärmepumpe technisch gut beherrschbar – die Frage ist
      vor allem: <strong class="text-text">Welche Bauart, welche Leistung, welcher Preis?</strong>
    </p>
    <p>
      Diese Seite zeigt eine ehrliche Aufschlüsselung nach Wohnfläche und Bauart, eine
      Amortisationsrechnung gegen die neue Gasheizung und die häufigsten Sonderposten,
      die im Bremer Einfamilienhaus zum Tragen kommen.
    </p>
  </article>
</SectionShell>

{/* Tabelle nach Wohnfläche */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Kosten nach Wohnfläche und Bauart
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Die nötige Heizleistung skaliert ungefähr linear mit der Wohnfläche – im Bremer
    Bestand rechnen Sie mit 50–80 W/m² Heizlast (sanierter Neubau am unteren Ende,
    unsanierter Altbau am oberen).
  </p>

  <div class="surface-card overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-surface-alt border-b border-border">
        <tr>
          <th class="text-left p-4 font-semibold text-text">Wohnfläche</th>
          <th class="text-left p-4 font-semibold text-text">Heizleistung</th>
          <th class="text-left p-4 font-semibold text-text">Luft-Wasser</th>
          <th class="text-left p-4 font-semibold text-text">Sole-Wasser</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <tr>
          <td class="p-4 text-text">100 m² (gut saniert)</td>
          <td class="p-4 text-text-muted">6–8 kW</td>
          <td class="p-4 text-text-muted">20.000 – 26.000 €</td>
          <td class="p-4 text-text-muted">28.000 – 36.000 €</td>
        </tr>
        <tr>
          <td class="p-4 text-text">150 m² (teilsaniert)</td>
          <td class="p-4 text-text-muted">9–12 kW</td>
          <td class="p-4 text-text-muted">24.000 – 32.000 €</td>
          <td class="p-4 text-text-muted">32.000 – 42.000 €</td>
        </tr>
        <tr>
          <td class="p-4 text-text">200 m² (Altbau)</td>
          <td class="p-4 text-text-muted">12–16 kW</td>
          <td class="p-4 text-text-muted">28.000 – 38.000 €</td>
          <td class="p-4 text-text-muted">36.000 – 48.000 €</td>
        </tr>
      </tbody>
    </table>
  </div>

  <p class="text-text-muted max-w-3xl text-sm mt-6">
    Alle Preise inkl. MwSt., Lieferung, Installation, hydraulischem Abgleich und
    Inbetriebnahme. Die Tabelle zeigt bewusst Bruttokosten vor Förderung. Welche
    Kosten aktuell berücksichtigt werden können, steht auf der
    <a href="/kfw-458-waermepumpe/" class="text-primary underline">KfW-458-Detailseite</a>.
  </p>
</SectionShell>

{/* Amortisationsrechnung */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Amortisation gegen neue Gasheizung – beispielhaft
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Vereinfachte Rechnung für ein Bremer 150-m²-Einfamilienhaus, das aktuell mit einer
    20 Jahre alten Gasheizung geheizt wird. Annahmen: 14.000 kWh Heizwärmebedarf,
    realistische JAZ 3,5, swb-Wärmepumpentarif 24,98 ct/kWh, Gas 13 ct/kWh (CO₂-Anteil
    steigend).
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl">
    <div class="surface-card p-5">
      <h3 class="font-semibold text-text mb-3">Variante A: Neue Gasheizung</h3>
      <ul class="text-sm text-text-muted space-y-1">
        <li>Investition: 14.000 €</li>
        <li>Förderung: 0 €</li>
        <li>Eigenanteil: 14.000 €</li>
        <li class="pt-2 border-t border-border mt-2">Gas-Kosten/Jahr (heute): ca. 1.820 €</li>
        <li>Jahr 5–10: rasch steigender CO₂-Anteil</li>
        <li>GEG-§71-Konflikt ab 01.07.2026</li>
      </ul>
    </div>
    <div class="surface-card p-5 border-l-4 border-primary">
      <h3 class="font-semibold text-text mb-3">Variante B: Luft-Wasser-Wärmepumpe</h3>
      <ul class="text-sm text-text-muted space-y-1">
        <li>Investition: 28.000 €</li>
        <li>Förderung: individuell zu prüfen</li>
        <li>Eigenanteil: abhängig von den aktuellen KfW-Konditionen</li>
        <li class="pt-2 border-t border-border mt-2">Strom-Kosten/Jahr: ca. 1.000 €</li>
        <li>Stabil planbar, swb-WP-Tarif</li>
        <li>GEG-konform</li>
      </ul>
    </div>
  </div>

  <NoticeSuccess class="mt-6">
    <p>
      <strong>Einordnung:</strong> Im Beispiel liegen die laufenden Energiekosten der
      Wärmepumpe niedriger. Für einen fairen Investitionsvergleich muss die zum
      Antragstermin geltende Förderung separat ergänzt werden. Die aktuellen Werte
      finden Sie unter <a href="/kfw-458-waermepumpe/" class="text-primary underline">KfW 458</a>.
    </p>
  </NoticeSuccess>
</SectionShell>

{/* Sonderposten EFH */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Was im Einfamilienhaus oft dazukommt
  </h2>
  <CheckList
    items={[
      { lead: "PV-Kombination:", text: "Wer PV-Strom selbst nutzt, drückt die Stromkosten der Wärmepumpe um 20–40 %." },
      { lead: "Smart-Home-Steuerung:", text: "Optimiert das Zusammenspiel von PV, Speicher, Wärmepumpe und Warmwasser und sollte als eigener Angebotsposten ausgewiesen werden." },
      { lead: "Warmwasser-Anpassung:", text: "Bei dezentraler Warmwasserversorgung (Durchlauferhitzer im OG) wird oft auf zentrale Versorgung umgestellt – Mehraufwand 1.500–3.000 €." },
      { lead: "Statik und Fundament:", text: "Außengerät braucht ein tragfähiges Fundament oder Wandkonsole – im Einfamilienhaus meist trivial, in dichten Reihenhäusern manchmal aufwändiger." },
      { lead: "Pufferspeicher 200–500 l:", text: "Standard im Komplettangebot – vermeidet Takten und steigert die JAZ." },
    ]}
  />
</SectionShell>

{/* Cluster-Crosslinks */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">Vertiefen</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl">
    <InternalLinkCard
      href="/waermepumpe-kosten-bremen/"
      title="Kosten Bremen (Hub)"
      description="Übersicht über alle Bauarten, Bremer Faktoren und Eigenanteile."
    />
    <InternalLinkCard
      href="/luft-wasser-waermepumpe-kosten/"
      title="Luft-Wasser im Detail"
      description="Detailaufschlüsselung der häufigsten Bauart inkl. Lärmrahmen."
    />
    <InternalLinkCard
      href="/kfw-458-waermepumpe/"
      title="KfW 458 Antrag"
      description="Aktuelle Konditionen, förderfähige Kosten und Antragsschritte."
    />
  </div>
</SectionShell>

    {data.ctaBlock && <CTASection {...data.ctaBlock} />}
    {data.faqs?.length > 0 && (
        <FAQSection heading={data.faqHeading} items={data.faqs} />
    )}
</Layout>
