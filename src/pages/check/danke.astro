---
import Layout from "../../layout/Layout.astro";
import SectionShell from "../../components/SectionShell.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

const title = "Anfrage eingegangen – Bremer Wärmepumpe";
const description =
    "Ihre Anfrage wurde übermittelt. Unser Heizungsbau-Experte aus Bremen meldet sich in Kürze mit einer kostenlosen und unverbindlichen Einschätzung.";
const canonical = Astro.url.href;

const ref = Astro.url.searchParams.get("ref") ?? "";
---

<Layout
    title={title}
    description={description}
    canonical={canonical}
    noindex={true}
>
    <Breadcrumb
        items={[
            { label: "Startseite", href: "/" },
            { label: "Wärmepumpen-Check", href: "/check/" },
            { label: "Anfrage eingegangen" },
        ]}
    />

    <section class="bg-primary py-16 md:py-20">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
            <div
                class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/20 mb-6"
            >
                <svg
                    class="w-8 h-8 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight">
                Anfrage eingegangen
            </h1>
            <p
                class="mt-4 text-white/85 text-lg leading-relaxed max-w-xl mx-auto"
            >
                Ihre Anfrage wurde erfolgreich übermittelt.
                {
                    ref && (
                        <span>
                            Referenz: <strong class="text-white">{ref}</strong>
                        </span>
                    )
                }
            </p>
        </div>
    </section>

    <SectionShell>
        <div class="max-w-2xl space-y-6 text-text-muted leading-relaxed">
            <div class="notice-success">
                <p class="font-semibold text-text mb-2">
                    Was als Nächstes passiert
                </p>
                <ol class="list-decimal list-inside space-y-2 text-sm">
                    <li>
                        Sie erhalten eine Bestätigungs-E-Mail mit Ihrer
                        Einwilligung und den Widerrufswegen.
                    </li>
                    <li>
                        Unser Heizungsbau-Experte aus Bremen erhält Ihre Anfrage
                        – nach erfolgreicher SMS-Verifizierung Ihrer
                        Telefonnummer.
                    </li>
                    <li>
                        Er meldet sich innerhalb von <strong
                            >24 Stunden (max. 1–3 Werktagen)</strong
                        > per E-Mail oder Telefon mit einer kostenlosen und unverbindlichen
                        Einschätzung zu Eignung, Machbarkeit, Kosten und Förderung.
                        Auf Wunsch unterbreitet er Ihnen ein unverbindliches Angebot.
                    </li>
                </ol>
            </div>

            <a
                href="/fachpartner/"
                class="surface-card flex items-center gap-4 p-4 hover:border-border-strong transition-colors no-underline"
            >
                <div
                    class="flex-shrink-0 w-12 h-12 rounded-full bg-highlight flex items-center justify-center text-primary"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                        ></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="flex-1">
                    <p class="text-sm font-semibold text-text">
                        Wer meldet sich bei mir?
                    </p>
                    <p class="text-xs text-text-muted mt-0.5">
                        Profil des SHK-Betrieb ansehen →
                    </p>
                </div>
            </a>

            <p>
                Durch diese Anfrage entsteht <strong
                    >kein Vertrag und keine Zahlungspflicht</strong
                >. Die Einschätzung des Experten ist kostenlos und
                unverbindlich.
            </p>

            <div class="border border-border rounded-lg p-5 bg-surface">
                <h2 class="text-lg font-bold text-text mb-3">
                    Einwilligung widerrufen
                </h2>
                <p class="text-sm mb-4">
                    Sie können Ihre Einwilligung jederzeit ohne Angabe von
                    Gründen widerrufen. Ein Widerruf wirkt für die Zukunft.
                </p>
                <ul class="space-y-2 text-sm">
                    <li class="flex items-start gap-2">
                        <span class="text-primary shrink-0 mt-0.5">→</span>
                        <span>
                            <a
                                href="/widerruf/"
                                class="text-primary hover:underline font-medium"
                            >
                                Online-Widerrufsformular
                            </a>
                            {
                                ref && (
                                    <span class="text-text-muted">
                                        {" "}
                                        (Referenz: {ref})
                                    </span>
                                )
                            }
                        </span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-primary shrink-0 mt-0.5">→</span>
                        <span>
                            Per E-Mail:
                            <a
                                href="mailto:bremerwaermepumpen@web.de"
                                class="text-primary hover:underline"
                            >
                                bremerwaermepumpen@web.de
                            </a>
                            {ref && <span> — Betreff: „Widerruf {ref}"</span>}
                        </span>
                    </li>
                </ul>
            </div>

            <p class="text-xs">
                Datenschutz: Die Einwilligung, die SMS-Verifizierung und die
                Weitergabe an den Experten sind in unserer
                <a href="/datenschutz/" class="text-primary hover:underline"
                    >Datenschutzerklärung</a
                >
                (§§ 5, 5a und 6) ausführlich beschrieben. Die Bedingungen der Nutzung
                regeln unsere
                <a href="/agb/" class="text-primary hover:underline"
                    >Nutzungsbedingungen</a
                >.
            </p>

            <div class="flex flex-col sm:flex-row gap-3 pt-4">
                <a href="/" class="btn-secondary text-center">
                    Zurück zur Startseite
                </a>
                <a
                    href="/waermepumpe-foerderung-bremen/"
                    class="btn-secondary text-center"
                >
                    Ratgeber Förderung
                </a>
            </div>
        </div>
    </SectionShell>
</Layout>
