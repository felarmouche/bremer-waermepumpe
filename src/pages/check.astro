---
import Layout from "../layout/Layout.astro";
import FAQSection from "../components/FAQSection.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import SectionShell from "../components/SectionShell.astro";
import FunnelParent from "../components/FunnelParent.tsx";

const title = "Kostenloser Wärmepumpen-Check Bremen | Experteneinschätzung";
const description =
    "Passt eine Wärmepumpe zu Ihrem Haus in Bremen? In wenigen Minuten Daten eingeben und eine kostenlose, unverbindliche Einschätzung vom Bremer Fachpartner erhalten.";
const canonical = Astro.url.href;

const faqs = [
    {
        question: "Wie läuft der Check ab?",
        answer: "Sie geben in zehn kurzen Schritten Angaben zu Gebäude, Heizung, Eigentum, Vorhaben, Adresse und Name an. Vor der SMS-Bestätigung erteilen Sie zwei Einwilligungen (Datenweitergabe und Nutzungsbedingungen). Wir bestätigen Ihre Telefonnummer per SMS-Code – das ist gesetzlich erforderlich (BGH „Telefonaktion II”). Erst danach übermittelt das System Ihre Anfrage an unseren SHK-Betrieb. Eine automatische Bewertung findet bewusst nicht statt – der Experte schaut sich Ihre Angaben persönlich an.",
    },
    {
        question: "Was passiert mit meinen Daten?",
        answer: "Ihre Angaben werden verschlüsselt gespeichert und – nach erfolgreicher SMS-Bestätigung Ihrer Telefonnummer – an den unter /fachpartner/ namentlich genannten SHK-Betrieb weitergeleitet. Eine automatisierte Bewertung oder Vor-Einstufung Ihrer Daten findet nicht statt. Details in unserer Datenschutzerklärung (Ziffer 5, 5a und 6).",
    },
    {
        question: "Warum eine SMS-Bestätigung?",
        answer: "Ohne SMS-Verifizierung könnte jemand fremde Telefonnummern eintragen, was zu unrechtmäßigen Werbeanrufen führen würde. Mit dem Code-Ident-Verfahren stellen wir sicher, dass Sie selbst Inhaber der angegebenen Nummer sind (BGH I ZR 164/09). Für Sie entstehen dabei keine Kosten.",
    },
    {
        question: "Was kostet die Einschätzung?",
        answer: "Nichts. Sowohl der Check als auch die Einschätzung des Experten – inkl. Eignung, Machbarkeit, grobe Kosten und Förderung – sind kostenlos und unverbindlich. Auf Wunsch erhalten Sie ein unverbindliches Angebot. Durch die Anfrage entsteht kein Vertrag und keine Zahlungspflicht.",
    },
    {
        question: "An wen wird meine Anfrage weitergegeben?",
        answer: "Ausschließlich an den unter /fachpartner/ namentlich genannten SHK-Betrieb. Diese Seite wird privat betrieben; der Betreiber erhält für die Weiterleitung keine Provision. Ein entgeltlicher Verkauf an Lead-Aggregatoren oder andere Dritte findet nicht statt.",
    },
    {
        question: "Wie kann ich meine Einwilligung widerrufen?",
        answer: "Jederzeit ohne Angabe von Gründen: per E-Mail an bremerwaermepumpen@web.de oder über /widerruf/. Auf /widerruf/ identifizieren Sie sich entweder per Telefonnummer (mit SMS-Re-Verify) oder per Referenznummer aus der Bestätigungs-SMS.",
    },
    {
        question: "Welche Postleitzahlen werden bedient?",
        answer: "Aktuell vermitteln wir nur Anfragen aus dem Bremer Raum (PLZ 27xxx und 28xxx). Anfragen aus anderen Regionen können wir derzeit nicht annehmen.",
    },
];
---

<Layout title={title} description={description} canonical={canonical}>
    <Breadcrumb
        items={[
            { label: "Startseite", href: "/" },
            { label: "Wärmepumpen-Check" },
        ]}
    />
    <SectionShell>
        <div class="max-w-3xl">
            <h1
                class="text-3xl md:text-4xl font-bold tracking-tight text-text mb-4"
            >
                Kostenloser Wärmepumpen-Check für Bremen
            </h1>
            <p class="text-text-muted leading-relaxed text-base sm:text-lg">
                Passt eine Wärmepumpe zu Ihrem Haus in Bremen, Bremerhaven oder
                dem Umland? Der kostenlose Eignungs- und Fördercheck ordnet in
                wenigen Schritten Gebäude, alte Heizung, Eigentum und Vorhaben
                ein – und übermittelt Ihre Anfrage erst nach SMS-Bestätigung an
                den namentlich genannten Bremer Fachpartner. Keine automatische
                Bewertung, kein anonymer Leadverkauf, keine Kosten.
            </p>
        </div>
    </SectionShell>

    <FunnelParent client:visible />

    <FAQSection heading="FAQ: Wärmepumpen-Check Bremen" items={faqs} />
</Layout>
