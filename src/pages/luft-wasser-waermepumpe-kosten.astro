---
import Layout from "../layout/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import TrustBar from "../components/TrustBar.astro";
import CTASection from "../components/CTASection.astro";
import FAQSection from "../components/FAQSection.astro";
import SectionShell from "../components/SectionShell.astro";
import NoticeSuccess from "../components/content/NoticeSuccess.astro";
import CheckList from "../components/content/CheckList.astro";
import InternalLinkCard from "../components/InternalLinkCard.astro";
import heroImage from "../images/heat-pump-bremen-hero.webp";

import type { PageData } from "../types/page";

const data: PageData = {
    // De-lokalisierter Kosten-Spoke: zielt auf „luft wasser wärmepumpe kosten"
    // (bundesweites Volumen). Der Bremen-Bezug gehört auf den lokalen Hub —
    // hier erzeugte er nur Konkurrenz um Bremen-Queries ohne einen Klick.
    title: "Luft-Wasser-Wärmepumpe Kosten 2026: Preise, Einbau, Betrieb",
    description: "Luft-Wasser-Wärmepumpe Kosten 2026: Gerät, Einbau, Stromverbrauch und Schallschutz – realistisch aufgeschlüsselt für Bestandsgebäude.",
    lastUpdated: "Mai 2026",
    hero: {
        headline: "Luft-Wasser-Wärmepumpe Kosten",
        subtext: "Die häufigste Bauart im Bestandsgebäude – ehrliche Aufschlüsselung von Anschaffung, Einbau und laufenden Kosten.",
        primaryCTA: {
            label: "Eignung & Förderung prüfen",
            href: "/check/"
        },
        secondaryCTA: {
            label: "Kosten-Übersicht Bremen",
            href: "/waermepumpe-kosten-bremen/"
        }
    },
    trustItems: [
        {
            text: "Preise nach Leistungsklasse"
        },
        {
            text: "Inkl. Schallschutz-Kosten"
        },
        {
            text: "Stand Mai 2026"
        },
        {
            text: "Inkl. Stromkosten pro Jahr"
        }
    ],
    breadcrumb: [
        {
            label: "Startseite",
            href: "/"
        },
        {
            label: "Kosten Bremen",
            href: "/waermepumpe-kosten-bremen/"
        },
        {
            label: "Luft-Wasser-Wärmepumpe"
        }
    ],
    ctaBlock: {
        headline: "Passt eine Luft-Wasser-Wärmepumpe zu Ihrem Haus?",
        text: "Kurzer Experten-Check zur Eignung und passenden Größe – unverbindlich & kostenlos.",
        variant: "highlight",
        primaryCTA: {
            label: "Eignung & Förderung prüfen",
            href: "/check/"
        },
        secondaryCTA: {
            label: "Förderung Bremen",
            href: "/waermepumpe-foerderung-bremen/"
        }
    },
    faqHeading: "FAQ: Luft-Wasser-Wärmepumpe Kosten",
    faqs: [
        {
            question: "Was kostet eine Luft-Wasser-Wärmepumpe inklusive Einbau?",
            answer: "Für ein Einfamilienhaus liegen die Komplettkosten typischerweise zwischen 22.000 und 35.000 Euro brutto. Davon entfallen etwa 9.000 bis 16.000 Euro auf das Gerät und 7.000 bis 14.500 Euro auf Installation, Hydraulik und Inbetriebnahme. Hochtemperatur-Modelle mit dem natürlichen Kältemittel R290 liegen häufig am oberen Ende der Spanne."
        },
        {
            question: "Wie viel Strom verbraucht eine Luft-Wasser-Wärmepumpe pro Jahr?",
            answer: "Ein Einfamilienhaus mit 140 m² teilsanierter Bausubstanz und 14.000 kWh Heizwärmebedarf benötigt bei einer realistischen Jahresarbeitszahl (JAZ) von 3,5 etwa 4.000 kWh Wärmepumpenstrom pro Jahr. Bei einem Wärmepumpentarif um 25 ct/kWh sind das rund 1.000 Euro Stromkosten pro Jahr."
        },
        {
            question: "Lohnt sich eine Luft-Wasser-Wärmepumpe gegenüber einer Gasheizung?",
            answer: "Auf 20-Jahres-Sicht kann sie sich lohnen. Eine neue Gasheizung ist in der Anschaffung meist günstiger, verursacht aber fossile Brennstoff- und CO₂-Kosten. Bei der Wärmepumpe zählen neben der Investition der Stromtarif, die Effizienz und eine mögliche Förderung, deren aktuelle Konditionen separat geprüft werden müssen."
        },
        {
            question: "Welchen Anteil machen Schallschutz und Aufstellung an den Kosten aus?",
            answer: "Kalkulieren Sie 400 bis 800 Euro für eine akustische Fachplanung und 300 bis 1.200 Euro für schwingungsentkoppelte Aufstellung. Eine nachträgliche Schallschutzhaube kostet 800 bis 2.500 Euro und wird meist nur nötig, wenn Aufstellort und Gerätewahl vorher nicht geprüft wurden. Zusammen sind das rund 3 bis 6 Prozent der Gesamtinvestition."
        },
        {
            question: "Welche Hersteller kommen für Bestandsgebäude infrage?",
            answer: "Verbreitet sind Vaillant aroTHERM, Viessmann Vitocal, Wolf CHA, Stiebel Eltron WPL, Daikin Altherma und Bosch Compress. Hochtemperatur-R290-Modelle (für Altbau) bieten u. a. Vaillant aroTHERM plus, Viessmann Vitocal 250-A, Wolf CHA-Monoblock und Bosch Compress 5800i AW. Eine konkrete Empfehlung kann nur ein Heizungsbauer nach Heizlastberechnung geben."
        }
    ],
    schema: {
        type: "Article",
        datePublished: "2026-05-02",
        dateModified: "2026-07-15"
    }
};

const canonical = data.canonical ?? Astro.url.href;
const hero = { ...data.hero, imageSrc: heroImage };
const dateLine = data.lastUpdated ? `Stand: ${data.lastUpdated}` : null;
const pageSchema = data.schema
    ? {
          ...data.schema,
          datePublished: data.schema.datePublished ?? data.schema.dateModified,
          dateModified: data.schema.dateModified ?? data.schema.datePublished,
      }
    : undefined;
---

<Layout
    title={data.title}
    description={data.description}
    canonical={canonical}
    noindex={data.noindex}
    pageSchema={pageSchema}
>
    {data.breadcrumb?.length > 0 && <Breadcrumb items={data.breadcrumb} />}
    <HeroSection {...hero} />
    {data.trustItems?.length > 0 && <TrustBar items={data.trustItems} />}
    {dateLine && (
        <div class="bg-background border-b border-border">
            <p class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-text-muted">
                {dateLine} · Redaktion bremer-waermepumpe.de · Alle Angaben ohne Gewähr
            </p>
        </div>
    )}

{/* Intro */}
<SectionShell>
  <article class="max-w-3xl space-y-4 text-text-muted leading-relaxed">
    <div class="bg-highlight border border-border rounded p-5">
      <p class="font-bold text-text mb-2">Schnelle Antwort</p>
      <p class="text-sm leading-relaxed">
        Eine Luft-Wasser-Wärmepumpe kostet in einem Bestandsgebäude
        typischerweise <strong class="text-text">22.000 bis 35.000 €</strong>{" "}
        vor Förderung. Bei Altbau, R290-Hochtemperaturgerät, Schallschutz oder
        Heizkörpertausch kann der obere Bereich realistisch sein. Eine mögliche
        Förderung wird nicht in diese Kostenspanne eingerechnet; aktuelle Details
        stehen auf der <a href="/kfw-458-waermepumpe/" class="text-primary underline">KfW-458-Seite</a>.
      </p>
    </div>
    <p>
      Die <strong class="text-text">Luft-Wasser-Wärmepumpe</strong> ist die mit Abstand
      häufigste Bauart im Bestand. Sie braucht keine Bohrung und keine Erdaushub-Genehmigung
      und passt in fast jeden Garten oder Innenhof – auch in dichten Reihenhauszeilen,
      sofern Aufstellort und Schallschutz vorher geplant werden.
    </p>
    <p>
      Diese Seite ordnet die Kosten ehrlich ein – Anschaffung, Einbau, laufende
      Stromkosten – und zeigt, wo Spielraum nach oben oder unten besteht.
    </p>
  </article>
</SectionShell>

{/* Detail-Aufschlüsselung */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Was kostet eine Luft-Wasser-Wärmepumpe? Detailaufschlüsselung
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Drei typische Leistungsklassen. Alle Preise inklusive Mehrwertsteuer, vor
    Abzug der Förderung.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="surface-card p-5">
      <h3 class="font-semibold text-text">Standard 8–10 kW</h3>
      <p class="text-text-muted text-sm mt-1">Saniertes Einfamilienhaus, ~120 m²</p>
      <ul class="text-sm text-text-muted mt-3 space-y-1">
        <li>Gerät: 9.000 – 12.000 €</li>
        <li>Installation: 7.000 – 10.000 €</li>
        <li>Hydraulik & Speicher: 2.000 – 3.000 €</li>
      </ul>
      <p class="font-bold text-primary mt-3 text-lg">22.000 – 27.000 €</p>
    </div>
    <div class="surface-card p-5">
      <h3 class="font-semibold text-text">Mittlere Klasse 10–14 kW</h3>
      <p class="text-text-muted text-sm mt-1">Teilsanierter Altbau, ~150 m²</p>
      <ul class="text-sm text-text-muted mt-3 space-y-1">
        <li>Gerät: 11.000 – 14.500 €</li>
        <li>Installation: 9.000 – 12.000 €</li>
        <li>Hydraulik & Speicher: 2.500 – 3.500 €</li>
      </ul>
      <p class="font-bold text-primary mt-3 text-lg">24.000 – 32.000 €</p>
    </div>
    <div class="surface-card p-5">
      <h3 class="font-semibold text-text">Hochtemperatur 14–18 kW (R290)</h3>
      <p class="text-text-muted text-sm mt-1">Unsanierter Altbau, ~190 m²</p>
      <ul class="text-sm text-text-muted mt-3 space-y-1">
        <li>Gerät: 13.000 – 16.500 €</li>
        <li>Installation: 10.500 – 14.500 €</li>
        <li>Hydraulik & Speicher: 3.000 – 4.500 €</li>
      </ul>
      <p class="font-bold text-primary mt-3 text-lg">28.000 – 36.000 €</p>
    </div>
  </div>

  <NoticeSuccess class="mt-6" variant="bordered">
    <p>
      <strong>R290 richtig einordnen:</strong> Das natürliche Kältemittel kann technisch
      sinnvoll sein, ist aber kein Ersatz für Heizlastberechnung und Kostenvergleich.
      Ob Geräte- oder Projektmerkmale aktuell die Förderung beeinflussen, steht auf der
      <a href="/kfw-458-waermepumpe/" class="text-primary underline">KfW-458-Detailseite</a>.
    </p>
  </NoticeSuccess>
</SectionShell>

{/* Schallschutz nur als Kostenposition. Die Regelwerke selbst (Grenzabstand,
    TA-Lärm-Werte) gehören auf die Abstands- und Lautstärke-Seiten — ausgebaut
    trat dieser Abschnitt gegen /waermepumpe-abstand-nachbar-bremen/ an und
    nahm ihr Impressionen zu ihrer eigenen Query ab. */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Was Schallschutz kostet
  </h2>
  <p class="text-text-muted max-w-3xl mb-6">
    Lärm ist der häufigste Einwand gegen Luft-Wasser-Wärmepumpen – und der
    Posten, der in Angeboten am häufigsten fehlt. Drei Positionen sollten Sie
    einkalkulieren:
  </p>

  <div class="space-y-4 max-w-3xl">
    <div class="surface-card p-5">
      <p class="font-semibold text-text mb-1">Akustische Fachplanung: 400–800 €</p>
      <p class="text-text-muted text-sm leading-relaxed">
        Rechnet die zu erwartenden Schallwerte am Nachbargrundstück nach und
        dokumentiert sie. Vermeidet Streit mit Nachbarn und Bauaufsicht und ist
        die günstigste Position im Vergleich zu späteren Nachrüstungen.
      </p>
    </div>
    <div class="surface-card p-5">
      <p class="font-semibold text-text mb-1">Aufstellung und Entkopplung: 300–1.200 €</p>
      <p class="text-text-muted text-sm leading-relaxed">
        Schwingungsentkoppeltes Fundament oder Wandkonsole, Führung der
        Kondensatleitung, Ausrichtung der Ausblasrichtung weg vom Nachbarn.
        Ein modernes Außengerät bei 50 dB(A) verliert über 3 Meter Distanz und
        einfache Massnahmen rasch <strong class="text-text">15–20 dB(A)</strong>.
      </p>
    </div>
    <div class="surface-card p-5">
      <p class="font-semibold text-text mb-1">Schallschutzhaube nachträglich: 800–2.500 €</p>
      <p class="text-text-muted text-sm leading-relaxed">
        Nur nötig, wenn Aufstellort und Gerätewahl von vornherein ungünstig
        waren – der Grund, warum sich die Fachplanung vorher rechnet.
      </p>
    </div>
  </div>

  <p class="text-text-muted max-w-3xl text-sm mt-6">
    Welche Grenzwerte und Grenzabstände dabei einzuhalten sind, unterscheidet
    sich je Bundesland: <a href="/waermepumpe-abstand-nachbar/" class="text-primary underline"
      >Abstand zum Nachbarn</a
    > fasst die Landesbauordnungen zusammen,
    <a href="/waermepumpe-lautstaerke-nachbar/" class="text-primary underline"
      >Lautstärke und Nachbarschaft</a
    > die TA-Lärm-Werte.
  </p>
</SectionShell>

{/* Stromkosten */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Was kostet der Betrieb? Stromverbrauch und Wärmepumpentarif
  </h2>
  <p class="text-text-muted max-w-3xl mb-4">
    Der Stromverbrauch hängt von der <strong class="text-text">Jahresarbeitszahl (JAZ)</strong>{" "}
    ab – sie sagt, wie viel kWh Wärme pro kWh Strom erzeugt werden. Realistische Werte
    für Luft-Wasser-Wärmepumpen:
  </p>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-4xl">
    <div class="surface-card p-5 text-center">
      <p class="text-3xl font-bold text-primary">3,8 – 4,2</p>
      <p class="font-semibold text-text mt-2">JAZ Neubau / saniert</p>
      <p class="text-text-muted text-sm mt-2">Mit Fußbodenheizung, Vorlauftemperatur 30–40 °C</p>
    </div>
    <div class="surface-card p-5 text-center">
      <p class="text-3xl font-bold text-primary">3,3 – 3,7</p>
      <p class="font-semibold text-text mt-2">JAZ teilsaniert</p>
      <p class="text-text-muted text-sm mt-2">Mit modernen Heizkörpern, Vorlauf 45–55 °C</p>
    </div>
    <div class="surface-card p-5 text-center">
      <p class="text-3xl font-bold text-primary">2,8 – 3,2</p>
      <p class="font-semibold text-text mt-2">JAZ Altbau (R290)</p>
      <p class="text-text-muted text-sm mt-2">Hochtemperatur-WP, Vorlauf 55–65 °C</p>
    </div>
  </div>

  <p class="text-text-muted max-w-3xl text-sm mt-6">
    Bei 14.000 kWh Jahres-Heizwärmebedarf und JAZ 3,5 ergeben sich rund 4.000 kWh
    Wärmepumpenstrom – bei einem Wärmepumpentarif um 25 ct/kWh etwa <strong
    class="text-text">1.000 Euro Stromkosten pro Jahr</strong>. Wer Photovoltaik und/oder
    Speicher dazu hat, kann diesen Wert um 20–40 % drücken. Die konkreten Bremer
    Tarifkonditionen stehen auf
    <a href="/waermepumpe-kosten-bremen/" class="text-primary underline"
      >Wärmepumpe Kosten Bremen</a
    >.
  </p>
</SectionShell>

{/* Was häufig vergessen wird */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Was viele Angebote vergessen
  </h2>
  <CheckList
    items={[
      { lead: "Akustische Fachplanung:", text: "in engen Reihenhauszeilen oft sinnvoll und im Angebot separat auszuweisen." },
      { lead: "Separater Stromzähler:", text: "Voraussetzung für den swb-Wärmepumpentarif – Tausch durch Netzbetreiber bzw. Konzession." },
      { lead: "Hydraulischer Abgleich:", text: "technisch wichtig für einen effizienten Betrieb und sauber im Angebot zu dokumentieren." },
      { lead: "Pufferspeicher und Trinkwarmwasserspeicher:", text: "müssen passend dimensioniert sein, sonst leidet die Effizienz." },
      { lead: "Fundament oder Wandkonsole:", text: "Aufstellungsart entscheidet über Schwingungsentkopplung." },
      { lead: "Rohrleitungs-Dämmung:", text: "wichtig für die JAZ – Standardposten, sollte aber im Angebot stehen." },
    ]}
  />
</SectionShell>

{/* Quellen */}
<SectionShell>
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
    Quellen und redaktioneller Stand
  </h2>
  <div class="surface-card p-5 max-w-3xl text-sm text-text-muted leading-relaxed">
    <p class="font-semibold text-text mb-3">Stand: 29. Mai 2026</p>
    <ul class="space-y-2">
      <li>
        swb: <a href="https://www.swb.de/strom/thermo-pronatur" class="text-primary underline" target="_blank" rel="noopener">Wärmepumpenstrom swb thermo proNatur</a>
      </li>
      <li>
        Bremen: <a href="https://www.transparenz.bremen.de/metainformationen/bremische-landesbauordnung-vom-29-mai-2024-232736" class="text-primary underline" target="_blank" rel="noopener">Bremische Landesbauordnung</a>
      </li>
      <li>
        Preisangaben sind redaktionelle Spannen und ersetzen kein verbindliches Fachbetriebsangebot.
      </li>
    </ul>
  </div>
</SectionShell>

{/* Cluster-Crosslinks */}
<SectionShell variant="alt">
  <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">Vertiefen</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl">
    <InternalLinkCard
      href="/waermepumpe-kosten-bremen/"
      title="Wärmepumpe Kosten Bremen"
      description="Alle Bauarten, alle Eigenanteile, swb-Wärmepumpentarif."
    />
    <InternalLinkCard
      href="/waermepumpe-altbau-kosten/"
      title="Altbau Kosten"
      description="Hochtemperatur-Wärmepumpen im Bestand, Heizkörper-Posten."
    />
    <InternalLinkCard
      href="/waermepumpe-foerderung-bremen/"
      title="Wärmepumpe Förderung Bremen"
      description="Aktuelle KfW-Konditionen und die Einordnung technischer Projektmerkmale."
    />
    <InternalLinkCard
      href="/check/"
      title="Eignungscheck"
      description="Prüfen, ob Luft-Wasser für Ihr Haus realistisch ist."
    />
  </div>
</SectionShell>

    {data.ctaBlock && <CTASection {...data.ctaBlock} />}
    {data.faqs?.length > 0 && (
        <FAQSection heading={data.faqHeading} items={data.faqs} />
    )}
</Layout>
