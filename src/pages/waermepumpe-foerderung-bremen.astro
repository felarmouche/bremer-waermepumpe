---
import { getImage } from "astro:assets";
import Layout from "../layout/Layout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import HeroSection from "../components/HeroSection.astro";
import TrustBar from "../components/TrustBar.astro";
import CTASection from "../components/CTASection.astro";
import FAQSection from "../components/FAQSection.astro";
import SectionShell from "../components/SectionShell.astro";
import NoticeSuccess from "../components/content/NoticeSuccess.astro";
import NumberedSteps from "../components/content/NumberedSteps.astro";
import InternalLinkCard from "../components/InternalLinkCard.astro";
import heroImage from "../images/foerderung-bremen-hero.webp";

import type { PageData } from "../types/page";

const data: PageData = {
  title: "Wärmepumpe Förderung Bremen 2026: Bis zu 70 % Zuschuss",
  description:
    "Wärmepumpe-Förderung in Bremen 2026: KfW 458 mit neuen Sätzen ab 21.07. (bis 70 %, Deckel 80 %), ab 02/2027 sinkt der Zuschuss. BAB-Status & Förderweg prüfen.",
  lastUpdated: "15. Juli 2026",
  hero: {
    headline: "Wärmepumpe Förderung Bremen",
    subtext:
      "KfW 458 mit neuen Sätzen ab dem 21. Juli 2026, BAFA-Heizungsoptimierung und Bremer BAB-Status: die relevanten Förderwege für Eigentümer in Bremen und Bremerhaven. Geprüft am 15. Juli 2026.",
    primaryCTA: {
      label: "Eignung & Förderung prüfen",
      href: "/check/",
    },
    secondaryCTA: {
      label: "Was kostet die Wärmepumpe?",
      href: "/waermepumpe-kosten-bremen/",
    },
  },
  trustItems: [
    {
      text: "Bis zu 70 % KfW-Zuschuss",
    },
    {
      text: "Bis zu 22.400 € beim Einfamilienhaus",
    },
    {
      text: "Volle KfW-Sätze nur bis 31.01.2027",
    },
    {
      text: "Geprüft am 15. Juli 2026",
    },
  ],
  breadcrumb: [
    {
      label: "Startseite",
      href: "/",
    },
    {
      label: "Förderung Bremen",
    },
  ],
  ctaBlock: {
    headline: "Welche Förderung passt zu Ihrer Bremer Immobilie?",
    text: "Der Browser-Check gibt eine erste unverbindliche Einordnung zu Gebäude, alter Heizung und möglichen Förderwegen – noch zu den vollen KfW-Sätzen, die bis zur ersten Kürzung am 1. Februar 2027 gelten. Kontaktdaten werden erst nach ausdrücklicher Einwilligung an den unter /fachpartner/ genannten Bremer Betrieb weitergegeben.",
    variant: "highlight",
    primaryCTA: {
      label: "Eignung & Förderung prüfen",
      href: "/check/",
    },
    secondaryCTA: {
      label: "Was kostet das nach Förderung?",
      href: "/waermepumpe-kosten-bremen/",
    },
  },
  faqHeading: "FAQ: Wärmepumpe Förderung Bremen",
  faqs: [
    {
      question: "Wie hoch ist die Wärmepumpen-Förderung in Bremen 2026?",
      answer:
        "Für den Kauf und Einbau einer förderfähigen Wärmepumpe ist KfW 458 der zentrale Zuschuss. Möglich sind bis zu 70 % der förderfähigen Kosten, für Haushalte mit dem höchsten Einkommensbonus bis zu 80 %. Bei einem Einfamilienhaus berücksichtigt die KfW ab dem 21. Juli 2026 höchstens 28.000 Euro; daraus ergeben sich je nach Boni bis zu 22.400 Euro Zuschuss. Die tatsächliche Quote hängt von Grundförderung und Boni ab.",
    },
    {
      question: "Sinkt die Wärmepumpen-Förderung ab 2027?",
      answer:
        "Ja, planmäßig: Ab dem 1. Februar 2027 sinkt der KfW-458-Höchstbetrag für die erste Wohneinheit halbjährlich um 750 Euro, der Klimageschwindigkeitsbonus um 4 Prozentpunkte. Maßgeblich sind die Konditionen am Tag der Antragstellung – je früher der Antrag, desto höher der Zuschuss. Den vollständigen Kürzungsfahrplan mit Beträgen zeigt die Detailseite KfW 458.",
    },
    {
      question: "Ist BAB Heizungstausch Bremen noch offen?",
      answer:
        "Nein. Neue Anträge für das frühere Bremer Zuschussprogramm waren nur bis zum 31. August 2025 möglich. Nach diesem Datum eingereichte Anträge müssen laut Serviceportal Bremen abgelehnt werden. Für neue Wärmepumpen-Vorhaben ist KfW 458 der zentrale Zuschussweg.",
    },
    {
      question:
        "Was ist über das neue BAB-Kreditprogramm ab Herbst 2026 bekannt?",
      answer:
        "Der Bremer Senat hat am 26. Mai 2026 die Entwicklung eines neuen Kreditförderprogramms für die Wärmewende beschlossen. Es soll im Herbst 2026 starten und Finanzierungslücken bei energetischen Sanierungen und klimafreundlichen Heizsystemen schließen. Konkrete Förderbedingungen und Angaben zur Antragstellung sind noch nicht veröffentlicht; aktuell ist das Programm noch nicht beantragbar.",
    },
    {
      question: "Was fördert BAFA rund um Wärmepumpen weiterhin?",
      answer:
        "BAFA fördert 2026 nicht den Kauf und Einbau der neuen Wärmepumpe selbst. Relevant bleiben insbesondere Heizungsoptimierung zur Verbesserung der Anlageneffizienz und Energieberatung. Bei einer Heizungsoptimierung kann ein zusätzlicher iSFP-Bonus von 5 Prozent möglich sein. Für dieselben Kosten darf keine Doppelförderung genutzt werden.",
    },
    {
      question: "Muss der KfW-Antrag vor dem Auftrag gestellt werden?",
      answer:
        'Der KfW-Antrag muss vor Beginn der Maßnahme gestellt werden. Für den Antrag ist aber bereits ein Liefer- oder Leistungsvertrag erforderlich, der eine aufschiebende oder auflösende Förderbedingung enthält. Die korrekte Reihenfolge lautet: BzA erstellen lassen, bedingten Vertrag schließen, Antrag bei „Meine KfW" stellen, Förderzusage abwarten und erst danach mit der Umsetzung beginnen.',
    },
    {
      question: "Was gilt durch das GEG seit dem 1. Juli 2026 in Bremen?",
      answer:
        "Seit dem 1. Juli 2026 gilt die 65-%-EE-Anforderung des Gebäudeenergiegesetzes im Land Bremen auch für neue Heizungen in Bestandsgebäuden. Es bestehen verschiedene Erfüllungsoptionen, Übergangsfristen und Ausnahmen. Eine Wärmepumpe ist eine der zentralen Erfüllungsoptionen.",
    },
  ],
  schema: {
    type: "Article",
    datePublished: "2026-05-02",
    dateModified: "2026-07-15",
  },
};

const canonical = data.canonical ?? Astro.url.href;
const hero = { ...data.hero, imageSrc: heroImage };
const ogImage = await getImage({
  src: heroImage,
  width: 1200,
  height: 630,
  fit: "cover",
  format: "jpg",
});
const dateLine = data.lastUpdated ? `Stand: ${data.lastUpdated}` : null;
const pageSchema = data.schema
  ? {
      ...data.schema,
      datePublished: data.schema.datePublished ?? data.schema.dateModified,
      dateModified: data.schema.dateModified ?? data.schema.datePublished,
    }
  : undefined;
---

<Layout
  title={data.title}
  description={data.description}
  canonical={canonical}
  ogImage={ogImage.src}
  noindex={data.noindex}
  pageSchema={pageSchema}
>
  {data.breadcrumb?.length > 0 && <Breadcrumb items={data.breadcrumb} />}
  <HeroSection {...hero} />
  {data.trustItems?.length > 0 && <TrustBar items={data.trustItems} />}
  {
    dateLine && (
      <div class="bg-background border-b border-border">
        <p class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-text-muted">
          {dateLine} · Redaktion bremer-waermepumpe.de · Alle Angaben ohne
          Gewähr
        </p>
      </div>
    )
  }

  {/* Answer-first: lokale Förderlage */}
  <SectionShell>
    <article class="max-w-3xl">
      <div class="surface-card p-6 sm:p-8 border-l-4 border-primary">
        <p
          class="text-xs font-semibold text-primary uppercase tracking-wide mb-3"
        >
          Kurzantwort
        </p>
        <p class="text-text leading-relaxed text-base sm:text-lg">
          Für eine neue Wärmepumpe in Bremen ist die
          <strong>KfW-Heizungsförderung 458</strong> der zentrale Zuschussweg. Ab
          dem <strong>21. Juli 2026</strong> gelten neue Konditionen:
          <strong>bis zu 70 % der förderfähigen Kosten</strong> (für die
          niedrigsten Einkommen bis 80 %), beim Einfamilienhaus höchstens
          <strong>28.000 Euro</strong> anrechenbare Kosten – je nach Boni
          <strong>bis zu 22.400 Euro Zuschuss</strong>. Das frühere Bremer
          Programm <strong>BAB Heizungstausch</strong> ist für neue Anträge seit
          dem <strong>31. August 2025</strong> geschlossen. Ein neues
          BAB-Kreditprogramm ist für <strong>Herbst 2026</strong>
          angekündigt, aktuell aber noch nicht beantragbar.
        </p>
        <p class="text-sm text-text-muted leading-relaxed mt-4">
          <strong class="text-text">Wichtig für die Planung:</strong> Ab dem
          <strong class="text-text">1. Februar 2027</strong> wird die
          KfW-Förderung planmäßig abgeschmolzen – der Höchstbetrag sinkt
          halbjährlich um 750 €, der Klimageschwindigkeitsbonus um
          4 Prozentpunkte. Was Warten konkret kostet, zeigt der
          <a
            href="/kfw-458-waermepumpe/#foerder-fahrplan"
            class="text-primary underline">Kürzungsfahrplan auf der KfW-458-Seite</a
          >.
        </p>
      </div>
      <p class="text-text-muted leading-relaxed mt-6">
        Diese Seite ordnet die Förderwege für Eigentümer in Bremen und
        Bremerhaven ein: Was bezuschusst den Heizungstausch, wann ist BAFA
        relevant und welcher lokale BAB-Status gilt am 15. Juli 2026?
        Detailfragen zur Berechnung und zu Sonderfällen bleiben bewusst auf den
        verlinkten Fachseiten, damit sich die Inhalte nicht gegenseitig
        Konkurrenz machen.
      </p>
      <NoticeSuccess class="mt-6">
        <p>
          <strong>Verfasser:</strong>
          <a href="/kontakt/" class="text-primary underline"
            >Ferris El-Armouche</a
          >. Quellenstand: 15. Juli 2026. Diese private Informationsseite ersetzt
          keine verbindliche Förderberatung oder Förderzusage. Vor dem Antrag
          müssen die Angaben für Ihr Vorhaben durch ein zugelassenes
          Fachunternehmen oder einen Energieeffizienz-Experten geprüft werden.
        </p>
      </NoticeSuccess>
    </article>
  </SectionShell>

  {/* KfW 458: kompakte Hub-Einordnung */}
  <SectionShell variant="alt">
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
      KfW 458: Bis zu 70 % Zuschuss für die Wärmepumpe
    </h2>
    <p class="text-text-muted max-w-3xl mb-6">
      Für bestehende Wohngebäude ist KfW 458 der zentrale Zuschuss für Kauf und
      Einbau einer klimafreundlichen Heizung. Ab dem
      <strong class="text-text">21. Juli 2026</strong> gelten neue Konditionen:
      Die Grundförderung bleibt bei 30 %, der Klimageschwindigkeitsbonus sinkt
      auf 16 %, der Effizienzbonus entfällt und der Einkommensbonus wird auf
      40/30/10 % gestaffelt. Gedeckelt wird bei
      <strong class="text-text">70 %</strong> – nur Haushalte mit dem höchsten
      Einkommensbonus erreichen 80 %.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-4xl">
      <div class="surface-card p-5">
        <div class="text-3xl font-bold text-primary mb-3">30 %</div>
        <h3 class="font-semibold text-text">Basisförderung</h3>
        <p class="text-text-muted text-sm mt-2">
          Grundlage für eine förderfähige Wärmepumpe im bestehenden Wohngebäude.
        </p>
      </div>
      <div class="surface-card p-5">
        <div class="text-3xl font-bold text-primary mb-3">70 %</div>
        <h3 class="font-semibold text-text">Maximale Förderquote</h3>
        <p class="text-text-muted text-sm mt-2">
          Mehrere Boni können zusammenkommen. Für die niedrigsten Einkommen
          steigt der Deckel auf 80 %.
        </p>
      </div>
      <div class="surface-card p-5">
        <div class="text-3xl font-bold text-primary mb-3">28.000 €</div>
        <h3 class="font-semibold text-text">
          Förderfähige Kosten beim Einfamilienhaus
        </h3>
        <p class="text-text-muted text-sm mt-2">
          Höchstbetrag für die erste Wohneinheit ab dem 21.07.2026 – je nach
          Boni bis zu 22.400 € Zuschuss.
        </p>
      </div>
    </div>
    <p class="text-text-muted max-w-3xl text-sm leading-relaxed mt-6">
      Welche Kosten bei mehreren Wohneinheiten gelten, wann Klimageschwindigkeits-
      oder Einkommensbonus greifen und wie die Förderung ab Februar 2027
      schrittweise sinkt, steht auf der Detailseite
      <a href="/kfw-458-waermepumpe/" class="text-brand underline"
        >KfW 458 förderfähige Kosten</a
      >.
    </p>
  </SectionShell>

  {/* Bremen-spezifische Förderwege */}
  <SectionShell>
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
      Welche Förderung gibt es in Bremen lokal?
    </h2>
    <p class="text-text-muted max-w-3xl mb-6">
      Für neue Wärmepumpen-Projekte ist die Trennung der Programme entscheidend:
      Zuschuss, Optimierung und künftige Finanzierung sind nicht dasselbe.
    </p>
    <div class="surface-card overflow-hidden max-w-4xl divide-y divide-border">
      <div
        class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1.4fr] gap-2 px-5 py-4 text-sm font-semibold text-text bg-highlight"
      >
        <span>Förderweg</span>
        <span>Status am 15. Juli 2026</span>
        <span>Einordnung für Bremen</span>
      </div>
      <div
        class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1.4fr] gap-2 px-5 py-4 text-sm"
      >
        <span class="font-semibold text-text">KfW 458</span>
        <span class="text-text-muted">zentraler Zuschuss</span>
        <span class="text-text-muted"
          >Fördert die Wärmepumpe und technisch notwendige Umfeldmaßnahmen im
          Bestand. Details
          auf der <a
            href="/kfw-458-waermepumpe/"
            class="text-brand underline">KfW 458-Seite</a
          >.</span
        >
      </div>
      <div
        class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1.4fr] gap-2 px-5 py-4 text-sm"
      >
        <span class="font-semibold text-text">BAFA-Heizungsoptimierung</span>
        <span class="text-text-muted">Optimierung und Beratung</span>
        <span class="text-text-muted"
          >Nicht der Einbau der neuen Wärmepumpe selbst. Heizungsoptimierung,
          Energieberatung und ein möglicher iSFP-Bonus bleiben relevant. Details
          auf der <a
            href="/bafa-foerderung-waermepumpe/"
            class="text-brand underline">BAFA-Seite</a
          >.</span
        >
      </div>
      <div
        class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1.4fr] gap-2 px-5 py-4 text-sm"
      >
        <span class="font-semibold text-text">BAB Heizungstausch</span>
        <span class="text-text-muted">für neue Anträge geschlossen</span>
        <span class="text-text-muted"
          >Das frühere Bremer Zuschussprogramm lief für neue Anträge bis
          31.08.2025. Für Altanträge gelten Restfristen. Details auf der <a
            href="/bab-heizungstausch-bremen/"
            class="text-brand underline">BAB-Seite</a
          >.</span
        >
      </div>
      <div
        class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1.4fr] gap-2 px-5 py-4 text-sm"
      >
        <span class="font-semibold text-text">Neues BAB-Kreditprogramm</span>
        <span class="text-text-muted">für Herbst 2026 angekündigt</span>
        <span class="text-text-muted"
          >Soll Finanzierungslücken bei energetischer Sanierung und
          klimafreundlichen Heizsystemen schließen. Konkrete Bedingungen sind
          noch nicht veröffentlicht; aktuell ist kein Antrag möglich.</span
        >
      </div>
    </div>
  </SectionShell>

  {/* GEG §71 ab 01.07.2026 */}
  <SectionShell variant="alt">
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
      GEG §71 seit 01.07.2026: Was gilt jetzt in Bremen?
    </h2>
    <p class="text-text-muted max-w-3xl mb-4">
      Seit dem <strong class="text-text">1. Juli 2026</strong> gilt im Land Bremen die
      65-%-EE-Anforderung des Gebäudeenergiegesetzes (GEG §71) auch für neue Heizungen
      in Bestandsgebäuden. Es bestehen verschiedene Erfüllungsoptionen, Übergangsfristen
      und Ausnahmen. Eine Wärmepumpe ist eine der zentralen Erfüllungsoptionen.
    </p>
    <p class="text-text-muted max-w-3xl mb-4">
      Die <strong class="text-text">kommunale Wärmeplanung</strong> dient Eigentümern
      als Orientierungshilfe: Sie soll zeigen, welche klimafreundlichen Wärmeversorgungen
      sich für einzelne Gebiete eignen. Sie ersetzt weder die Prüfung des Gebäudes
      noch eine konkrete Förderzusage.
    </p>
    <p class="text-text-muted max-w-3xl text-sm">
      Detail-Update zu allen 2026er-Änderungen auf der Seite <a
        href="/waermepumpe-foerderung-2026/"
        class="text-brand underline">Wärmepumpe Förderung 2026</a
      >.
    </p>
  </SectionShell>

  {/* Antragsweg: bewusst kompakt, Details auf der KfW-Spoke */}
  <SectionShell>
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">
      KfW 458 beantragen: die richtige Reihenfolge
    </h2>
    <NumberedSteps
      items={[
        {
          title: "BzA erstellen lassen",
          text: "Eine Bestätigung zum Antrag (BzA) muss durch einen Energieeffizienz-Experten oder ein zugelassenes Fachunternehmen ausgestellt werden. Ohne BzA-ID kein Antrag.",
        },
        {
          title: "Bedingten Vertrag schließen und Antrag stellen",
          text: 'Für den Antrag ist ein Liefer- oder Leistungsvertrag mit aufschiebender oder auflösender Förderbedingung erforderlich. Danach stellen Sie den Zuschussantrag im Portal „Meine KfW".',
        },
        {
          title: "Zusage abwarten und danach umsetzen",
          text: "Erst nach der KfW-Förderzusage beginnen Sie mit der Umsetzung. Nach Abschluss werden Bestätigung nach Durchführung (BnD) und Rechnungen für die Auszahlung eingereicht.",
        },
      ]}
    />
    <p class="text-text-muted max-w-3xl text-sm mt-6">
      Sonderfälle für Mehrfamilienhäuser und WEG, die gestaffelten Kosten je
      Wohneinheit und die vollständigen Antragsschritte stehen auf der Seite
      <a href="/kfw-458-waermepumpe/" class="text-brand underline"
        >KfW 458 im Detail</a
      >.
    </p>
  </SectionShell>

  {/* Quellen */}
  <SectionShell>
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-4">
      Quellen und redaktioneller Stand
    </h2>
    <div
      class="surface-card p-5 max-w-3xl text-sm text-text-muted leading-relaxed"
    >
      <p class="font-semibold text-text mb-3">
        Quellenstand: 15. Juli 2026 · neue KfW-Konditionen ab 21.07.2026
      </p>
      <ul class="space-y-2">
        <li>
          KfW: <a
            href="https://www.kfw.de/inlandsfoerderung/Privatpersonen/Bestehende-Immobilie/F%C3%B6rderprodukte/Heizungsf%C3%B6rderung-f%C3%BCr-Privatpersonen-Wohngeb%C3%A4ude-%28458%29/"
            class="text-primary underline"
            target="_blank"
            rel="noopener"
            >Heizungsförderung für Privatpersonen – Wohngebäude 458</a
          >
        </li>
        <li>
          KfW: <a
            href="https://www.kfw.de/%C3%9Cber-die-KfW/Newsroom/Aktuelles/Pressemitteilungen-Details_900928.html"
            class="text-primary underline"
            target="_blank"
            rel="noopener"
            >Pressemitteilung: Anpassungen der BEG-Förderung zum 21.07.2026
            (inkl. Degression ab 01.02.2027)</a
          >
        </li>
        <li>
          BAFA: <a
            href="https://www.bafa.de/DE/Energie/Effiziente_Gebaeude/Sanierung_Wohngebaeude/Heizungsoptimierung/heizungsoptimierung_node.html"
            class="text-primary underline"
            target="_blank"
            rel="noopener">Heizungsoptimierung und iSFP-Bonus</a
          >
        </li>
        <li>
          Bremen Service: <a
            href="https://www.service.bremen.de/dienstleistungen/foerderung-fuer-den-heizungstausch-beantragen-190934"
            class="text-primary underline"
            target="_blank"
            rel="noopener">Förderung für den Heizungstausch beantragen</a
          >
        </li>
        <li>
          BAB: <a
            href="https://www.bab-bremen.de/de/page/news/82957"
            class="text-primary underline"
            target="_blank"
            rel="noopener"
            >Neues Kreditförderprogramm für die Wärmewende ab Herbst 2026</a
          >
        </li>
        <li>
          Umwelt Bremen: <a
            href="https://umwelt.bremen.de/klima/energie/gebaeudeenergiegesetz-geg/anforderungen-an-bestehende-gebaeude-2387269"
            class="text-primary underline"
            target="_blank"
            rel="noopener">GEG-Anforderungen an bestehende Gebäude</a
          >
        </li>
        <li>
          Umwelt Bremen: <a
            href="https://umwelt.bremen.de/klima/waermewende/die-kommunale-waermeplanung-2383791"
            class="text-primary underline"
            target="_blank"
            rel="noopener">Kommunale Wärmeplanung als Orientierungshilfe</a
          >
        </li>
        <li>
          Diese Seite ersetzt keine verbindliche Förderzusage der KfW, BAFA, BAB
          oder eines Energieeffizienz-Experten.
        </li>
      </ul>
    </div>
  </SectionShell>

  {/* Cluster-Crosslinks */}
  <SectionShell variant="alt">
    <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">
      Vertiefen: Förderung im Detail
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl">
      <InternalLinkCard
        href="/kfw-458-waermepumpe/"
        title="KfW 458 im Detail"
        description="Förderfähige Kosten 28.000 / 15.000 / 8.000 €, Kürzungsfahrplan ab 2027, Antragsschritte und Fallstricke."
      />
      <InternalLinkCard
        href="/bafa-foerderung-waermepumpe/"
        title="BAFA-Förderung Wärmepumpe"
