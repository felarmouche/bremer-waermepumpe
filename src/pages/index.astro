---
import Layout from "../layout/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import TrustBar from "../components/TrustBar.astro";
import SectionShell from "../components/SectionShell.astro";
import ProcessSection from "../components/ProcessSection.astro";
import FAQSection from "../components/FAQSection.astro";
import CTASection from "../components/CTASection.astro";
import heroImage from "../images/heat-pump-bremen-hero.webp";

const title = "Wärmepumpe Bremen: Eignungscheck, Kosten & Förderung";
const description =
    "Wärmepumpe in Bremen planen: Eignung im Altbau, Kosten, swb-Heizstrom, KfW-Förderung und lokale Fachpartner-Einschätzung prüfen.";
const canonical = Astro.url.href;

const trustItems = [
    { text: "Fokus auf Bremen und Umgebung" },
    { text: "Eignungscheck für Eigentümer" },
    { text: "Bremer Fachpartner statt Leadverkauf" },
];

const processSteps = [
    {
        number: 1,
        title: "Hausdaten prüfen",
        description:
            "Gebäude, alte Heizung, Dämmstand, PLZ und Eigentümerstatus werden eingeordnet.",
    },
    {
        number: 2,
        title: "Eignung einschätzen",
        description:
            "Der Check zeigt, ob eine Wärmepumpe direkt realistisch ist oder zuerst Heizflächen, Schall oder Vorlauf geklärt werden müssen.",
    },
    {
        number: 3,
        title: "Kostenrahmen verstehen",
        description: "Bauart, Aufstellort und notwendige Umfeldmaßnahmen bestimmen die Investition.",
    },
    {
        number: 4,
        title: "Förderung prüfen",
        description: "KfW 458, BAFA-Optimierung und lokale Bremer Bausteine werden sauber getrennt.",
    },
    {
        number: 5,
        title: "Fachpartner anfragen",
        description:
            "Wenn das Objekt passt, kann ein Bremer Fachpartner die nächsten Schritte prüfen.",
    },
];

const faqs = [
    {
        question: "Funktioniert eine Wärmepumpe im Altbau?",
        answer: "In vielen Fällen ja – aber es hängt von Faktoren wie Dämmstandard, Heizkörpern und Vorlauftemperatur ab. Eine individuelle Prüfung durch einen Fachbetrieb bringt hier Klarheit.",
    },
    {
        question: "Geht das auch ohne Fußbodenheizung?",
        answer: "Ja, eine Wärmepumpe kann auch mit Heizkörpern funktionieren. Entscheidend ist die Vorlauftemperatur. In vielen Bremer Bestandsgebäuden ist das mit optimierten Heizkörpern möglich.",
    },
    {
        question: "Wie laut ist eine Wärmepumpe?",
        answer: "Moderne Luft-Wasser-Wärmepumpen arbeiten im Bereich von 35–50 dB. Bei der Planung ist die Aufstellung so zu wählen, dass die Schallschutzanforderungen der TA Lärm eingehalten werden.",
    },
    {
        question: "Was kostet eine Wärmepumpe in Bremen?",
        answer: "Die Gesamtkosten liegen je nach Objekt typischerweise zwischen 25.000 und 50.000 Euro vor Förderung – unverbindliche Orientierung, Stand 2026. Faktoren wie Altbau-Anpassungen beeinflussen den Preis.",
    },
    {
        question: "Welche Förderung gibt es aktuell?",
        answer: "Für den eigentlichen Heizungstausch ist die KfW-Heizungsförderung 458 zentral. Bis zu 70 % der förderfähigen Kosten sind möglich. BAFA bleibt eher für Optimierung, Energieberatung und iSFP relevant. Verbindliche Auskünfte erteilen KfW, BAFA und zertifizierte Energieberater.",
    },
    {
        question: "Wie läuft der Prozess typischerweise ab?",
        answer: "In der Regel erfolgt zunächst eine Heizlastberechnung, dann die Auswahl einer passenden Wärmepumpe, die Antragstellung für die KfW-Förderung und anschließend die Installation durch einen zugelassenen SHK-Meisterbetrieb.",
    },
    {
        question:
            "Kann ich eine Wärmepumpe nachrüsten, ohne komplett zu sanieren?",
        answer: "In vielen Fällen ja. Nicht jedes Haus muss vollständig kernsaniert werden. Oft reichen bereits einzelne Maßnahmen wie der Austausch von Heizkörpern, Verbesserungen an Fenstern oder eine Optimierung des Heizsystems aus.",
    },
    {
        question:
            "Welche Wärmepumpe ist für ein Reihenhaus am besten geeignet?",
        answer: "Für viele Reihenhäuser ist die Luft-Wasser-Wärmepumpe die praktikabelste Lösung, weil sie sich meist mit überschaubarem Aufwand nachrüsten lässt. Wichtig sind jedoch Platzverhältnisse, das Schallthema, die Leitungsführung und der tatsächliche Wärmebedarf des Hauses.",
    },
    {
        question: "Ist eine Wärmepumpe im norddeutschen Klima zuverlässig?",
        answer: "Ja, moderne Wärmepumpen sind grundsätzlich für den ganzjährigen Betrieb ausgelegt. Wichtig ist jedoch eine fachgerechte Planung, die richtige Gerätegröße, ein sinnvoller Aufstellort und eine sauber abgestimmte Installation. Dann arbeitet die Anlage auch unter norddeutschen Wetterbedingungen zuverlässig und effizient.",
    },
    {
        question: "Gibt es in Bremen einen günstigen Wärmepumpentarif für Strom?",
        answer: "Ja, der regionale Versorger swb bietet wie viele Anbieter einen separaten Wärmepumpen- bzw. Heizstromtarif an, der über einen eigenen Zähler abgerechnet wird und in der Regel günstiger ist als der Haushaltsstrom. Ob sich ein separater Zähler lohnt, hängt vom Verbrauch und der Auslegung ab. Anbieter und Tarife sollten Sie vor dem Wechsel aktuell vergleichen.",
    },
];
---

<Layout title={title} description={description} canonical={canonical}>
    <HeroSection
        imageSrc={heroImage}
        headline="Wärmepumpe Bremen"
        subtext="Eignung, Kosten und Förderung für Bremer Eigentümer prüfen"
        primaryCTA={{
            label: "Eignung & Förderung prüfen",
            href: "/check/",
        }}
        secondaryCTA={{
            label: "Kosten in Bremen verstehen",
            href: "/waermepumpe-kosten-bremen/",
        }}
    />

    <TrustBar items={trustItems} />

    <!-- Intro -->
    <SectionShell>
        <article class="max-w-3xl">
            <p class="text-text leading-relaxed text-base sm:text-lg">
                Eine <strong>Wärmepumpe in Bremen</strong> ist für viele Eigentümer
                realistisch, aber nicht jede Immobilie braucht dieselbe Lösung. Der
                wichtigste erste Schritt ist deshalb kein Gerätevergleich, sondern ein
                ehrlicher Eignungscheck: Vorlauftemperatur, Heizkörper, alte Heizung,
                Aufstellort, Schallschutz, Kostenrahmen und mögliche KfW-Förderung.
            </p>
            <p class="text-text-muted leading-relaxed mt-5">
                bremer-waermepumpe.de richtet sich an Eigentümer in Bremen,
                Bremerhaven und dem Umland, die einen Heizungstausch konkret prüfen.
                Der <a href="/check/" class="text-primary underline"
                    >Eignungs- und Fördercheck</a
                > ordnet Ihr Haus direkt im Browser ein. Danach können Sie die Details zu
                <a href="/waermepumpe-kosten-bremen/" class="text-primary underline"
                    >Kosten in Bremen</a
                >,
                <a href="/waermepumpe-foerderung-bremen/" class="text-primary underline"
                    >Förderung</a
                > und
                <a href="/waermepumpe-altbau-bremen/" class="text-primary underline"
                    >Altbau-Eignung</a
                > vertiefen.
            </p>
        </article>
    </SectionShell>

    <!-- Lokale Einordnung -->
    <SectionShell>
        <h2
            class="text-2xl md:text-3xl font-bold tracking-tight text-text mb-6"
        >
            Lokale Erstberatung statt anonymer Leadverkauf
        </h2>
        <p class="text-text-muted leading-relaxed mb-6 max-w-3xl">
            Der Check ist bewusst auf Bremen und Umgebung zugeschnitten. Bei passender
            Ausgangslage kann Ihre Anfrage an den namentlich genannten Bremer
            Fachpartner <strong class="text-text">Fritts Group, Osterdeich 59A,
            28203 Bremen</strong> weitergegeben werden. Fokusgebiet sind die
            PLZ-Bereiche <strong class="text-text">27xxx und 28xxx</strong> – von der
            Neustadt, Findorff und Schwachhausen über die Vahr bis nach Bremen-Nord,
            Vegesack und ins Bremerhavener Umland.
        </p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-3xl">
            {[
                "Keine Weitergabe an anonyme Leadbörsen",
                "Bremen-Fokus: Reihenhäuser, Altbremer Häuser, Bremerhaven und Umland",
                "Erste Einordnung zu KfW 458, BAFA und BAB-Status",
                "Direkter Blick auf Aufstellort, Schall und Heizflächen",
            ].map((item) => (
                <li class="flex items-start gap-3 text-text-muted text-sm leading-relaxed">
                    <span class="text-primary font-bold mt-0.5 shrink-0">✓</span>
                    {item}
                </li>
            ))}
        </ul>
    </SectionShell>

    <!-- Warum sich eine WP lohnt -->
    <SectionShell variant="alt">
        <h2
            class="text-2xl md:text-3xl font-bold tracking-tight text-text mb-6"
        >
            Warum sich eine Wärmepumpe in Bremen lohnt
        </h2>
        <p class="text-text-muted leading-relaxed max-w-2xl mb-8">
            Moderne Systeme nutzen Umweltenergie aus Luft, Erdreich oder Wasser.
            Für Bremer Eigentümer wird die Entscheidung vor allem durch drei Punkte
            interessant: KfW-Förderung, planbare Stromkosten über Wärmepumpentarife
            und die Frage, ob das Haus mit niedriger Vorlauftemperatur warm wird.
        </p>
        <p class="font-semibold text-text mb-4">Ihre Vorteile im Überblick:</p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8 max-w-3xl">
            {
                [
                    "Niedrigere laufende Heizkosten bei guter Planung und passender Auslegung",
                    "Weniger Abhängigkeit von Gas- und Ölpreisen",
                    "Klimafreundliche Heizlösung mit deutlich geringeren Emissionen",
                    "Kombinierbar mit Photovoltaik für noch mehr Eigenverbrauch",
                    "Hohe Fördermöglichkeiten für Austausch und Modernisierung",
                    "Wartungsarm im Vergleich zu vielen klassischen Heizsystemen",
                    "Attraktive Lösung für Sanierung und Neubau",
                ].map((item) => (
                    <li class="flex items-start gap-3 text-text-muted text-sm leading-relaxed">
                        <span class="text-primary font-bold mt-0.5 shrink-0">
                            ✓
                        </span>
                        {item}
                    </li>
                ))
            }
        </ul>
        <p class="text-text-muted leading-relaxed max-w-2xl text-sm">
            Gerade in Bremen spielt der Gebäudebestand eine große Rolle. Viele
            Häuser sind älter, teilweise modernisiert und haben individuelle
            Voraussetzungen. Genau deshalb ist eine pauschale Empfehlung selten
            sinnvoll. Entscheidend ist immer, wie gut Haus, Heizflächen,
            Wärmebedarf und Aufstellort zusammenpassen. Für Reihenhäuser ist auch
            der <a href="/waermepumpe-abstand-nachbar-bremen/" class="text-primary underline"
                >Abstand zum Nachbarn</a
            > relevant.
        </p>
    </SectionShell>

    <!-- Für welche Gebäude geeignet -->
    <SectionShell>
        <h2
            class="text-2xl md:text-3xl font-bold tracking-tight text-text mb-6"
        >
            Für welche Gebäude ist eine Wärmepumpe geeignet?
        </h2>
        <p class="text-text leading-relaxed font-medium mb-6">
            Die kurze Antwort: Für deutlich mehr Häuser, als viele Eigentümer
            denken.
        </p>
        <p class="text-text-muted leading-relaxed mb-6 max-w-2xl">
            Eine Wärmepumpe funktioniert besonders effizient, wenn sie mit
            möglichst niedrigen Vorlauftemperaturen arbeiten kann. Das ist ideal
            bei:
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 mb-10">
            <div>
                <p
                    class="font-semibold text-text text-sm mb-3 uppercase tracking-wide"
                >
                    Optimale Ausgangsbedingungen
                </p>
                <ul class="space-y-2">
                    {
                        [
                            "Fußbodenheizungen",
                            "Groß dimensionierten Heizkörpern",
                            "Gut gedämmten Gebäuden",
                            "Modernisierten Fenstern und Gebäudehüllen",
                        ].map((item) => (
                            <li class="flex items-start gap-2 text-text-muted text-sm leading-relaxed">
                                <span class="text-primary shrink-0 mt-0.5">
                                    →
                                </span>
                                {item}
                            </li>
                        ))
                    }
                </ul>
            </div>
            <div>
                <p
                    class="font-semibold text-text text-sm mb-3 uppercase tracking-wide"
                >
                    Typische gute Voraussetzungen
                </p>
                <ul class="space-y-2">
                    {
                        [
                            "Bereits durchgeführte Sanierungen an Dach, Fassade oder Fenstern",
                            "Niedriger bis mittlerer Wärmebedarf",
                            "Ausreichend Platz für Innen- oder Außeneinheit",
                            "Moderne Heizkörper oder Flächenheizung",
                            "Bereitschaft zur ganzheitlichen Heizungsmodernisierung",
                        ].map((item) => (
                            <li class="flex items-start gap-2 text-text-muted text-sm leading-relaxed">
                                <span class="text-primary shrink-0 mt-0.5">
                                    →
                                </span>
                                {item}
                            </li>
                        ))
                    }
                </ul>
            </div>
        </div>
        <p class="text-text-muted leading-relaxed max-w-2xl text-sm">
            Doch auch in älteren Häusern kann eine Wärmepumpe wirtschaftlich
            betrieben werden. Wer eine <strong
                >Wärmepumpe in Bremen nachrüsten</strong
            > möchte, sollte das Gebäude individuell prüfen lassen. Gerade typische
            <strong>Bremer Reihenhäuser</strong>, Doppelhaushälften und
            klassische Altbauten haben oft mehr Potenzial als zunächst vermutet.
        </p>
    </SectionShell>

    <!-- Altbau nachrüsten -->
    <SectionShell variant="alt">
        <h2
            class="text-2xl md:text-3xl font-bold tracking-tight text-text mb-6"
        >
            Wärmepumpe nachrüsten in Bremen: Was im Altbau wichtig ist
        </h2>
        <p class="text-text-muted leading-relaxed mb-4 max-w-2xl">
            Viele Eigentümer fragen sich, ob sich eine Wärmepumpe im Altbau
            überhaupt lohnt. Die Antwort lautet: oft ja – wenn die Planung
            stimmt.
        </p>
        <p class="text-text-muted leading-relaxed mb-2 text-sm">
            In Bremen gibt es zahlreiche ältere Wohnhäuser mit unterschiedlichem
            energetischem Zustand. Dazu gehören:
        </p>
        <ul
            class="list-disc list-inside space-y-1 mb-8 text-text-muted text-sm"
        >
            <li>Klassische Bremer Reihenhäuser</li>
            <li>Einfamilienhäuser aus den 50er bis 80er Jahren</li>
            <li>Teilmodernisierte Altbauten</li>
            <li>Bestandsimmobilien mit begrenztem Platzangebot</li>
        </ul>
        <p class="font-semibold text-text mb-6">
            Diese Punkte sollten vorab geprüft werden:
        </p>
        <div class="space-y-5 max-w-2xl">
            {
                [
                    {
                        title: "Heizlast des Gebäudes",
                        text: "Wie viel Wärme braucht das Haus tatsächlich? Eine seriöse Planung beginnt nicht mit dem Gerät, sondern mit dem Bedarf.",
                    },
                    {
                        title: "Vorlauftemperatur",
                        text: "Je niedriger die benötigte Heiztemperatur, desto effizienter arbeitet die Wärmepumpe.",
                    },
                    {
                        title: "Zustand der Gebäudehülle",
                        text: "Gedämmte Dächer, moderne Fenster und reduzierte Wärmeverluste verbessern die Wirtschaftlichkeit deutlich.",
                    },
                    {
                        title: "Heizkörper und Flächenheizung",
                        text: "Nicht immer ist sofort eine Fußbodenheizung nötig. Häufig reichen größere oder modernere Heizkörper bereits aus.",
                    },
                    {
                        title: "Platz und Schallschutz",
                        text: "In dichter bebauten Wohnlagen ist die Positionierung der Außeneinheit besonders wichtig.",
                    },
                ].map((block) => (
                    <div class="border-l-4 border-primary pl-5">
                        <h3 class="font-semibold text-text mb-1">
                            {block.title}
                        </h3>
                        <p class="text-text-muted text-sm leading-relaxed">
                            {block.text}
                        </p>
                    </div>
                ))
            }
        </div>
        <p
            class="mt-8 text-sm text-text-muted leading-relaxed italic max-w-2xl"
        >
            Wichtig: Eine Wärmepumpe ist kein Standardprodukt von der Stange.
            Wer im Bestand modernisiert, sollte mit einem erfahrenen
            Heizungsbauer in Bremen zusammenarbeiten, der sowohl Technik als
            auch Gebäudesituation realistisch beurteilt.
        </p>
    </SectionShell>

    <!-- Welche Wärmepumpe -->
    <SectionShell>
        <h2
            class="text-2xl md:text-3xl font-bold tracking-tight text-text mb-6"
        >
            Welche Wärmepumpe ist sinnvoll?
        </h2>
        <p class="text-text-muted leading-relaxed mb-10 max-w-2xl">
            Nicht jede Wärmequelle passt zu jedem Grundstück. Welche Lösung
            sinnvoll ist, hängt von Gebäude, Budget, Platz und
            Genehmigungssituation ab.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Luft-Wasser -->
            <div class="surface-card p-6 flex flex-col">
                <h3 class="font-bold text-text text-lg mb-2">
                    Luft-Wasser-Wärmepumpe
                </h3>
                <p class="text-text-muted text-sm leading-relaxed mb-6">
                    Die <strong>Luft-Wasser-Wärmepumpe</strong> ist meist die erste
                    Wahl. Sie nutzt die Außenluft als Energiequelle und ist vergleichsweise
                    flexibel planbar.
                </p>
                <div class="mt-auto space-y-5">
                    <div>
                        <p
                            class="text-xs font-semibold text-primary uppercase tracking-wide mb-2"
                        >
                            Vorteile
                        </p>
                        <ul class="space-y-1.5">
                            {
                                [
                                    "Meist geringerer Installationsaufwand",
                                    "Ideal für viele Bestandsgebäude",
                                    "Kein großer Eingriff ins Grundstück nötig",
                                    "Gute Lösung für Reihenhäuser und kleinere Grundstücke",
                                    "Vergleichsweise schnelle Nachrüstung möglich",
                                ].map((v) => (
                                    <li class="flex items-start gap-2 text-text-muted text-xs leading-relaxed">
                                        <span class="text-primary shrink-0 font-bold">
                                            ✓
                                        </span>
                                        {v}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <div>
                        <p
                            class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-2"
                        >
                            Zu beachten
                        </p>
                        <ul class="space-y-1.5">
                            {
                                [
                                    "Außengerät muss sinnvoll platziert werden",
                                    "Schallschutz und Nachbarschaftssituation sind wichtig",
                                    "Effizienz hängt stark von der Auslegung ab",
                                ].map((v) => (
                                    <li class="flex items-start gap-2 text-text-muted text-xs leading-relaxed">
                                        <span class="shrink-0">!</span>
                                        {v}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Sole-Wasser -->
            <div class="surface-card p-6 flex flex-col">
                <h3 class="font-bold text-text text-lg mb-2">
                    Sole-Wasser-Wärmepumpe
                </h3>
                <p class="text-text-muted text-sm leading-relaxed mb-6">
                    Diese Systeme gewinnen Wärme aus dem Erdreich und arbeiten
                    sehr effizient. Sie kommen vor allem infrage, wenn
                    ausreichend Grundstücksfläche vorhanden ist oder geologische
                    Voraussetzungen passen.
                </p>
                <div class="mt-auto space-y-5">
                    <div>
                        <p
                            class="text-xs font-semibold text-primary uppercase tracking-wide mb-2"
                        >
                            Vorteile
                        </p>
                        <ul class="space-y-1.5">
                            {
                                [
                                    "Sehr gute Effizienz",
                                    "Konstante Wärmequelle",
                                    "Niedrige Betriebskosten bei guter Planung",
                                ].map((v) => (
                                    <li class="flex items-start gap-2 text-text-muted text-xs leading-relaxed">
                                        <span class="text-primary shrink-0 font-bold">
                                            ✓
                                        </span>
                                        {v}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <div>
                        <p
                            class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-2"
                        >
                            Zu beachten
                        </p>
                        <ul class="space-y-1.5">
                            {
                                [
                                    "Höherer Planungs- und Installationsaufwand",
                                    "Nicht auf jedem Grundstück realisierbar",
                                    "Oft höhere Anfangsinvestition",
                                ].map((v) => (
                                    <li class="flex items-start gap-2 text-text-muted text-xs leading-relaxed">
                                        <span class="shrink-0">!</span>
                                        {v}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Grundwasser -->
            <div class="surface-card p-6 flex flex-col">
                <h3 class="font-bold text-text text-lg mb-2">
                    Grundwasser-Wärmepumpe
                </h3>
                <p class="text-text-muted text-sm leading-relaxed mb-6">
                    Eine technisch interessante, aber in der Praxis oft
                    anspruchsvollere Lösung. Sie bietet hohe Effizienz, ist
                    jedoch stark von den örtlichen Gegebenheiten abhängig.
                </p>
                <div class="mt-auto space-y-5">
                    <div>
                        <p
                            class="text-xs font-semibold text-primary uppercase tracking-wide mb-2"
                        >
                            Vorteile
                        </p>
                        <ul class="space-y-1.5">
                            {
                                [
                                    "Sehr effiziente Wärmequelle",
                                    "Niedrige Betriebskosten möglich",
                                ].map((v) => (
                                    <li class="flex items-start gap-2 text-text-muted text-xs leading-relaxed">
                                        <span class="text-primary shrink-0 font-bold">
                                            ✓
                                        </span>
                                        {v}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <div>
                        <p
                            class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-2"
                        >
                            Zu beachten
                        </p>
                        <ul class="space-y-1.5">
                            {
                                [
                                    "Genehmigungsabhängig",
                                    "Aufwendigere Planung",
                                    "Nicht für jedes Grundstück geeignet",
                                ].map((v) => (
                                    <li class="flex items-start gap-2 text-text-muted text-xs leading-relaxed">
                                        <span class="shrink-0">!</span>
                                        {v}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>
            </div>
