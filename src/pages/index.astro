                                            ✓
                                        </span>
                                        {v}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                    <div>
                        <p
                            class="text-xs font-semibold text-text-muted uppercase tracking-wide mb-2"
                        >
                            Zu beachten
                        </p>
                        <ul class="space-y-1.5">
                            {
                                [
                                    "Höherer Planungs- und Installationsaufwand",
                                    "Nicht auf jedem Grundstück realisierbar",
                                    "Oft höhere Anfangsinvestition",
                                ].map((v) => (
                                    <li class="flex items-start gap-2 text-text-muted text-xs leading-relaxed">
                                        <span class="shrink-0">!</span>
                                        {v}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Grundwasser -->
            <div class="surface-card p-6 flex flex-col">
                <h3 class="font-bold text-text text-lg mb-2">
                    Grundwasser-Wärmepumpe
                </h3>
                <p class="text-text-muted text-sm leading-relaxed mb-6">
                    Eine technisch interessante, aber in der Praxis oft
                    anspruchsvollere Lösung. Sie bietet hohe Effizienz, ist
                    jedoch stark von den örtlichen Gegebenheiten abhängig.
                </p>
                <div class="mt-auto space-y-5">
