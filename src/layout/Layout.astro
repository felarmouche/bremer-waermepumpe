---
import Head from "../components/Head.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface PageSchema {
    type?: "Article" | "HowTo";
    datePublished?: string;
    dateModified?: string;
    howToName?: string;
    howToDescription?: string;
    howToSteps?: { name: string; text: string }[];
}

interface Props {
    title: string;
    description: string;
    canonical?: string;
    ogImage?: string;
    noindex?: boolean;
    pageSchema?: PageSchema;
}
const { title, description, canonical, ogImage, noindex, pageSchema } = Astro.props;
---

<!doctype html>
<html lang="de">
    <head>
        <Head title={title} description={description} canonical={canonical} ogImage={ogImage} noindex={noindex} pageSchema={pageSchema} />
    </head>
    <body class="bg-background text-text min-h-screen flex flex-col">
        <header class="bg-white sticky top-0 z-50 border-b border-border">
            <NavBar />
        </header>
        <main class="flex-1">
            <slot />
        </main>
        <Footer />
    </body>
</html>
