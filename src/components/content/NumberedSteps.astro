---
interface Step {
    title: string;
    text: string;
}

interface Props {
    items: Step[];
    numbered?: boolean;
    class?: string;
}
const { items, numbered = true, class: className = "" } = Astro.props;
---

<div class:list={["space-y-4 max-w-3xl", className]}>
    {
        items.map((item, i) => (
            <div class="border-l-4 border-primary pl-5 py-2">
                <h3 class="font-semibold text-text mb-2">
                    {numbered ? `${i + 1}. ${item.title}` : item.title}
                </h3>
                <p class="text-text-muted text-sm leading-relaxed">
                    {item.text}
                </p>
            </div>
        ))
    }
</div>
