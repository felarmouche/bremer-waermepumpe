---
interface Props {
    heading?: string;
    steps: { number: number; title: string; description: string }[];
}
const { heading = "So läuft der Prozess ab", steps } = Astro.props;
---

<section class="bg-surface-alt py-16 md:py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-text mb-12 lg:mb-16">{heading}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {steps.map((step) => (
                <div class="surface-card p-6">
                    <span class="text-3xl font-bold text-primary">{step.number}</span>
                    <h3 class="font-semibold text-text mt-2">{step.title}</h3>
                    <p class="text-text-muted text-sm mt-2">{step.description}</p>
                </div>
            ))}
        </div>
    </div>
</section>
