---
import { render, type CollectionEntry } from "astro:content";
import Layout from "../layout/Layout.astro";
import Breadcrumb from "./Breadcrumb.astro";
import HeroSection from "./HeroSection.astro";
import TrustBar from "./TrustBar.astro";
import CTASection from "./CTASection.astro";
import FAQSection from "./FAQSection.astro";

interface Props {
    entry: CollectionEntry<"pages">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const canonical = d.canonical ?? Astro.url.href;

const dateLine = d.lastUpdated
    ? `Stand: ${d.lastUpdated}`
    : null;

const pageSchema = d.schema
    ? {
          ...d.schema,
          datePublished: d.schema.datePublished ?? d.schema.dateModified,
          dateModified: d.schema.dateModified ?? d.schema.datePublished,
      }
    : undefined;
---

<Layout
    title={d.title}
    description={d.description}
    canonical={canonical}
    noindex={d.noindex}
    pageSchema={pageSchema}
>
    {d.breadcrumb.length > 0 && <Breadcrumb items={d.breadcrumb} />}
    <HeroSection {...d.hero} />
    {d.trustItems.length > 0 && <TrustBar items={d.trustItems} />}
    {dateLine && (
        <div class="bg-background border-b border-border">
            <p class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-xs text-text-muted">
                {dateLine} · Redaktion bremer-waermepumpe.de · Alle Angaben ohne Gewähr
            </p>
        </div>
    )}
    <Content />
    {d.ctaBlock && <CTASection {...d.ctaBlock} />}
    {
        d.faqs.length > 0 && (
            <FAQSection heading={d.faqHeading} items={d.faqs} />
        )
    }
</Layout>
