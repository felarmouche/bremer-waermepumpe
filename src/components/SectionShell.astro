---
interface Props {
    variant?: "default" | "alt" | "highlight";
    class?: string;
    id?:string;
}
const { variant = "default", class: className = "", id = "" } = Astro.props;

const bgClass = {
    default: "bg-background",
    alt: "bg-surface-alt",
    highlight: "bg-highlight",
}[variant];
---

<section id={id} class:list={["py-12 md:py-20 lg:py-24", bgClass, className]}>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <slot />
    </div>
</section>
