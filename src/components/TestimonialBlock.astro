---
interface Props {
    heading?: string;
    items: { quote: string; author: string; location?: string }[];
}
const { heading = "Das sagen Eigentümer aus Bremen", items } = Astro.props;
---

<section class="bg-background py-16 md:py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-text mb-10 lg:mb-14">{heading}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
            {items.map((item) => (
                <div class="surface-card p-6">
                    <p class="text-text-muted italic leading-relaxed">&bdquo;{item.quote}&ldquo;</p>
                    <div class="mt-4">
                        <p class="font-semibold text-sm text-text">{item.author}</p>
                        {item.location && (
                            <p class="text-text-muted text-sm">{item.location}</p>
                        )}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
