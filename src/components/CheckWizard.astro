---
/*
  CheckWizard – 4-Schritt-Assistent für Eignungs- und Fördercheck.
  Alle Eingaben werden ausschließlich clientseitig verarbeitet.
  Es werden keine Daten an den Server übermittelt, gespeichert
  oder per E-Mail versendet. Siehe /datenschutz/ §7.
*/
---

<section
  id="check-wizard"
  class="bg-background py-12 md:py-20"
  aria-label="Wärmepumpen-Check"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="surface-card p-6 md:p-10" data-check-wizard>
      <div class="mb-8">
        <div
          class="flex items-center justify-between mb-3 text-xs text-text-muted"
        >
          <span data-step-label>Schritt 1 von 3</span>
          <span data-step-meta>Gebäude</span>
        </div>
        <div
          class="h-2 w-full bg-surface-alt rounded-full overflow-hidden border border-border"
        >
          <div
            class="h-full bg-primary transition-[width] duration-300"
            style="width: 33%"
            data-progress-bar
          >
          </div>
        </div>
      </div>

      <form data-check-form novalidate>
        <fieldset data-step="1" class="space-y-6">
          <legend class="text-xl md:text-2xl font-bold text-text mb-2">
            Ihr Gebäude in Bremen
          </legend>
          <p class="text-sm text-text-muted mb-6">
            Mit diesen Angaben starten wir die erste Einordnung.
          </p>

          <div>
            <label
              class="block font-semibold text-sm text-text mb-1"
              for="cw-plz"
            >
              Postleitzahl<span class="text-accent ml-1">*</span>
            </label>
            <input
              id="cw-plz"
              type="text"
              name="plz"
              inputmode="numeric"
              pattern="[0-9]{5}"
              placeholder="z.B. 28195"
              class="input-base"
              required
              data-field
            />
            <p class="text-xs text-text-muted mt-1">
              Nur 5-stellige PLZ. Wird nicht übertragen.
            </p>
          </div>

          <div>
            <span class="block font-semibold text-sm text-text mb-2">
              Gebäudetyp<span class="text-accent ml-1">*</span>
            </span>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="gebaeudetyp"
                  value="einfamilienhaus"
                  required
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">Einfamilienhaus</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="gebaeudetyp"
                  value="reihenhaus"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">Reihenhaus</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="gebaeudetyp"
                  value="doppelhaushaelfte"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">Doppelhaushälfte</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="gebaeudetyp"
                  value="mehrfamilienhaus"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">Mehrfamilienhaus</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong sm:col-span-2"
              >
                <input
                  type="radio"
                  name="gebaeudetyp"
                  value="sonstiges"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">Sonstiges</span>
              </label>
            </div>
          </div>

          <div>
            <span class="block font-semibold text-sm text-text mb-2">
              Baujahr<span class="text-accent ml-1">*</span>
            </span>
            <div class="grid grid-cols-2 gap-2">
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="baujahr"
                  value="vor1977"
                  required
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">vor 1977</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="baujahr"
                  value="1977_1995"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">1977 – 1995</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="baujahr"
                  value="1996_2020"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">1996 – 2020</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="baujahr"
                  value="nach2020"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">nach 2020</span>
              </label>
            </div>
          </div>

          <div>
            <span class="block font-semibold text-sm text-text mb-2">
              Wohnfläche<span class="text-accent ml-1">*</span>
            </span>
            <div class="grid grid-cols-2 gap-2">
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="flaeche"
                  value="bis100"
                  required
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">bis 100 m²</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="flaeche"
                  value="100_150"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">100 – 150 m²</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="flaeche"
                  value="150_220"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">150 – 220 m²</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="flaeche"
                  value="ueber220"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">über 220 m²</span>
              </label>
            </div>
          </div>
        </fieldset>

        <fieldset data-step="2" class="space-y-6 hidden">
          <legend class="text-xl md:text-2xl font-bold text-text mb-2">
            Heizung &amp; Technik
          </legend>
          <p class="text-sm text-text-muted mb-6">
            Die aktuelle Heizung bestimmt, wie Umstieg und Förderung aussehen
            können.
          </p>

          <div>
            <label
              class="block font-semibold text-sm text-text mb-1"
              for="cw-heizung"
            >
              Aktuelle Heizung<span class="text-accent ml-1">*</span>
            </label>
            <select
              id="cw-heizung"
              name="heizung"
              class="input-base"
              required
              data-field
            >
              <option value="" disabled selected>Bitte wählen</option>
              <option value="oel">Ölheizung</option>
              <option value="gas">Gasheizung</option>
              <option value="gasetage">Gas-Etagenheizung</option>
              <option value="fernwaerme">Fernwärme</option>
              <option value="nachtspeicher">Nachtspeicher / Strom</option>
              <option value="biomasse">Biomasseheizung (Holz/Pellets)</option>
              <option value="kohle">Kohleheizung</option>
              <option value="waermepumpe">bereits Wärmepumpe</option>
              <option value="andere">andere / unbekannt</option>
            </select>
          </div>

          <div>
            <span class="block font-semibold text-sm text-text mb-2">
              Alter der Heizung<span class="text-accent ml-1">*</span>
            </span>
            <div class="grid grid-cols-2 gap-2">
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="heizungsalter"
                  value="u5"
                  required
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">unter 5 Jahre</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="heizungsalter"
                  value="5_15"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">5 – 15 Jahre</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="heizungsalter"
                  value="15_20"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">15 – 20 Jahre</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="heizungsalter"
                  value="20_25"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">20 – 25 Jahre</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="heizungsalter"
                  value="ueber25"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">über 25 Jahre</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="heizungsalter"
                  value="unbekannt"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">unbekannt</span>
              </label>
            </div>
          </div>

          <div>
            <span class="block font-semibold text-sm text-text mb-2">
              Wärmeabgabe im Haus<span class="text-accent ml-1">*</span>
            </span>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="waermeabgabe"
                  value="heizkoerper"
                  required
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">nur Heizkörper</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="waermeabgabe"
                  value="gemischt"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">gemischt</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="waermeabgabe"
                  value="fbh"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">nur Fußbodenheizung</span>
              </label>
            </div>
          </div>

          <div>
            <span class="block font-semibold text-sm text-text mb-2">
              Dämmstandard<span class="text-accent ml-1">*</span>
            </span>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="daemmung"
                  value="unsaniert"
                  required
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">unsaniert</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="daemmung"
                  value="teilsaniert"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">teilsaniert</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="daemmung"
                  value="saniert"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">saniert</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="daemmung"
                  value="neubau"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">Neubaustandard</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong sm:col-span-2"
              >
                <input
                  type="radio"
                  name="daemmung"
                  value="unsicher"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">unsicher</span>
              </label>
            </div>
          </div>
        </fieldset>

        <fieldset data-step="3" class="space-y-6 hidden">
          <legend class="text-xl md:text-2xl font-bold text-text mb-2">
            Eigentum &amp; Förderung
          </legend>
          <p class="text-sm text-text-muted mb-6">
            Diese Angaben entscheiden, welche KfW-Bausteine möglich sind.
          </p>

          <div>
            <span class="block font-semibold text-sm text-text mb-2">
              Eigentumsstatus<span class="text-accent ml-1">*</span>
            </span>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="eigentum"
                  value="selbstgenutzt"
                  required
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">Eigentümer, selbstgenutzt</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="eigentum"
                  value="vermietet"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">Eigentümer, vermietet</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="eigentum"
                  value="weg"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">Miteigentum / WEG</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="eigentum"
                  value="mieter"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">Mieter</span>
              </label>
            </div>
          </div>

          <div>
            <span class="block font-semibold text-sm text-text mb-2">
              Haushaltsjahreseinkommen
            </span>
            <p class="text-xs text-text-muted mb-2">
              Nur für den KfW-Einkommensbonus. Angabe freiwillig, wird nicht
              übertragen.
            </p>
            <div class="grid grid-cols-2 gap-2">
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="einkommen"
                  value="bis40"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">bis 40.000 €</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="einkommen"
                  value="40_90"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">40.000 – 90.000 €</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="einkommen"
                  value="ueber90"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">über 90.000 €</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="einkommen"
                  value="keine"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">keine Angabe</span>
              </label>
            </div>
          </div>

          <div>
            <span class="block font-semibold text-sm text-text mb-2">
              Bereits Förderantrag gestellt?<span class="text-accent ml-1"
                >*</span
              >
            </span>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="antrag"
                  value="ja"
                  required
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">ja</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="antrag"
                  value="planung"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">in Planung</span>
              </label>
              <label
                class="flex items-center gap-2 border border-border rounded-md px-3 py-2 cursor-pointer hover:border-border-strong"
              >
                <input
                  type="radio"
                  name="antrag"
                  value="nein"
                  data-field
                  class="accent-primary"
                />
                <span class="text-sm">nein</span>
              </label>
            </div>
          </div>
        </fieldset>

        <div
          class="flex flex-col sm:flex-row justify-between gap-3 mt-10"
          data-step-nav
        >
          <button
            type="button"
            class="btn-secondary w-full sm:w-auto hidden"
            data-back-btn
          >
            Zurück
          </button>
          <button
            type="button"
            class="btn-accent w-full sm:w-auto sm:ml-auto"
            data-next-btn
          >
            Weiter
          </button>
          <button
            type="button"
            class="btn-accent w-full sm:w-auto sm:ml-auto hidden"
            data-submit-btn
          >
            Einschätzung anzeigen
          </button>
        </div>

        <p class="text-xs text-text-muted mt-6 text-center" data-hint>
          Ihre Eingaben verlassen niemals diesen Browser. Keine Anmeldung, keine
          E-Mail.
        </p>
      </form>

      <div data-result-panel class="hidden mt-8">
        <div class="border-t border-border pt-8">
          <h2 class="text-2xl md:text-3xl font-bold text-text mb-6">
            Ihre Einschätzung
          </h2>

          <div class="space-y-6">
            <div class="border border-border rounded-lg p-5 bg-surface">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs uppercase tracking-wide text-text-muted"
                  >Eignung</span
                >
                <span
                  data-eignung-badge
                  class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold"
                ></span>
              </div>
              <p data-eignung-text class="text-text leading-relaxed"></p>
            </div>

            <div class="border border-border rounded-lg p-5 bg-surface">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs uppercase tracking-wide text-text-muted"
                  >Förderung</span
                >
                <span
                  data-foerder-badge
                  class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold"
                ></span>
              </div>
              <p data-foerder-text class="text-text leading-relaxed mb-4"></p>
              <ul data-foerder-list class="space-y-2 text-sm"></ul>
              <p
                data-bestand-hinweis
                class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-md p-3 mt-4 hidden"
              >
              </p>
              <p class="text-xs text-text-muted mt-4">
                Maximal förderfähige Kosten April 2026: 30.000 € für ein
                Einfamilienhaus. Prozentsätze sind Obergrenzen; die tatsächliche
                Förderhöhe wird im Antrag festgestellt.
              </p>
            </div>

            <div
              data-kosten-block
              class="border border-border rounded-lg p-5 bg-surface"
            >
              <h3 class="text-sm font-semibold text-text mb-2">
                Orientierende Kostenlage (Stand 2026)
              </h3>
              <p class="text-sm text-text leading-relaxed mb-2">
                Typische Gesamtkosten vor Förderung: <strong
                  >25.000–50.000 €</strong
                >.
              </p>
              <p class="text-sm text-text-muted leading-relaxed mb-3">
                Beispiel Reihenhaus teilsaniert: 25.000–32.000 € Anschaffung,
                15.000–22.400 € Förderung, Eigenanteil ≈ 10.000–14.000 €.
              </p>
              <a
                href="/waermepumpe-kosten-foerderung/"
                class="text-sm text-primary hover:underline font-medium"
              >
                → Detaillierte Kosten- und Förderübersicht
              </a>
              <p class="text-xs text-text-muted mt-2">
                Keine individuelle Schätzung – die tatsächlichen Kosten hängen
                von Gebäude, Auslegung und Wunschsystem ab.
              </p>
            </div>

            <div class="notice-success">
              <p class="font-semibold text-text mb-2">Empfehlung</p>
              <p data-empfehlung-text class="text-sm leading-relaxed"></p>
            </div>

            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href="/waermepumpe-kosten-foerderung/"
                class="btn-secondary w-full sm:w-auto text-center"
              >
                Mehr zur Förderung
              </a>
              <a
                href="/waermepumpe-altbau-bremen/"
                class="btn-secondary w-full sm:w-auto text-center"
              >
                Altbau-Themen
              </a>
              <button
                type="button"
                class="btn-secondary w-full sm:w-auto"
                data-restart-btn
              >
                Check neu starten
              </button>
            </div>

            <p class="text-xs text-text-muted leading-relaxed">
              Automatisierte Orientierung auf Basis öffentlich verfügbarer
              Förderregeln (BEG Einzelmaßnahmen / KfW 458, Stand April 2026).
              Keine Rechts-, Steuer- oder Energieberatung. Eine belastbare
              Aussage liefert nur die Prüfung durch einen zugelassenen
              Fachbetrieb oder eine anerkannte Energieberatung.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var root = document.querySelector("[data-check-wizard]");
    if (!root) return;

    var form = root.querySelector("[data-check-form]");
    var steps = Array.from(root.querySelectorAll("[data-step]"));
    var backBtn = root.querySelector("[data-back-btn]");
    var nextBtn = root.querySelector("[data-next-btn]");
    var submitBtn = root.querySelector("[data-submit-btn]");
    var stepLabel = root.querySelector("[data-step-label]");
    var stepMeta = root.querySelector("[data-step-meta]");
    var progressBar = root.querySelector("[data-progress-bar]");
    var stepNav = root.querySelector("[data-step-nav]");
    var hint = root.querySelector("[data-hint]");
    var resultPanel = root.querySelector("[data-result-panel]");
    var restartBtn = root.querySelector("[data-restart-btn]");

    var stepMetaMap = ["Gebäude", "Heizung & Technik", "Eigentum & Förderung"];
    var current = 0;
    var total = steps.length;
    var started = false;

    function track(eventName, props) {
      if (typeof window.plausible === "function") {
        try {
          window.plausible(eventName, props ? { props: props } : undefined);
        } catch (e) {}
      }
    }

    function showStep(idx) {
      steps.forEach(function (s, i) {
        s.classList.toggle("hidden", i !== idx);
      });
      backBtn.classList.toggle("hidden", idx === 0);
      var isLast = idx === total - 1;
      nextBtn.classList.toggle("hidden", isLast);
      submitBtn.classList.toggle("hidden", !isLast);
      stepLabel.textContent = "Schritt " + (idx + 1) + " von " + total;
      stepMeta.textContent = stepMetaMap[idx] || "";
      var pct = Math.round(((idx + 1) / total) * 100);
      progressBar.style.width = pct + "%";

      if (!started) {
        started = true;
        track("check_started");
      }
    }

    function validateStep(idx) {
      var step = steps[idx];
      var fields = step.querySelectorAll("[data-field][required]");
      var ok = true;
      for (var i = 0; i < fields.length; i++) {
        var f = fields[i];
        if (f.type === "radio") {
          var groupName = f.name;
          var anyChecked = step.querySelector(
            'input[name="' + groupName + '"]:checked',
          );
          if (!anyChecked) {
            ok = false;
            break;
          }
        } else if (
          !f.value ||
          (f.pattern && !new RegExp("^" + f.pattern + "$").test(f.value))
        ) {
          ok = false;
          break;
        }
      }
      if (!ok) {
        step.classList.add("ring-2", "ring-accent", "rounded-md", "p-2");
        setTimeout(function () {
          step.classList.remove("ring-2", "ring-accent", "rounded-md", "p-2");
        }, 1200);
      }
      return ok;
    }

    function collect() {
      var fd = new FormData(form);
      return {
        plz: String(fd.get("plz") || ""),
        gebaeudetyp: String(fd.get("gebaeudetyp") || ""),
        baujahr: String(fd.get("baujahr") || ""),
        flaeche: String(fd.get("flaeche") || ""),
        heizung: String(fd.get("heizung") || ""),
        heizungsalter: String(fd.get("heizungsalter") || ""),
        waermeabgabe: String(fd.get("waermeabgabe") || ""),
        daemmung: String(fd.get("daemmung") || ""),
        eigentum: String(fd.get("eigentum") || ""),
        einkommen: String(fd.get("einkommen") || ""),
        antrag: String(fd.get("antrag") || ""),
      };
    }

    function scoreEignung(d) {
      var baujahr =
        { vor1977: 0, "1977_1995": 10, "1996_2020": 18, nach2020: 22 }[
          d.baujahr
        ] || 0;
      var waerme =
        { heizkoerper: 10, gemischt: 25, fbh: 35 }[d.waermeabgabe] || 0;
      var daemm =
        { unsaniert: 0, teilsaniert: 18, saniert: 30, neubau: 35, unsicher: 8 }[
          d.daemmung
        ] || 0;
      var typBonus =
        ["einfamilienhaus", "reihenhaus", "doppelhaushaelfte"].indexOf(
          d.gebaeudetyp,
        ) >= 0
          ? 5
          : 0;
      var total = baujahr + waerme + daemm + typBonus;

      var level;
      if (total >= 65) level = "hoch";
      else if (total >= 40) level = "mittel";
      else level = "niedrig";

      var text;
      if (level === "hoch") {
        text =
          "Das Gebäude bringt gute Voraussetzungen für eine Wärmepumpe mit. " +
          "Baujahr, Wärmeabgabe und Dämmstandard sprechen für einen effizienten Betrieb. " +
          "Eine Vor-Ort-Prüfung (Heizlast, Vorlauftemperatur) bestätigt die Einschätzung.";
      } else if (level === "mittel") {
        text =
          "Eine Wärmepumpe ist grundsätzlich möglich. Einzelne Punkte – etwa " +
          "Heizkörperauslegung, Dämmstandard oder Vorlauftemperatur – sollten vor der " +
          "Installation geprüft und ggf. angepasst werden.";
      } else {
        text =
          "Die Voraussetzungen sind auf den ersten Blick eingeschränkt. Das bedeutet " +
          "nicht automatisch, dass eine Wärmepumpe ausscheidet, aber es braucht eine " +
          "sorgfältige Einzelfallprüfung – insbesondere zu Vorlauftemperatur, Heizkörpern " +
          "und Dämmung.";
      }
      return { score: total, level: level, text: text };
    }

    function scoreFoerderung(d, eignungLevel) {
      var bausteine = [];
      var mieter = d.eigentum === "mieter";
      var vermietet = d.eigentum === "vermietet";
      var weg = d.eigentum === "weg";
      var selbst = d.eigentum === "selbstgenutzt";
      var istBestandsgebaeude = d.baujahr !== "nach2020";

      if (mieter) {
        return {
          level: "nicht_anwendbar",
          text:
            "Als Mieter sind Sie nicht antragsberechtigt. Der Förderantrag muss vom " +
            "Eigentümer bzw. der Eigentümergemeinschaft gestellt werden.",
          bausteine: [],
          summe: 0,
          bestandsWarnung: false,
        };
      }

      // Heizungstypen, die keinen Heizungstausch fördern
      if (d.heizung === "waermepumpe") {
        return {
          level: "nicht_anwendbar",
          text:
            "Sie betreiben bereits eine Wärmepumpe. Ein Heizungstausch Wärmepumpe → Wärmepumpe ist über KfW 458 in der Regel nicht förderfähig. " +
            "Für Effizienzmaßnahmen an der bestehenden Anlage kommt ggf. die BAFA-Heizungsoptimierung in Frage.",
          bausteine: [],
          summe: 0,
          bestandsWarnung: false,
        };
      }

      if (d.heizung === "fernwaerme") {
        return {
          level: "nicht_anwendbar",
          text: "Fernwärme-Anschlüsse haben eigene Förderwege. Ein reiner Heizungstausch von Fernwärme auf Wärmepumpe ist über KfW 458 in der Regel nicht förderfähig.",
          bausteine: [],
          summe: 0,
          bestandsWarnung: false,
        };
      }

      if (selbst || weg) {
        bausteine.push({
          name: "Grundförderung KfW 458",
          pct: 30,
          hinweis: "Basis-Zuschuss für den Heizungstausch",
          anwendbar: istBestandsgebaeude,
        });
      } else if (vermietet) {
        bausteine.push({
          name: "Grundförderung KfW 458 (vermietet)",
          pct: 30,
          hinweis: "Auch für vermieteten Wohnraum",
          anwendbar: istBestandsgebaeude,
        });
      }

      // Klimageschwindigkeits-Bonus
      var immerBonus =
        ["oel", "kohle", "gasetage", "nachtspeicher"].indexOf(d.heizung) >= 0;
      var ab20Jahre =
        ["gas", "biomasse"].indexOf(d.heizung) >= 0 &&
        ["20_25", "ueber25"].indexOf(d.heizungsalter) >= 0;

      if ((immerBonus || ab20Jahre) && (selbst || weg || vermietet)) {
        bausteine.push({
          name: "Klimageschwindigkeits-Bonus",
          pct: 20,
          hinweis: "Für den Austausch einer funktionierenden alten Heizung",
        });
      }

      // Einkommens-Bonus
      if (selbst && d.einkommen === "bis40") {
        bausteine.push({
          name: "Einkommens-Bonus",
          pct: 30,
          hinweis:
            "Für selbstnutzende Eigentümer mit Haushaltseinkommen bis 40.000 €",
        });
      } else if (selbst && (d.einkommen === "" || d.einkommen === "keine")) {
        // Informativer Baustein, wird nicht zur Summe addiert
        bausteine.push({
          name: "ggf. Einkommens-Bonus",
          pct: 30,
          hinweis:
            "Falls Haushaltseinkommen ≤ 40.000 €: zusätzlich 30 % Bonus möglich.",
          informativ: true,
        });
      }

      // Effizienz-Bonus
      bausteine.push({
        name: "Effizienz-Bonus",
        pct: 5,
        hinweis:
          "Gilt für Wärmepumpen mit natürlichem Kältemittel (z. B. R290) oder Erdreich-/Grundwasser-/Abwasser-Wärmequelle. Im konkreten Angebot bestätigen lassen.",
      });

      // Summe berechnen (ohne informativen Bausteine)
      var summe = bausteine.reduce(function (acc, b) {
        return acc + (b.informativ ? 0 : b.pct);
      }, 0);
      summe = Math.min(summe, 70); // KfW-Deckel 2026

      var level;
      if (d.antrag === "ja") {
        level = "bereits_gestellt";
      } else if (summe >= 50) {
        level = "wahrscheinlich";
      } else if (summe >= 30) {
        level = "pruefen";
      } else {
        level = "eingeschraenkt";
      }

      var text;
      if (level === "bereits_gestellt") {
        text =
          "Sie haben bereits einen Förderantrag gestellt. Eine erneute Einreichung ist für " +
          "dasselbe Vorhaben nicht möglich. Prüfen Sie den Status beim BAFA/der KfW, " +
          "bevor ein Installationsvertrag geschlossen wird.";
      } else if (level === "wahrscheinlich") {
        text =
          "Auf Basis Ihrer Angaben sind mehrere Förderbausteine grundsätzlich anwendbar. " +
          "In Kombination ergibt sich eine hohe Förderquote – gedeckelt bei 70 % der " +
          "förderfähigen Kosten. Die verbindliche Zusage erfolgt durch die KfW.";
      } else if (level === "pruefen") {
        text =
          "Die Grundförderung kommt voraussichtlich in Frage. Zusätzliche Boni hängen " +
          "von Details ab, die im Antragsprozess belegt werden müssen.";
      } else {
        text =
          "Die möglichen Bausteine sind auf Basis Ihrer Angaben eingeschränkt. " +
          "Eine Einzelfallprüfung lohnt sich dennoch, weil sich Förderkonstellationen " +
          "laufend ändern können.";
      }

      return {
        level: level,
        text: text,
        bausteine: bausteine,
        summe: summe,
        bestandsWarnung: !istBestandsgebaeude,
      };
    }

    function buildEmpfehlung(d, eignung, foerder) {
      var parts = [];

      if (d.eigentum === "mieter") {
        return (
          "Sprechen Sie zunächst mit der Eigentümerin bzw. dem Eigentümer. " +
          "Erst dann lassen sich sinnvoll Eignung und Fördermöglichkeiten prüfen."
        );
      }

      if (d.heizung === "waermepumpe") {
        return (
          "Sie betreiben bereits eine Wärmepumpe. Prüfen Sie stattdessen, ob eine BAFA-Heizungsoptimierung " +
          "oder eine effizientere Anlagenregelung sinnvoll ist. Eine Heizlastberechnung hilft, " +
          "die Auslegung der bestehenden Anlage zu bewerten."
        );
      }

      if (d.heizung === "fernwaerme") {
        return (
          "Fernwärme-Anschlüsse haben eigene Förderwege. Eine Heizlastberechnung und " +
          "Vorlauftemperatur-Prüfung helfen, die konkrete Situation einzuschätzen. " +
          "Lassen Sie sich von einem Fachbetrieb beraten, ob ein Systemwechsel überhaupt sinnvoll ist."
        );
      }

      // Heizlastberechnung immer erwähnen
      var heizlastText =
        "Lassen Sie zunächst eine Heizlastberechnung und Vorlauftemperatur-Prüfung vor Ort machen. ";

      if (eignung.level === "hoch" && foerder.level === "wahrscheinlich") {
        parts.push(
          "Die Kombination aus guter Eignung und anwendbaren Förderbausteinen spricht für einen Wechsel. ",
        );
        parts.push(heizlastText);
        parts.push(
          "Als nächster Schritt: Fachbetrieb kontaktieren, Heizlast und Vorlauftemperatur prüfen lassen, dann Förderantrag VOR Vertragsschluss stellen.",
        );
      } else if (eignung.level === "niedrig") {
        parts.push(heizlastText);
        parts.push(
          "Das Ergebnis entscheidet, ob ein Heizkörpertausch oder eine Teilsanierung den Weg zur Wärmepumpe ebnet.",
        );
      } else {
        parts.push(heizlastText);
        parts.push(
          "Klären Sie im nächsten Schritt die offenen technischen Punkte (Vorlauftemperatur, Heizkörper, Dämmung) und stellen Sie erst danach den Förderantrag. ",
        );
        parts.push(
          "Der Antrag muss immer VOR Abschluss des Installationsvertrags eingereicht werden.",
        );
      }

      // Hinweis bei unbekanntem Alter bei gas/biomasse
      if (
        d.heizungsalter === "unbekannt" &&
        ["gas", "biomasse"].indexOf(d.heizung) >= 0
      ) {
        parts.push(
          " Alter der Heizung klären — ab 20 Jahren kommt ein Klimabonus von +20 % in Betracht.",
        );
      }

      // Hinweis bei großer Wohnfläche
      if (d.flaeche === "ueber220" && d.gebaeudetyp === "einfamilienhaus") {
        parts.push(
          " Große Wohnfläche — Heizlast und Geräteauslegung besonders sorgfältig prüfen.",
        );
      }

      // Hinweis bei kleiner unsanierter Objekte
      if (
        d.flaeche === "bis100" &&
        d.waermeabgabe === "heizkoerper" &&
        d.daemmung === "unsaniert"
      ) {
        parts.push(
          " Bei kleinen unsanierten Objekten mit reinen Heizkörpern kann der Eigenanteil anteilig höher ausfallen.",
        );
      }

      return parts.join("");
    }

    function renderResult() {
      var d = collect();
      var eignung = scoreEignung(d);
      var foerder = scoreFoerderung(d, eignung.level);
      var empfehlung = buildEmpfehlung(d, eignung, foerder);

      var eBadge = root.querySelector("[data-eignung-badge]");
      eBadge.textContent =
        eignung.level === "hoch"
          ? "Hoch"
          : eignung.level === "mittel"
            ? "Mittel"
            : "Niedrig";
      eBadge.className =
        "inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold " +
        (eignung.level === "hoch"
          ? "bg-highlight text-primary border border-border"
          : eignung.level === "mittel"
            ? "bg-surface-alt text-text border border-border-strong"
            : "bg-red-50 text-red-700 border border-red-200");
      root.querySelector("[data-eignung-text]").textContent = eignung.text;

      var fBadge = root.querySelector("[data-foerder-badge]");
      var fLabel =
        {
          wahrscheinlich: "Förderfähig",
          pruefen: "Einzelfallprüfung",
          eingeschraenkt: "Eingeschränkt",
          nicht_anwendbar: "Nicht anwendbar",
          bereits_gestellt: "Bereits gestellt",
        }[foerder.level] || "Prüfen";
      fBadge.textContent = fLabel;
      fBadge.className =
        "inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold " +
        (foerder.level === "wahrscheinlich"
          ? "bg-highlight text-primary border border-border"
          : foerder.level === "nicht_anwendbar"
            ? "bg-red-50 text-red-700 border border-red-200"
            : "bg-surface-alt text-text border border-border-strong");
      root.querySelector("[data-foerder-text]").textContent = foerder.text;

      var list = root.querySelector("[data-foerder-list]");
      list.innerHTML = "";
      if (foerder.bausteine.length === 0) {
        var li = document.createElement("li");
        li.className = "text-text-muted";
        li.textContent = "Keine Bausteine auf Basis der Angaben anwendbar.";
        list.appendChild(li);
      } else {
        foerder.bausteine.forEach(function (b) {
          var li = document.createElement("li");
          li.className = "flex items-start gap-3";
          if (b.informativ) {
            li.className +=
              " border border-dashed border-border rounded-md p-2 bg-surface-alt/50";
            li.innerHTML =
              '<span class="inline-flex items-center px-2 py-0.5 rounded bg-gray-200 text-gray-700 font-semibold text-xs min-w-14 justify-center">ggf. ' +
              b.pct +
              " %</span>" +
              '<span><span class="font-semibold text-text">' +
              b.name +
              '</span><br><span class="text-text-muted">' +
              b.hinweis +
              "</span></span>";
          } else if (b.anwendbar === false) {
            li.className +=
              " border border-dashed border-amber-300 rounded-md p-2 bg-amber-50/50";
            li.innerHTML =
              '<span class="inline-flex items-center px-2 py-0.5 rounded bg-amber-100 text-amber-800 font-semibold text-xs min-w-14 justify-center">bis ' +
              b.pct +
              " %</span>" +
              '<span><span class="font-semibold text-text">' +
              b.name +
              '</span><br><span class="text-text-muted">' +
              b.hinweis +
              " (nur bei Bestandsgebäude anwendbar)</span></span>";
          } else {
            li.innerHTML =
              '<span class="inline-flex items-center px-2 py-0.5 rounded bg-primary/10 text-primary font-semibold text-xs min-w-14 justify-center">bis ' +
              b.pct +
              " %</span>" +
              '<span><span class="font-semibold text-text">' +
              b.name +
              '</span><br><span class="text-text-muted">' +
              b.hinweis +
              "</span></span>";
          }
          list.appendChild(li);
        });
        var sumLi = document.createElement("li");
        sumLi.className =
          "flex items-start gap-3 border-t border-border pt-2 mt-2";
        sumLi.innerHTML =
          '<span class="inline-flex items-center px-2 py-0.5 rounded bg-primary text-white font-semibold text-xs min-w-14 justify-center">bis ' +
          foerder.summe +
          " %</span>" +
          '<span class="font-semibold text-text">Bandbreite gesamt (gedeckelt bei 70 %)</span>';
        list.appendChild(sumLi);
      }

      // Bestandsgebäude-Warnung
      var bestandHinweis = root.querySelector("[data-bestand-hinweis]");
      if (foerder.bestandsWarnung) {
        bestandHinweis.textContent =
          "Hinweis: Für KfW 458 muss der Bauantrag mindestens 5 Jahre zurückliegen. Bei Baujahr 2021+ bitte individuell prüfen.";
        bestandHinweis.classList.remove("hidden");
      } else {
        bestandHinweis.classList.add("hidden");
      }

      root.querySelector("[data-empfehlung-text]").textContent = empfehlung;

      track("check_completed", {
        eignung: eignung.level,
        foerderung: foerder.level,
        gebaeudetyp: d.gebaeudetyp,
        baujahr: d.baujahr,
        heizung: d.heizung,
        eigentum: d.eigentum,
        waermeabgabe: d.waermeabgabe,
        daemmung: d.daemmung,
      });
    }

    nextBtn.addEventListener("click", function () {
      if (!validateStep(current)) return;
      track("check_step_completed", { step: String(current + 1) });
      if (current < total - 1) {
        current++;
        showStep(current);
      }
    });

    backBtn.addEventListener("click", function () {
      if (current > 0) {
        current--;
        showStep(current);
      }
    });

    submitBtn.addEventListener("click", function () {
      if (!validateStep(current)) return;
      track("check_step_completed", { step: String(current + 1) });
      renderResult();
      form.classList.add("hidden");
      stepNav.classList.add("hidden");
      hint.classList.add("hidden");
      resultPanel.classList.remove("hidden");
      var header = root.querySelector(".mb-8");
      if (header) header.classList.add("hidden");
      resultPanel.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    restartBtn.addEventListener("click", function () {
      form.reset();
      current = 0;
      started = false;
      showStep(0);
      form.classList.remove("hidden");
      stepNav.classList.remove("hidden");
      hint.classList.remove("hidden");
      resultPanel.classList.add("hidden");
      var header = root.querySelector(".mb-8");
      if (header) header.classList.remove("hidden");
      root.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    showStep(0);
  })();
</script>
