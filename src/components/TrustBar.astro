---
interface Item {
    text: string;
}

interface Props {
    items: Item[];
}

const { items = [] } = Astro.props;
---

{
    items.length > 0 && (
        <section
            class="border-y border-border bg-surface-alt py-8 md:py-10"
            aria-label="Vorteile"
        >
            <ul class="mx-auto grid max-w-5xl grid-cols-1 gap-4 px-4 sm:grid-cols-2 sm:px-6 md:grid-cols-4 lg:px-8">
                {items.map((item: Item) => (
                    <li class="flex items-center md:justify-center gap-3 rounded-lg px-4 py-2 text-sm text-text-muted">
                        <span
                            class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xs font-bold text-primary"
                            aria-hidden="true"
                        >
                            ✓
                        </span>
                        <span>{item.text}</span>
                    </li>
                ))}
            </ul>
        </section>
    )
}
