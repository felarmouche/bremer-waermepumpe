---
interface Props {
    href: string;
    title: string;
    description: string;
}
const { href, title, description } = Astro.props;
---

{/* Bewusst keine Überschrift: die Kachel ist vollständig ein Link auf eine
    andere Seite. Als <h3> würde der Linktext als Abschnittsthema *dieser*
    Seite gewertet und liesse sie um die Query der Zielseite mitkonkurrieren.
    Der Ankertext bleibt unverändert — er soll die Zielseite stärken. */}
<a href={href} class="surface-card p-6 sm:p-8 block hover:border-border-strong transition-colors group">
    <p class="font-semibold text-primary group-hover:text-primary-hover transition-colors">
        {title} <span class="inline-block ml-1">&rarr;</span>
    </p>
    <p class="text-text-muted text-sm mt-3 leading-relaxed">{description}</p>
</a>
