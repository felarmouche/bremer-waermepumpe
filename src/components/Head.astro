---
interface PageSchema {
    type?: "Article" | "HowTo";
    datePublished?: string;
    dateModified?: string;
    howToName?: string;
    howToDescription?: string;
    howToSteps?: { name: string; text: string }[];
}

interface Props {
    title: string;
    description: string;
    canonical?: string;
    ogImage?: string;
    noindex?: boolean;
    pageSchema?: PageSchema;
}
const { title, description, canonical, ogImage, noindex, pageSchema } =
    Astro.props;
const siteUrl = "https://bremer-waermepumpe.de";
const resolvedOgImage = ogImage
    ? `${siteUrl}${ogImage}`
    : `${siteUrl}/og-image.jpg`;

const articleJsonLd =
    pageSchema?.type === "Article" || pageSchema?.type === "HowTo"
        ? {
              "@context": "https://schema.org",
              "@type": "Article",
              headline: title,
              description,
              image: resolvedOgImage,
              author: {
                  "@type": "Organization",
                  name: "Bremer Wärmepumpe",
                  url: siteUrl,
              },
              publisher: {
                  "@type": "Organization",
                  name: "Bremer Wärmepumpe",
                  url: siteUrl,
              },
              ...(pageSchema.datePublished && {
                  datePublished: pageSchema.datePublished,
              }),
              ...(pageSchema.dateModified && {
                  dateModified: pageSchema.dateModified,
              }),
              ...(canonical && { mainEntityOfPage: canonical }),
              inLanguage: "de-DE",
          }
        : null;

const howToJsonLd =
    pageSchema?.type === "HowTo" &&
    pageSchema.howToSteps &&
    pageSchema.howToSteps.length > 0
        ? {
              "@context": "https://schema.org",
              "@type": "HowTo",
              name: pageSchema.howToName ?? title,
              description: pageSchema.howToDescription ?? description,
              step: pageSchema.howToSteps.map((s, i) => ({
                  "@type": "HowToStep",
                  position: i + 1,
                  name: s.name,
                  text: s.text,
              })),
              inLanguage: "de-DE",
          }
        : null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="robots" content={noindex ? "noindex, follow" : "index, follow"} />

<link rel="icon" href="/favicon.ico" />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:locale" content="de_DE" />
<meta property="og:site_name" content="Bremer Wärmepumpe" />

<script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Bremer Wärmepumpe",
        url: siteUrl,
        inLanguage: "de-DE",
    })}
/>

<script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Bremer Wärmepumpe",
        description:
            "Private Empfehlungsseite für einen lokalen SHK-Betrieb in Bremen und Umland.",
        url: siteUrl,
        publisher: {
            "@type": "Person",
            name: "Ferris El-Armouche",
            address: {
                "@type": "PostalAddress",
                streetAddress: "Spittaler Straße 1c",
                postalCode: "28359",
                addressLocality: "Bremen",
                addressCountry: "DE",
            },
            telephone: "+49 176 34690188",
            email: "bremerwaermepumpen@web.de",
        },
        areaServed: {
            "@type": "AdministrativeArea",
            name: "Bremen und Umland",
        },
        inLanguage: "de-DE",
    })}
/>

{
    articleJsonLd && (
        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify(articleJsonLd)}
        />
    )
}

{
    howToJsonLd && (
        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify(howToJsonLd)}
        />
    )
}
