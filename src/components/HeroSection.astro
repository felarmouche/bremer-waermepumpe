---
import { Image } from "astro:assets";

interface Props {
    imageSrc: ImageMetadata;
    headline: string;
    subtext: string;
    primaryCTA: { label: string; href: string };
    secondaryCTA?: { label: string; href: string };
}

const { imageSrc, headline, subtext, primaryCTA, secondaryCTA } = Astro.props;
---

<section
    class="relative w-full min-h-[75vh] flex items-center py-24 overflow-hidden bg-gray-900"
>
    <!-- Background Image with Professional Directional Gradient -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <Image
            src={imageSrc}
            alt="Wärmepumpe an einem Haus in Bremen"
            class="h-full w-full object-cover object-center opacity-90"
            sizes="100vw"
            priority
        />
        <!-- 
          Dark on mobile for readability. 
          On larger screens, it fades from dark on the left (for text) to transparent on the right (for the image). 
        -->
        <div
            class="absolute inset-0 bg-gray-950/60 sm:bg-gradient-to-r sm:from-gray-950/60 sm:via-gray-950/10 sm:to-transparent"
        >
        </div>
    </div>

    <!-- Content Container -->
    <div class="relative z-10 w-full mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
            <h1
                class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white text-balance leading-[1.15]"
            >
                {headline}
            </h1>

            <p
                class="mt-6 max-w-xl text-lg sm:text-xl text-gray-300 leading-relaxed text-balance"
            >
                {subtext}
            </p>

            <div class="mt-10 flex flex-col sm:flex-row items-start gap-4">
                <!-- Primary CTA: High contrast, bold, no shiny effects -->
                <a
                    href={primaryCTA.href}
                    class="inline-flex justify-center items-center px-8 py-3.5 text-base font-semibold text-gray-900 bg-white rounded-md transition-colors hover:bg-gray-200 w-full sm:w-auto"
                >
                    {primaryCTA.label}
                </a>

                <!-- Secondary CTA: Subtle outline, highly minimal -->
                {
                    secondaryCTA && (
                        <a
                            href={secondaryCTA.href}
                            class="inline-flex justify-center items-center px-8 py-3.5 text-base font-semibold text-white bg-transparent border-2 border-white/50 rounded-md transition-colors hover:bg-white/10 hover:border-white/60 w-full sm:w-auto"
                        >
                            {secondaryCTA.label}
                        </a>
                    )
                }
            </div>
        </div>
    </div>
</section>
