---
import { Image } from "astro:assets";
import HeroHeatingQuickstart from "./HeroHeatingQuickstart.astro";

interface Props {
    imageSrc: ImageMetadata;
    headline: string;
    subtext: string;
    primaryCTA: { label: string; href: string };
    secondaryCTA?: { label: string; href: string };
    showQuickstart?: boolean;
    quickstartLabel?: string;
}

const {
    imageSrc,
    headline,
    subtext,
    primaryCTA,
    secondaryCTA,
    showQuickstart = true,
    quickstartLabel,
} = Astro.props;
---

<section
    class:list={[
        "relative w-full flex items-center py-10 md:py-20 overflow-hidden bg-gray-900",
        showQuickstart ? "min-h-[46svh] md:min-h-[64svh]" : "min-h-[52svh] md:min-h-[70svh]",
    ]}
>
    <!-- Background Image with Directional Gradient -->
    <div class="absolute inset-0 z-0 pointer-events-none">
        <Image
            src={imageSrc}
            alt="Wärmepumpe an einem Haus in Bremen"
            class="h-full w-full object-cover object-center opacity-90"
            sizes="100vw"
            priority
        />
        <!--
          Dark on mobile for readability.
          Desktop: dark on left where text sits, fades right where the card sits.
        -->
        <div
            class="absolute inset-0 bg-gray-950/65 sm:bg-gradient-to-r sm:from-gray-950/50 sm:via-gray-950/20 sm:to-gray-950/5"
        >
        </div>
    </div>

    <!-- Content Container -->
    <div
        class="relative z-10 w-full grid grid-cols-1 md:grid-cols-12 gap-y-10 md:gap-x-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 items-center"
    >
        <div
            class:list={[
                showQuickstart ? "md:col-span-7" : "md:col-span-12 max-w-3xl",
            ]}
        >
            <h1
                class="text-3xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white text-balance leading-[1.12]"
            >
                {headline}
            </h1>

            <p
                class="mt-4 md:mt-6 max-w-xl text-base sm:text-xl text-gray-300 leading-relaxed text-balance"
            >
                {subtext}
            </p>

            {
                showQuickstart ? (
                    <>
                        {/* Mobile: keep both CTAs (the quickstart sits BELOW the hero on mobile) */}
                        <div class="mt-6 flex flex-col sm:flex-row items-start gap-3 md:hidden">
                            <a
                                href={primaryCTA.href}
                                class="inline-flex justify-center items-center px-6 py-3 text-base font-semibold text-gray-900 bg-white rounded-md transition-colors hover:bg-gray-100 w-full sm:w-auto"
                            >
                                {primaryCTA.label}
                            </a>
                            {secondaryCTA && (
                                <a
                                    href={secondaryCTA.href}
                                    class="inline-flex justify-center items-center px-6 py-3 text-base font-semibold text-white bg-transparent border-2 border-white/40 rounded-md transition-colors hover:bg-white/10 w-full sm:w-auto"
                                >
                                    {secondaryCTA.label}
                                </a>
                            )}
                        </div>
                        {/* Desktop: the quickstart card on the right IS the primary action.
                            Show only the secondary CTA as a subtle text link below the copy. */}
                        {secondaryCTA && (
                            <div class="hidden md:flex mt-8 items-center">
                                <a
                                    href={secondaryCTA.href}
                                    class="inline-flex items-center gap-2 text-base font-medium text-white/85 hover:text-white border-b border-white/30 hover:border-white/70 pb-0.5 transition-colors"
                                >
                                    <span>{secondaryCTA.label}</span>
                                    <span
                                        aria-hidden="true"
                                        class="transition-transform group-hover:translate-x-0.5"
                                    >
                                        →
                                    </span>
                                </a>
                            </div>
                        )}
                    </>
                ) : (
                    <div class="mt-10 flex flex-col sm:flex-row items-start gap-4">
                        <a
                            href={primaryCTA.href}
                            class="inline-flex justify-center items-center px-8 py-3.5 text-base font-semibold text-gray-900 bg-white rounded-md transition-colors hover:bg-gray-200 w-full sm:w-auto"
                        >
                            {primaryCTA.label}
                        </a>
                        {secondaryCTA && (
                            <a
                                href={secondaryCTA.href}
                                class="inline-flex justify-center items-center px-8 py-3.5 text-base font-semibold text-white bg-transparent border-2 border-white/50 rounded-md transition-colors hover:bg-white/10 hover:border-white/60 w-full sm:w-auto"
                            >
                                {secondaryCTA.label}
                            </a>
                        )}
                    </div>
                )
            }
        </div>

        {
            /* Quickstart card – DESKTOP ONLY (lives inside the hero, right column) */
        }
        {
            showQuickstart && (
                <div class="hidden md:block md:col-span-5">
                    <HeroHeatingQuickstart
                        ctaLabel={quickstartLabel}
                        layout="dark"
                    />
                </div>
            )
        }
    </div>
</section>

{
    /* Mobile-only quickstart band, sitting directly under the hero so the
    1-click entry stays visible without crowding the hero itself.
    No bottom border: the TrustBar below has its own border-y. */
}
{
    showQuickstart && (
        <section class="md:hidden bg-surface-alt py-4">
            <div class="mx-auto max-w-2xl px-4">
                <HeroHeatingQuickstart
                    ctaLabel={quickstartLabel}
                    layout="light"
                />
            </div>
        </section>
    )
}
