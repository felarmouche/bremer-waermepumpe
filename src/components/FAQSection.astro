---
interface Props {
    heading?: string;
    items: { question: string; answer: string }[];
}
const { heading = "Häufige Fragen", items } = Astro.props;
---

<section class="bg-background py-16 md:py-24 lg:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2
            class="text-2xl md:text-3xl font-bold tracking-tight text-text mb-10 lg:mb-14"
        >
            {heading}
        </h2>
        <div class="divide-y divide-border">
            {
                items.map((item: { question: string; answer: string }) => (
                    <details class="group py-5">
                        <summary class="cursor-pointer font-semibold text-text text-base sm:text-lg flex items-center justify-between">
                            {item.question}
                            <span class="text-text-muted text-sm ml-4 group-open:rotate-180 transition-transform">
                                &#9660;
                            </span>
                        </summary>
                        <div class="mt-4 text-text-muted leading-relaxed text-sm sm:text-base">
                            {item.answer}
                        </div>
                    </details>
                ))
            }
        </div>
    </div>
</section>
